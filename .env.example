# void-blog 环境变量
# D1 通过 Cloudflare Pages binding 直接访问，无需 API Key。
# 本地开发：wrangler pages dev dist --d1=void_blog_posts
# 部署：Cloudflare Pages Dashboard → Settings → Environment Variables

# 后台管理密码（必填，部署前在 CF Pages 环境变量里设置）
NUXT_ADMIN_PASSWORD=your-strong-password-here

# JWT 签名密钥（必填，随机字符串即可）
NUXT_JWT_SECRET=your-random-secret-here
