---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter(p => !p.id.startsWith('about'))

const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6)

const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))]

// Tag weights for cloud
const tagCounts = allPosts.flatMap(p => p.data.tags).reduce((acc, tag) => {
  acc[tag] = (acc[tag] || 0) + 1
  return acc
}, {} as Record<string, number>)
const maxCount = Math.max(...Object.values(tagCounts))
const tagCloud = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 18)

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' })

// Tag colors cycle
const tagColors = ['neon-green', 'neon-cyan', 'neon-purple', 'neon-pink']
const getTagColor = (tag: string) => {
  const idx = Math.abs(tag.split('').reduce((a, c) => a + c.charCodeAt(0), 0)) % tagColors.length
  return tagColors[idx]
}

// Tech stack data
const techStack = [
  {
    key: 'lang',
    color: 'neon-green',
    items: [
      { name: 'C++', color: 'neon-cyan' },
      { name: 'C#', color: 'neon-purple' },
      { name: 'TypeScript', color: 'neon-cyan' },
      { name: 'Python', color: 'neon-green' },
      { name: 'Rust (学习中)', color: 'neon-pink' },
    ],
  },
  {
    key: 'framework',
    color: 'neon-cyan',
    items: [
      { name: 'Vue 3', color: 'neon-green' },
      { name: 'React', color: 'neon-cyan' },
      { name: 'Electron', color: 'neon-purple' },
      { name: 'Astro', color: 'neon-pink' },
      { name: 'Qt', color: 'neon-cyan' },
    ],
  },
  {
    key: 'tools',
    color: 'neon-purple',
    items: [
      { name: 'Vite', color: 'neon-purple' },
      { name: 'CMake', color: 'neon-green' },
      { name: 'Git', color: 'neon-pink' },
      { name: 'Docker', color: 'neon-cyan' },
      { name: 'GitHub Actions', color: 'neon-green' },
    ],
  },
  {
    key: 'infra',
    color: 'neon-pink',
    items: [
      { name: 'Linux', color: 'neon-green' },
      { name: 'Windows', color: 'neon-cyan' },
      { name: 'VMware', color: 'neon-purple' },
      { name: 'Nginx', color: 'neon-pink' },
    ],
  },
  {
    key: 'ai',
    color: 'neon-cyan',
    items: [
      { name: 'OpenClaw', color: 'neon-green' },
      { name: 'LangChain', color: 'neon-cyan' },
      { name: 'Dify', color: 'neon-purple' },
      { name: 'RAG', color: 'neon-pink' },
    ],
  },
]
---

<BaseLayout title="void.dev">
  <div class="min-h-screen bg-[var(--color-void)]">

    <!-- Nav -->
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.85)] backdrop-blur-xl">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8">
        <a href="/void-blog/" class="font-mono font-bold text-[var(--color-neon-green)] glow-green text-sm tracking-widest">
          void.dev
        </a>
        <div class="ml-auto flex items-center gap-5 text-xs font-mono text-[var(--color-text-muted)]">
          <a href="/void-blog/blog/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/blog</a>
          <a href="/void-blog/tags/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/tags</a>
          <a href="/void-blog/search/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/search</a>
          <a href="/void-blog/blog/about/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/about</a>
          <a href="/void-blog/stats/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/stats</a>
          <a href="/void-blog/lab/" class="hover:text-[var(--color-neon-cyan)] transition-colors" style="color:rgba(180,0,255,0.9)">~/lab</a>
          <a href="https://github.com/Quantum505Void" target="_blank" rel="noopener"
             class="hover:text-[var(--color-neon-green)] transition-colors flex items-center gap-1">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <!-- Hero -->
    <section class="relative py-24 border-b border-[var(--color-void-border)] overflow-hidden">
      <!-- Background grid -->
      <div class="absolute inset-0 opacity-[0.03]"
           style="background-image: linear-gradient(var(--color-neon-green) 1px, transparent 1px), linear-gradient(90deg, var(--color-neon-green) 1px, transparent 1px); background-size: 40px 40px;"></div>
      <!-- Corner glow -->
      <div class="absolute top-0 right-0 w-96 h-96 rounded-full opacity-5"
           style="background: radial-gradient(circle, var(--color-neon-purple), transparent 70%); transform: translate(30%, -30%);"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 rounded-full opacity-5"
           style="background: radial-gradient(circle, var(--color-neon-cyan), transparent 70%); transform: translate(-30%, 30%);"></div>

      <div class="relative max-w-5xl mx-auto px-6">
        <div class="flex items-start gap-4 mb-8">
          <div class="mt-2 w-2 h-2 rounded-full bg-[var(--color-neon-green)] animate-pulse shrink-0"
               style="animation: pulse 1.5s ease-in-out infinite;"></div>
          <div>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] tracking-[0.2em] uppercase mb-3">
              process started
            </p>
            <h1 class="text-5xl sm:text-7xl font-bold font-mono leading-none mb-6">
              <span class="text-[var(--color-text-primary)]">void</span><span
                class="gradient-text">.</span><span
                class="text-[var(--color-neon-cyan)]">dev</span><span
                class="cursor-blink text-[var(--color-neon-green)] text-4xl sm:text-5xl"></span>
            </h1>
            <div class="font-mono text-sm space-y-2.5 max-w-xl">
              <p class="animate-fade-up" style="animation-delay:0.1s;color:#c8c8e0">
                <span style="color:#b400ff">interest</span>
                <span style="color:#6666aa"> = </span>
                <span id="hero-line-0" style="color:#00d4ff">["\u7cfb\u7edf", "\u5de5\u5177\u94fe", "\u684c\u9762\u5e94\u7528", "AI Agent", "...\u66f4\u591a"]</span>
              </p>
              <p class="animate-fade-up" style="animation-delay:0.2s;color:#c8c8e0">
                <span style="color:#b400ff">stack</span>
                <span style="color:#6666aa"> = </span>
                <span id="hero-line-1" style="color:#39ff14">["C++", "TypeScript", "Vue", "Electron", "Astro"]</span>
              </p>
              <p class="animate-fade-up" style="animation-delay:0.3s;color:#c8c8e0">
                <span style="color:#b400ff">status</span>
                <span style="color:#6666aa"> = </span>
                <span id="hero-line-2" style="color:#39ff14">\u5728\u7ebf \u25cf</span>
              </p>
            </div>
          </div>
        </div>

        <!-- Stats bar -->
        <div class="flex gap-8 font-mono text-xs text-[var(--color-text-muted)] animate-fade-up" style="animation-delay:0.4s">
          <div class="flex items-center gap-2">
            <span class="text-[var(--color-neon-green)]">▸</span>
            <span style="color:#e8e8f0;font-weight:bold">{allPosts.length}</span>
            <span>篇文章</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[var(--color-neon-cyan)]">▸</span>
            <span style="color:#e8e8f0;font-weight:bold">{allTags.length}</span>
            <span>个标签</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-[var(--color-neon-purple)]">▸</span>
            <span style="color:#e8e8f0;font-weight:bold">2021</span>
            <span>年至今</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Stack section -->
    <section class="border-b border-[var(--color-void-border)] py-10 overflow-hidden">
      <div class="max-w-5xl mx-auto px-6">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] tracking-[0.2em] uppercase mb-6 flex items-center gap-3">
          <span class="text-[var(--color-neon-green)]">▶</span>
          tech_stack.json
          <span class="flex-1 h-px bg-gradient-to-r from-[var(--color-void-border)] to-transparent"></span>
        </p>
        <div class="space-y-3 font-mono text-sm">
          {techStack.map((row) => (
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-2">
              <span class={`text-[var(--color-${row.color})] shrink-0 w-24 text-right`}>{row.key}</span>
              <span class="text-[var(--color-text-muted)] shrink-0">=</span>
              <div class="flex flex-wrap gap-1.5">
                {row.items.map((item, idx) => {
                  const neonColors = ['neon-green', 'neon-cyan', 'neon-purple', 'neon-pink']
                  const c = item.color || neonColors[idx % neonColors.length]
                  return (
                    <span
                      class="tech-badge px-2.5 py-0.5 rounded-full text-xs border font-mono cursor-default transition-all duration-200"
                      style={`color: var(--color-${c}); border-color: color-mix(in srgb, var(--color-${c}) 30%, transparent); background: color-mix(in srgb, var(--color-${c}) 8%, transparent);`}
                      data-color={c}
                    >
                      {item.name}
                    </span>
                  )
                })}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Content grid -->
    <div class="max-w-5xl mx-auto px-6 py-16 grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12">

      <!-- Posts list -->
      <section>
        <h2 class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-[0.2em] mb-6 flex items-center gap-3">
          <span class="text-[var(--color-neon-green)]">▶</span>
          最新文章
          <span class="flex-1 h-px bg-gradient-to-r from-[var(--color-void-border)] to-transparent"></span>
        </h2>

        <div class="space-y-2">
          {posts.map((post, i) => {
            const slug = post.id.replace(/\.mdx?$/, '')
            const color = getTagColor(post.data.tags[0] ?? '')
            return (
              <a
                href={`/void-blog/blog/${slug}/`}
                class="group block p-4 rounded-xl border border-transparent hover:border-[var(--color-void-border)] hover:bg-[var(--color-void-card)] transition-all duration-200 animate-fade-up"
                style={`animation-delay: ${i * 0.05}s`}
              >
                <div class="flex items-start gap-4">
                  <!-- Color accent bar -->
                  <div class={`shrink-0 w-0.5 h-full self-stretch rounded-full mt-1 bg-[var(--color-${color})] opacity-50 group-hover:opacity-100 transition-opacity`}
                       style={`background: var(--color-${color}); min-height: 2.5rem;`}></div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-4">
                      <h3 class="font-mono text-sm text-[var(--color-text-primary)] group-hover:text-[var(--color-neon-cyan)] transition-colors leading-snug">
                        {post.data.title}
                      </h3>
                      <time datetime={post.data.pubDate.toISOString()}
                            class="font-mono text-[10px] text-[var(--color-text-muted)] shrink-0 pt-0.5">
                        {formatDate(post.data.pubDate)}
                      </time>
                    </div>
                    {post.data.description && (
                      <p class="text-xs mt-1 line-clamp-1 leading-relaxed" style="color:#9999bb">
                        {post.data.description}
                      </p>
                    )}
                    <div class="flex flex-wrap gap-1.5 mt-2">
                      {post.data.tags.slice(0, 3).map(tag => (
                        <span class="font-mono text-[10px] px-2 py-0.5 rounded-full bg-[var(--color-void-muted)] text-[var(--color-text-muted)]">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              </a>
            )
          })}
        </div>

        <div class="mt-6">
          <a href="/void-blog/blog/"
             class="inline-flex items-center gap-2 font-mono text-xs text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors border border-[var(--color-void-border)] hover:border-[rgba(0,212,255,0.3)] px-4 py-2 rounded-lg">
            查看全部 {allPosts.length} 篇文章 →
          </a>
        </div>
      </section>

      <!-- Sidebar -->
      <aside class="space-y-8">

        <!-- About card - antfu style: minimal, dense, every line has value -->
        <div class="space-y-px">
          {[
            { label: '王宇', sub: 'C++ / 桌面 / AI Agent', color: 'var(--color-neon-green)' },
          ].map(({ label, sub, color }) => (
            <div class="font-mono text-xs text-[var(--color-text-muted)] py-1">
              <span style={`color:${color}`}>{label}</span>
              <span class="ml-2 text-[10px]">{sub}</span>
            </div>
          ))}
          <div class="pt-3 mt-2 border-t border-[var(--color-void-border)] flex flex-wrap gap-x-4 gap-y-1.5">
            {[
              {href:'https://github.com/Quantum505Void', label:'GitHub'},
              {href:'/void-blog/rss.xml', label:'RSS'},
              {href:'/void-blog/search/', label:'Search'},
              {href:'/void-blog/stats/', label:'Stats'},
              {href:'/void-blog/lab/', label:'Lab'},
            ].map(({href, label}) => (
              <a href={href} target={href.startsWith('http')?'_blank':undefined} rel={href.startsWith('http')?'noopener':undefined}
                 class="font-mono text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors">
                {label} ↗
              </a>
            ))}
          </div>
        </div>

        <!-- Quick tag links (replace tag cloud) -->
        <div>
          <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-[0.2em] mb-3">
            <span class="text-[var(--color-neon-purple)]">▶</span> 热门标签
          </p>
          <div class="flex flex-wrap gap-1.5">
            {Object.entries(tagCounts)
              .sort((a, b) => b[1] - a[1])
              .slice(0, 10)
              .map(([tag]) => (
                <a href={`/void-blog/tags/${tag}/`}
                   class="font-mono text-[10px] px-2 py-0.5 rounded border border-[var(--color-void-border)] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] hover:border-[rgba(0,212,255,0.3)] transition-all">
                  #{tag}
                </a>
              ))}
          </div>
        </div>

      </aside>
    </div>

    <!-- Footer -->
    <footer class="border-t border-[var(--color-void-border)] py-10">
      <div class="max-w-5xl mx-auto px-6">
        <div class="font-mono text-[10px] text-[var(--color-text-muted)] text-center mb-4 opacity-30 select-none leading-relaxed">
          {'░▒▓ void.dev ▓▒░'}
        </div>
        <div class="flex items-center justify-between flex-wrap gap-4 font-mono text-xs text-[var(--color-text-muted)]">
          <span>
            构建于 <span class="text-[var(--color-neon-cyan)]">Astro 6</span> ·
            <span class="text-[var(--color-neon-purple)]">Tailwind v4</span> ·
            <span class="text-[var(--color-neon-green)]">Vue 3</span>
          </span>
          <span>© 2021–2026 王宇</span>
        </div>
      </div>
    </footer>
  </div>

  <style>
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }
    .tech-badge:hover {
      filter: brightness(1.3);
      box-shadow: 0 0 8px color-mix(in srgb, currentColor 40%, transparent);
    }
  </style>

  <script is:inline>
  // Terminal typewriter on hero
  document.addEventListener('DOMContentLoaded', () => {
    const lines = [
      { el: 'hero-line-0', text: 'interest = ["系统", "工具链", "桌面", "AI Agent"]', delay: 200 },
      { el: 'hero-line-1', text: 'stack    = ["C++", "TypeScript", "Vue", "Astro"]',  delay: 600 },
      { el: 'hero-line-2', text: 'status   = 在线 ●',                                  delay: 1000 },
    ]
    lines.forEach(({el, text, delay}) => {
      const node = document.getElementById(el)
      if (!node) return
      node.textContent = ''
      let i = 0
      setTimeout(() => {
        const timer = setInterval(() => {
          node.textContent += text[i++]
          if (i >= text.length) clearInterval(timer)
        }, 18)
      }, delay)
    })
  })
  </script>

</BaseLayout>
