---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Minesweeper from '../../components/Minesweeper.vue'
---

<BaseLayout title="Minesweeper | void.dev">
  <div class="min-h-screen bg-[var(--color-void)]">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.85)] backdrop-blur-xl">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8">
        <a href="/void-blog/" class="font-mono font-bold text-[var(--color-neon-green)] text-sm tracking-widest">void.dev</a>
        <div class="ml-auto flex items-center gap-2 text-xs font-mono text-[var(--color-text-muted)]">
          <a href="/void-blog/lab/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/lab</a>
          <span class="opacity-40">/</span>
          <span class="text-[rgba(255,0,170,0.9)]">minesweeper</span>
        </div>
      </div>
    </nav>

    <div class="max-w-5xl mx-auto px-6 py-10">
      <div class="mb-6 text-center">
        <h1 class="font-mono text-4xl font-bold text-[var(--color-text-primary)] mb-2">
          <span class="text-[rgba(255,0,170,0.9)]">💣</span> Minesweeper
        </h1>
        <p class="font-mono text-sm text-[var(--color-text-muted)]">扫雷 — 终端 ASCII 风格</p>
      </div>

      <Minesweeper client:load />
    </div>
  </div>
</BaseLayout>
