---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="Minesweeper | void.dev">
  <div class="min-h-screen bg-[var(--color-void)]">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.85)] backdrop-blur-xl">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8">
        <a href="/void-blog/" class="font-mono font-bold text-[var(--color-neon-green)] text-sm tracking-widest">void.dev</a>
        <div class="ml-auto flex items-center gap-2 text-xs font-mono text-[var(--color-text-muted)]">
          <a href="/void-blog/lab/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/lab</a>
          <span class="opacity-40">/</span>
          <span class="text-[rgba(255,0,170,0.9)]">minesweeper</span>
        </div>
      </div>
    </nav>

    <div class="max-w-5xl mx-auto px-6 py-10">
      <div class="mb-6 text-center">
        <h1 class="font-mono text-4xl font-bold text-[var(--color-text-primary)] mb-2">
          <span class="text-[rgba(255,0,170,0.9)]">💣</span> Minesweeper
        </h1>
        <p class="font-mono text-sm text-[var(--color-text-muted)]">扫雷 — 终端 ASCII 风格</p>
      </div>

      <!-- Controls -->
      <div class="flex flex-wrap items-center justify-center gap-4 mb-5">
        <div class="flex gap-2">
          {[
            {id:'easy',   label:'初级 9×9/10',    },
            {id:'medium', label:'中级 16×16/40',  },
            {id:'hard',   label:'高级 30×16/99',  },
          ].map(({id, label}) => (
            <button
              id={`btn-${id}`}
              data-diff={id}
              class="diff-btn font-mono text-xs px-3 py-1.5 rounded-lg border border-[rgba(255,0,170,0.3)] text-[rgba(255,0,170,0.7)] hover:bg-[rgba(255,0,170,0.1)] transition-colors"
            >
              {label}
            </button>
          ))}
        </div>
      </div>

      <!-- Status bar -->
      <div class="flex items-center justify-center gap-8 mb-5 font-mono">
        <div class="flex items-center gap-2 border border-[rgba(255,0,170,0.2)] rounded-lg px-4 py-2 bg-[var(--color-void-card)]">
          <span class="text-[rgba(255,0,170,0.7)] text-sm">💣</span>
          <span id="mine-count" class="text-[rgba(255,0,170,0.9)] font-bold text-lg min-w-[2.5rem] text-center">10</span>
        </div>
        <button id="reset-btn" class="text-2xl hover:scale-110 transition-transform" title="New Game">🙂</button>
        <div class="flex items-center gap-2 border border-[rgba(255,0,170,0.2)] rounded-lg px-4 py-2 bg-[var(--color-void-card)]">
          <span class="text-[rgba(0,212,255,0.7)] text-sm">⏱</span>
          <span id="timer" class="text-[rgba(0,212,255,0.9)] font-bold text-lg min-w-[2.5rem] text-center">0</span>
        </div>
      </div>

      <!-- Board container -->
      <div class="flex justify-center overflow-x-auto">
        <div id="ms-board" class="font-mono select-none" style="line-height:1;display:inline-block;overflow-x:auto;max-width:100%"></div>
      </div>

      <div class="mt-6 text-center font-mono text-xs text-[var(--color-text-muted)] opacity-60">
        左键翻开 &nbsp;·&nbsp; 右键插旗 &nbsp;·&nbsp; 第一次点击永远安全
      </div>
    </div>
  </div>

  <style>
    .ms-cell {
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: bold;
      cursor: pointer;
      border-radius: 4px;
      border: 1px solid rgba(255,0,170,0.15);
      background: rgba(255,0,170,0.06);
      transition: background 0.1s, box-shadow 0.1s;
      user-select: none;
      vertical-align: middle;
    }
    .ms-cell:hover:not(.revealed):not(.flagged) {
      background: rgba(255,0,170,0.15);
      box-shadow: 0 0 8px rgba(255,0,170,0.3);
    }
    .ms-cell.revealed {
      background: rgba(255,255,255,0.04);
      cursor: default;
      border-color: rgba(255,255,255,0.05);
    }
    .ms-cell.flagged {
      background: rgba(255,0,170,0.12);
    }
    .ms-cell.boom {
      background: rgba(255,50,50,0.3);
      border-color: rgba(255,50,50,0.5);
      box-shadow: 0 0 12px rgba(255,50,50,0.6);
    }
    .ms-row {
      display: flex;
      flex-wrap: nowrap;
      gap: 2px;
      margin-bottom: 2px;
    }
    .diff-btn.active {
      background: rgba(255,0,170,0.15);
      border-color: rgba(255,0,170,0.6);
      color: rgba(255,0,170,1);
    }
    .num-1 { color: rgba(0,212,255,0.9); }
    .num-2 { color: rgba(57,255,20,0.9); }
    .num-3 { color: rgba(255,165,0,0.9); }
    .num-4 { color: rgba(255,0,170,0.9); }
    .num-5 { color: rgba(180,0,255,0.9); }
    .num-6 { color: rgba(0,255,255,0.9); }
    .num-7 { color: rgba(255,255,255,0.9); }
    .num-8 { color: rgba(150,150,150,0.9); }
  </style>

  <script is:inline>
document.addEventListener("DOMContentLoaded", function() {

    interface Difficulty {
      rows: number
      cols: number
      mines: number
    }

    const DIFFICULTIES: Record<string, Difficulty> = {
      easy:   {rows:9,  cols:9,  mines:10},
      medium: {rows:16, cols:16, mines:40},
      hard:   {rows:16, cols:30, mines:99},
    }

    let diff: Difficulty = DIFFICULTIES.easy
    let currentDiffKey = 'easy'
    let board: number[][] = []      // -1 = mine, 0-8 = neighbor count
    let revealed: boolean[][] = []
    let flagged: boolean[][] = []
    let firstClick = true
    let gameOver = false
    let gameWon = false
    let timerInterval: ReturnType<typeof setInterval> | null = null
    let seconds = 0
    let remainingMines = 0

    const boardEl = document.getElementById('ms-board')!
    const mineCountEl = document.getElementById('mine-count')!
    const timerEl = document.getElementById('timer')!
    const resetBtn = document.getElementById('reset-btn')!

    function startGame(diffKey: string) {
      currentDiffKey = diffKey
      diff = DIFFICULTIES[diffKey]
      board = Array.from({length: diff.rows}, () => Array(diff.cols).fill(0))
      revealed = Array.from({length: diff.rows}, () => Array(diff.cols).fill(false))
      flagged = Array.from({length: diff.rows}, () => Array(diff.cols).fill(false))
      firstClick = true
      gameOver = false
      gameWon = false
      remainingMines = diff.mines
      mineCountEl.textContent = String(remainingMines)
      stopTimer()
      seconds = 0
      timerEl.textContent = '0'
      resetBtn.textContent = '🙂'

      // Highlight active difficulty button
      document.querySelectorAll<HTMLElement>('.diff-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.diff === diffKey)
      })

      renderBoard()
    }

    function placeMines(excludeR: number, excludeC: number) {
      const positions: [number, number][] = []
      for (let r = 0; r < diff.rows; r++)
        for (let c = 0; c < diff.cols; c++) {
          // Exclude the clicked cell and its neighbors
          if (Math.abs(r - excludeR) <= 1 && Math.abs(c - excludeC) <= 1) continue
          positions.push([r, c])
        }
      // Shuffle and pick
      for (let i = positions.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1))
        ;[positions[i], positions[j]] = [positions[j], positions[i]]
      }
      for (let i = 0; i < diff.mines; i++) {
        const [r, c] = positions[i]
        board[r][c] = -1
      }
      // Calculate neighbor counts
      for (let r = 0; r < diff.rows; r++)
        for (let c = 0; c < diff.cols; c++) {
          if (board[r][c] === -1) continue
          let count = 0
          for (let dr = -1; dr <= 1; dr++)
            for (let dc = -1; dc <= 1; dc++) {
              const nr = r + dr, nc = c + dc
              if (nr >= 0 && nr < diff.rows && nc >= 0 && nc < diff.cols && board[nr][nc] === -1)
                count++
            }
          board[r][c] = count
        }
    }

    function reveal(r: number, c: number) {
      if (r < 0 || r >= diff.rows || c < 0 || c >= diff.cols) return
      if (revealed[r][c] || flagged[r][c]) return
      revealed[r][c] = true
      if (board[r][c] === 0) {
        // BFS expand
        const queue: [number, number][] = [[r, c]]
        while (queue.length > 0) {
          const [cr, cc] = queue.shift()!
          for (let dr = -1; dr <= 1; dr++)
            for (let dc = -1; dc <= 1; dc++) {
              const nr = cr + dr, nc = cc + dc
              if (nr >= 0 && nr < diff.rows && nc >= 0 && nc < diff.cols && !revealed[nr][nc] && !flagged[nr][nc]) {
                revealed[nr][nc] = true
                if (board[nr][nc] === 0) queue.push([nr, nc])
              }
            }
        }
      }
    }

    function checkWin(): boolean {
      for (let r = 0; r < diff.rows; r++)
        for (let c = 0; c < diff.cols; c++)
          if (board[r][c] !== -1 && !revealed[r][c]) return false
      return true
    }

    function handleClick(r: number, c: number) {
      if (gameOver || gameWon) return
      if (flagged[r][c]) return
      if (revealed[r][c]) return

      if (firstClick) {
        firstClick = false
        placeMines(r, c)
        startTimer()
      }

      if (board[r][c] === -1) {
        // Boom!
        gameOver = true
        revealed[r][c] = true
        stopTimer()
        resetBtn.textContent = '😵'
        // Reveal all mines
        for (let rr = 0; rr < diff.rows; rr++)
          for (let cc = 0; cc < diff.cols; cc++)
            if (board[rr][cc] === -1) revealed[rr][cc] = true
        renderBoard()
        // Mark the hit cell
        const cells = boardEl.querySelectorAll('.ms-cell')
        const idx = r * diff.cols + c
        cells[idx].classList.add('boom')
        return
      }

      reveal(r, c)

      if (checkWin()) {
        gameWon = true
        stopTimer()
        resetBtn.textContent = '😎'
        // Flag all remaining mines
        for (let rr = 0; rr < diff.rows; rr++)
          for (let cc = 0; cc < diff.cols; cc++)
            if (board[rr][cc] === -1) flagged[rr][cc] = true
        remainingMines = 0
        mineCountEl.textContent = '0'
      }

      renderBoard()
    }

    function handleRightClick(e: MouseEvent, r: number, c: number) {
      e.preventDefault()
      if (gameOver || gameWon) return
      if (revealed[r][c]) return

      flagged[r][c] = !flagged[r][c]
      remainingMines += flagged[r][c] ? -1 : 1
      mineCountEl.textContent = String(remainingMines)
      renderBoard()
    }

    function renderBoard() {
      boardEl.innerHTML = ''
      for (let r = 0; r < diff.rows; r++) {
        const rowEl = document.createElement('div')
        rowEl.className = 'ms-row'
        for (let c = 0; c < diff.cols; c++) {
          const cell = document.createElement('div')
          cell.className = 'ms-cell'

          if (flagged[r][c] && !revealed[r][c]) {
            cell.textContent = '🚩'
            cell.classList.add('flagged')
          } else if (!revealed[r][c]) {
            cell.textContent = '▓'
            cell.style.color = 'rgba(255,0,170,0.3)'
          } else if (board[r][c] === -1) {
            cell.textContent = '💣'
            cell.classList.add('revealed')
          } else {
            cell.classList.add('revealed')
            if (board[r][c] > 0) {
              cell.textContent = String(board[r][c])
              cell.classList.add(`num-${board[r][c]}`)
            } else {
              cell.textContent = ''
            }
          }

          const rr = r, cc = c
          cell.addEventListener('click', () => handleClick(rr, cc))
          cell.addEventListener('contextmenu', e => handleRightClick(e, rr, cc))
          rowEl.appendChild(cell)
        }
        boardEl.appendChild(rowEl)
      }
    }

    function startTimer() {
      timerInterval = setInterval(() => {
        seconds++
        timerEl.textContent = String(Math.min(seconds, 999))
      }, 1000)
    }

    function stopTimer() {
      if (timerInterval) { clearInterval(timerInterval); timerInterval = null }
    }

    // Init
    startGame('easy')

    resetBtn.addEventListener('click', () => startGame(currentDiffKey))

    document.querySelectorAll<HTMLElement>('.diff-btn').forEach(btn => {
      btn.addEventListener('click', () => startGame(btn.dataset.diff!))
    })
  
});
</script>
</BaseLayout>
