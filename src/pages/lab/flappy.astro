---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="Flappy Bird | void.dev">
  <div class="min-h-screen bg-[var(--color-void)] flex flex-col items-center justify-center p-4">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.85)] backdrop-blur-xl">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-4">
        <a href="/void-blog/" class="font-mono text-sm text-[var(--color-neon-green)] hover:opacity-80 transition-all">~/void-blog</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <a href="/void-blog/lab/" class="font-mono text-xs text-[var(--color-neon-cyan)] hover:opacity-80 transition-all">lab</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="font-mono text-xs" style="color:#ffa500">flappy</span>
      </div>
    </nav>

    <div class="pt-20 w-full max-w-sm">
      <div class="text-center mb-4">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] tracking-[0.25em] uppercase mb-2">process: flappy.exe</p>
        <h1 class="font-mono text-2xl font-bold mb-1" style="color:#ffa500;text-shadow:0 0 20px rgba(255,165,0,0.5)">FLAPPY BIRD</h1>
        <p class="font-mono text-xs text-[var(--color-text-muted)]">Space / 点击 / 触屏 跳跃</p>
      </div>

      <div class="flex justify-center">
        <div class="relative border border-[var(--color-void-border)] rounded-xl overflow-hidden"
          style="box-shadow:0 0 40px rgba(255,165,0,0.08),inset 0 0 60px rgba(0,0,0,0.5)">
          <canvas id="flappy-canvas" width="320" height="480" style="display:block;cursor:pointer"></canvas>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  const canvas = document.getElementById('flappy-canvas')
  const ctx = canvas.getContext('2d')
  const W = canvas.width
  const H = canvas.height

  const GRAVITY = 0.45
  const JUMP_FORCE = -7.5
  const PIPE_SPEED = 2.5
  const PIPE_GAP = 140
  const PIPE_WIDTH = 52
  const PIPE_INTERVAL = 1900

  // Stars
  const stars = Array.from({length: 80}, () => ({
    x: Math.random() * W,
    y: Math.random() * H,
    size: Math.random() * 1.5 + 0.3,
    speed: Math.random() * 0.3 + 0.1,
    alpha: Math.random() * 0.6 + 0.2,
  }))

  let state = 'idle'
  let bird = {}
  let pipes = []
  let score = 0
  let best = parseInt(localStorage.getItem('flappy-best') || '0')
  let lastPipe = 0
  let animFrame = 0
  let lastTime = 0
  let deathTimer = 0

  function resetBird() {
    bird = { x: 60, y: H / 2, vy: 0, w: 18, h: 14, dead: false, angle: 0 }
  }

  function addPipe() {
    const minTop = 60
    const maxTop = H - PIPE_GAP - 60
    const topH = Math.random() * (maxTop - minTop) + minTop
    pipes.push({ x: W + 10, topH, scored: false })
  }

  function jump() {
    if (state === 'idle') {
      state = 'running'
      lastPipe = performance.now()
      addPipe()
    }
    if (state === 'dead') {
      setTimeout(() => {
        state = 'idle'
        pipes = []
        score = 0
        resetBird()
      }, 50)
      return
    }
    if (state === 'running') {
      bird.vy = JUMP_FORCE
    }
  }

  function checkCollision() {
    const bx = bird.x - bird.w / 2
    const by = bird.y - bird.h / 2
    const bx2 = bx + bird.w
    const by2 = by + bird.h

    if (by <= 0 || by2 >= H) return true

    for (const p of pipes) {
      const px = p.x - PIPE_WIDTH / 2
      const px2 = px + PIPE_WIDTH
      if (bx2 > px + 4 && bx < px2 - 4) {
        if (by < p.topH - 4 || by2 > p.topH + PIPE_GAP + 4) return true
      }
    }
    return false
  }

  function drawBackground() {
    // Dark gradient
    const grad = ctx.createLinearGradient(0, 0, 0, H)
    grad.addColorStop(0, '#050510')
    grad.addColorStop(1, '#0a0a1a')
    ctx.fillStyle = grad
    ctx.fillRect(0, 0, W, H)

    // Stars with parallax
    stars.forEach(s => {
      ctx.globalAlpha = s.alpha
      ctx.fillStyle = '#ffffff'
      ctx.beginPath()
      ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2)
      ctx.fill()
    })
    ctx.globalAlpha = 1
  }

  function drawPipe(p) {
    const x = p.x - PIPE_WIDTH / 2
    const topH = p.topH
    const botY = topH + PIPE_GAP
    const botH = H - botY

    // Top pipe
    const topGrad = ctx.createLinearGradient(x, 0, x + PIPE_WIDTH, 0)
    topGrad.addColorStop(0, 'rgba(0,40,50,0.9)')
    topGrad.addColorStop(0.3, 'rgba(0,80,100,0.9)')
    topGrad.addColorStop(1, 'rgba(0,40,50,0.9)')
    ctx.fillStyle = topGrad
    ctx.fillRect(x, 0, PIPE_WIDTH, topH)

    // Top pipe cap
    ctx.fillStyle = 'rgba(0,100,130,0.9)'
    ctx.fillRect(x - 4, topH - 20, PIPE_WIDTH + 8, 20)

    // Bottom pipe
    ctx.fillStyle = topGrad
    ctx.fillRect(x, botY, PIPE_WIDTH, botH)

    // Bottom pipe cap
    ctx.fillRect(x - 4, botY, PIPE_WIDTH + 8, 20)

    // Glow
    ctx.shadowColor = '#00d4ff'
    ctx.shadowBlur = 12
    ctx.strokeStyle = 'rgba(0,212,255,0.5)'
    ctx.lineWidth = 1.5
    ctx.strokeRect(x, 0, PIPE_WIDTH, topH)
    ctx.strokeRect(x - 4, topH - 20, PIPE_WIDTH + 8, 20)
    ctx.strokeRect(x, botY, PIPE_WIDTH, botH)
    ctx.strokeRect(x - 4, botY, PIPE_WIDTH + 8, 20)
    ctx.shadowBlur = 0
  }

  function drawBird() {
    ctx.save()
    ctx.translate(bird.x, bird.y)
    const angle = Math.max(-0.5, Math.min(1.2, bird.vy * 0.07))
    ctx.rotate(angle)

    const bw = bird.w, bh = bird.h

    // Glow
    ctx.shadowColor = '#39ff14'
    ctx.shadowBlur = bird.dead ? 4 : 16

    // Body
    ctx.fillStyle = bird.dead ? '#555566' : '#39ff14'
    ctx.fillRect(-bw / 2, -bh / 2, bw, bh)

    // Highlight
    ctx.fillStyle = bird.dead ? 'rgba(255,255,255,0.1)' : 'rgba(255,255,255,0.35)'
    ctx.fillRect(-bw / 2, -bh / 2, bw, 3)

    ctx.shadowBlur = 0
    ctx.restore()
  }

  function drawScore() {
    ctx.font = 'bold 32px monospace'
    ctx.textAlign = 'center'
    ctx.shadowColor = '#ffa500'
    ctx.shadowBlur = 15
    ctx.fillStyle = '#ffa500'
    ctx.fillText(score, W / 2, 48)
    ctx.shadowBlur = 0

    ctx.font = '11px monospace'
    ctx.fillStyle = 'rgba(255,165,0,0.5)'
    ctx.fillText('BEST: ' + best, W / 2, 66)
    ctx.textAlign = 'left'
  }

  function drawIdle() {
    drawBackground()
    drawBird()
    ctx.font = 'bold 22px monospace'
    ctx.textAlign = 'center'
    ctx.shadowColor = '#ffa500'
    ctx.shadowBlur = 20
    ctx.fillStyle = '#ffa500'
    ctx.fillText('FLAPPY BIRD', W / 2, H / 2 - 40)
    ctx.shadowBlur = 0
    ctx.font = '12px monospace'
    ctx.fillStyle = 'rgba(255,255,255,0.5)'
    ctx.fillText('Space / Tap 开始', W / 2, H / 2 - 10)
    ctx.font = '10px monospace'
    ctx.fillStyle = 'rgba(255,255,255,0.25)'
    ctx.fillText('BEST: ' + best, W / 2, H / 2 + 12)
    ctx.textAlign = 'left'
  }

  function drawDead() {
    ctx.font = 'bold 28px monospace'
    ctx.textAlign = 'center'
    ctx.shadowColor = '#ff4444'
    ctx.shadowBlur = 20
    ctx.fillStyle = '#ff4444'
    ctx.fillText('DEAD', W / 2, H / 2 - 30)
    ctx.shadowBlur = 0
    ctx.font = '16px monospace'
    ctx.fillStyle = '#ffa500'
    ctx.fillText('SCORE: ' + score, W / 2, H / 2)
    ctx.font = '12px monospace'
    ctx.fillStyle = 'rgba(255,255,255,0.4)'
    ctx.fillText('BEST: ' + best, W / 2, H / 2 + 22)
    ctx.font = '11px monospace'
    ctx.fillStyle = 'rgba(255,255,255,0.35)'
    ctx.fillText('Space / Tap 重试', W / 2, H / 2 + 50)
    ctx.textAlign = 'left'
  }

  function update(now) {
    if (state !== 'running') return
    const dt = Math.min(now - lastTime, 50)
    lastTime = now

    // Move stars
    stars.forEach(s => { s.x -= s.speed; if (s.x < 0) { s.x = W; s.y = Math.random() * H } })

    // Bird physics
    bird.vy += GRAVITY
    bird.vy = Math.min(bird.vy, 12)
    bird.y += bird.vy

    // Pipe spawning
    if (now - lastPipe > PIPE_INTERVAL) {
      addPipe()
      lastPipe = now
    }

    // Move pipes & score
    pipes.forEach(p => {
      p.x -= PIPE_SPEED
      if (!p.scored && p.x < bird.x) {
        p.scored = true
        score++
        if (score > best) {
          best = score
          localStorage.setItem('flappy-best', best)
        }
      }
    })
    pipes = pipes.filter(p => p.x > -PIPE_WIDTH)

    // Collision
    if (checkCollision()) {
      state = 'dead'
      bird.dead = true
      bird.vy = -5
    }
  }

  function render(now) {
    if (state === 'idle') { drawIdle(); return }
    drawBackground()
    pipes.forEach(drawPipe)
    drawBird()
    drawScore()
    if (state === 'dead') drawDead()
  }

  function loop(now) {
    lastTime = lastTime || now
    update(now)
    render(now)
    lastTime = now
    animFrame = requestAnimationFrame(loop)
  }

  canvas.addEventListener('click', jump)
  canvas.addEventListener('touchstart', function(e) { e.preventDefault(); jump() }, { passive: false })
  document.addEventListener('keydown', function(e) {
    if (e.code === 'Space') { e.preventDefault(); jump() }
  })

  resetBird()
  animFrame = requestAnimationFrame(loop)
})
</script>
