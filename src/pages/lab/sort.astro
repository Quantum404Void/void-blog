---
export const prerender = true
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="Sort Visualizer | void.dev">
  <div class="min-h-screen bg-[var(--color-void)] flex flex-col">
    <!-- Nav -->
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.85)] backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 h-14 flex items-center gap-4">
        <a href="/lab/" class="font-mono text-sm text-[var(--color-neon-green)] transition-all">~/lab</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="font-mono text-xs text-[var(--color-neon-purple)]">sort</span>
      </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 py-4 flex-1 flex flex-col gap-3 w-full">

      <!-- Algo selector row -->
      <div class="flex flex-wrap gap-2">
        {[
          ['bubble','冒泡','O(n²)','#00d4ff'],
          ['selection','选择','O(n²)','#39ff14'],
          ['insertion','插入','O(n²)','#ff00aa'],
          ['shell','希尔','O(n^1.5)','#ffa500'],
          ['quick','快排','O(n log n)','#b400ff'],
          ['merge','归并','O(n log n)','#00d4ff'],
          ['heap','堆排','O(n log n)','#39ff14'],
          ['counting','计数','O(n+k)','#ff00aa'],
          ['radix','基数','O(nk)','#ffa500'],
        ].map(([algo, label, tc, color]) => (
          <button class="algo-btn font-mono text-xs px-3 py-1.5 rounded-lg border transition-all"
            data-algo={algo} data-color={color}
            style={`border-color:${color}44;color:${color}99;background:transparent`}
          >
            {label} <span style={`color:${color}66;font-size:9px`}>{tc}</span>
          </button>
        ))}
      </div>

      <!-- Main: Canvas + Pseudocode -->
      <div class="flex gap-3 flex-1" style="min-height:0">

        <!-- Left column -->
        <div class="flex flex-col gap-2 flex-1 min-w-0">

          <!-- Canvas area -->
          <div class="border border-[var(--color-void-border)] rounded-xl overflow-hidden relative" style="background:#04040c;height:340px;flex-shrink:0">
            <canvas id="sort-canvas" style="display:block;width:100%;height:100%"></canvas>
            <div id="sort-label" class="absolute top-3 left-4 font-mono text-sm font-bold" style="color:#b400ff;text-shadow:0 0 12px #b400ff;opacity:0.8">bubbleSort</div>
            <div id="sort-overlay" class="absolute inset-0 flex items-center justify-center font-mono text-[var(--color-text-muted)] text-sm pointer-events-none">
              选择算法 → ▶ RUN
            </div>
          </div>

          <!-- Step description -->
          <div class="border border-[var(--color-void-border)] rounded-xl px-4 py-2 bg-[var(--color-void-card)] font-mono text-xs" style="min-height:36px">
            <span id="step-desc" class="text-[var(--color-text-muted)]">—</span>
            <span class="ml-4 text-[rgba(0,212,255,0.6)]">比较: <span id="cmp-count" class="text-[var(--color-neon-cyan)] font-bold">0</span></span>
            <span class="ml-3 text-[rgba(255,0,170,0.6)]">交换: <span id="swap-count" class="text-[var(--color-neon-pink)] font-bold">0</span></span>
            <span class="ml-3 text-[rgba(180,0,255,0.6)]">耗时: <span id="time-count" class="text-[var(--color-neon-purple)] font-bold">0</span>ms</span>
          </div>

          <!-- Controls -->
          <div class="flex flex-wrap gap-2 items-center">
            <button id="btn-shuffle" class="font-mono text-xs px-3 py-1.5 rounded-lg border border-[rgba(0,212,255,0.3)] text-[rgba(0,212,255,0.8)] hover:bg-[rgba(0,212,255,0.1)] transition-all">🔀 打乱</button>
            <button id="btn-run"    class="font-mono text-xs px-4 py-1.5 rounded-lg border border-[rgba(57,255,20,0.5)] text-[rgba(57,255,20,0.9)] hover:bg-[rgba(57,255,20,0.1)] transition-all font-bold">▶ 运行</button>
            <button id="btn-pause"  class="font-mono text-xs px-3 py-1.5 rounded-lg border border-[rgba(255,170,0,0.4)] text-[rgba(255,170,0,0.8)] hover:bg-[rgba(255,170,0,0.1)] transition-all hidden">⏸ 暂停</button>
            <button id="btn-resume" class="font-mono text-xs px-3 py-1.5 rounded-lg border border-[rgba(57,255,20,0.4)] text-[rgba(57,255,20,0.8)] hover:bg-[rgba(57,255,20,0.1)] transition-all hidden">▶ 继续</button>
            <button id="btn-step"   class="font-mono text-xs px-3 py-1.5 rounded-lg border border-[rgba(0,212,255,0.4)] text-[rgba(0,212,255,0.8)] hover:bg-[rgba(0,212,255,0.1)] transition-all hidden">⏭ 单步</button>
            <button id="btn-stop"   class="font-mono text-xs px-3 py-1.5 rounded-lg border border-[rgba(255,0,170,0.3)] text-[rgba(255,0,170,0.7)] hover:bg-[rgba(255,0,170,0.1)] transition-all hidden">⏹ 停止</button>
            <select id="speed-select" class="font-mono text-xs px-2 py-1.5 rounded-lg border border-[var(--color-void-border)] text-[var(--color-text-muted)] bg-[var(--color-void-card)]">
              <option value="300">慢速</option>
              <option value="80" selected>正常</option>
              <option value="20">快速</option>
              <option value="3">极速</option>
            </select>
            <select id="size-select" class="font-mono text-xs px-2 py-1.5 rounded-lg border border-[var(--color-void-border)] text-[var(--color-text-muted)] bg-[var(--color-void-card)]">
              <option value="30">30</option>
              <option value="60" selected>60</option>
              <option value="120">120</option>
              <option value="200">200</option>
            </select>
          </div>

          <!-- Complexity info -->
          <div class="grid grid-cols-4 gap-2">
            {[
              ['时间（平均）','tc-avg','#b400ff'],
              ['时间（最坏）','tc-worst','#ff00aa'],
              ['空间复杂度','sc','#00d4ff'],
              ['稳定性','stable','#39ff14'],
            ].map(([label, id, color]) => (
              <div class="border border-[var(--color-void-border)] rounded-xl p-2 bg-[var(--color-void-card)] text-center font-mono">
                <div class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest mb-1">{label}</div>
                <div id={id} class="text-xs font-bold" style={`color:${color}`}>--</div>
              </div>
            ))}
          </div>

        </div>

        <!-- Right: Pseudocode panel -->
        <div class="flex-shrink-0 rounded-xl border border-[var(--color-void-border)] overflow-hidden flex flex-col" style="width:230px;background:rgba(0,0,0,0.4)">
          <div class="px-3 py-2 border-b border-[var(--color-void-border)] font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-widest">Pseudocode</div>
          <div id="pseudo-panel" class="flex-1 overflow-y-auto py-2 font-mono" style="font-size:11px;line-height:1"></div>
        </div>

      </div>
    </div>
  </div>

  <script>
    // ── Types & State ──────────────────────────────────────────────────────────
    const canvas = document.getElementById('sort-canvas') as HTMLCanvasElement
    const ctx = canvas.getContext('2d')!
    const overlay = document.getElementById('sort-overlay') as HTMLElement
    const sortLabel = document.getElementById('sort-label') as HTMLElement
    const cmpEl = document.getElementById('cmp-count')!
    const swapEl = document.getElementById('swap-count')!
    const timeEl = document.getElementById('time-count')!
    const stepDescEl = document.getElementById('step-desc')!
    const pseudoPanel = document.getElementById('pseudo-panel')!

    const ALGO_INFO: Record<string,{avg:string,worst:string,space:string,stable:string,color:string}> = {
      bubble:    {avg:'O(n²)',        worst:'O(n²)',        space:'O(1)',      stable:'✅',color:'#00d4ff'},
      selection: {avg:'O(n²)',        worst:'O(n²)',        space:'O(1)',      stable:'❌',color:'#39ff14'},
      insertion: {avg:'O(n²)',        worst:'O(n²)',        space:'O(1)',      stable:'✅',color:'#ff00aa'},
      shell:     {avg:'O(n^1.5)',     worst:'O(n²)',        space:'O(1)',      stable:'❌',color:'#ffa500'},
      quick:     {avg:'O(n log n)',   worst:'O(n²)',        space:'O(log n)', stable:'❌',color:'#b400ff'},
      merge:     {avg:'O(n log n)',   worst:'O(n log n)',   space:'O(n)',     stable:'✅',color:'#00d4ff'},
      heap:      {avg:'O(n log n)',   worst:'O(n log n)',   space:'O(1)',     stable:'❌',color:'#39ff14'},
      counting:  {avg:'O(n+k)',       worst:'O(n+k)',       space:'O(k)',     stable:'✅',color:'#ff00aa'},
      radix:     {avg:'O(nk)',        worst:'O(nk)',        space:'O(n+k)',   stable:'✅',color:'#ffa500'},
    }

    const PSEUDOCODE: Record<string, {id:number,code:string,indent:number}[]> = {
      bubble: [
        {id:0, code:'for i = 0 to n-1:', indent:0},
        {id:1, code:'for j = 0 to n-i-2:', indent:1},
        {id:2, code:'if arr[j] > arr[j+1]:', indent:2},
        {id:3, code:'swap(arr[j], arr[j+1])', indent:3},
        {id:4, code:'// arr[n-i-1] sorted', indent:1},
      ],
      selection: [
        {id:0, code:'for i = 0 to n-1:', indent:0},
        {id:1, code:'minIdx = i', indent:1},
        {id:2, code:'for j = i+1 to n:', indent:1},
        {id:3, code:'if arr[j] < arr[minIdx]:', indent:2},
        {id:4, code:'minIdx = j', indent:3},
        {id:5, code:'swap(arr[i], arr[minIdx])', indent:1},
      ],
      insertion: [
        {id:0, code:'for i = 1 to n:', indent:0},
        {id:1, code:'key = arr[i]; j = i-1', indent:1},
        {id:2, code:'while j >= 0 and arr[j] > key:', indent:1},
        {id:3, code:'arr[j+1] = arr[j]', indent:2},
        {id:4, code:'j--', indent:2},
        {id:5, code:'arr[j+1] = key', indent:1},
      ],
      shell: [
        {id:0, code:'gap = n / 2', indent:0},
        {id:1, code:'while gap > 0:', indent:0},
        {id:2, code:'for i = gap to n:', indent:1},
        {id:3, code:'while j >= gap:', indent:2},
        {id:4, code:'if arr[j-gap] > arr[j]:', indent:3},
        {id:5, code:'swap(arr[j-gap], arr[j])', indent:4},
        {id:6, code:'gap = gap / 2', indent:1},
      ],
      quick: [
        {id:0, code:'quickSort(lo, hi):', indent:0},
        {id:1, code:'if lo >= hi: return', indent:1},
        {id:2, code:'pivot = arr[hi]', indent:1},
        {id:3, code:'p = lo', indent:1},
        {id:4, code:'for i = lo to hi-1:', indent:1},
        {id:5, code:'if arr[i] <= pivot:', indent:2},
        {id:6, code:'swap(arr[i], arr[p++])', indent:3},
        {id:7, code:'swap(arr[p], arr[hi])', indent:1},
        {id:8, code:'recurse lo..p-1, p+1..hi', indent:1},
      ],
      merge: [
        {id:0, code:'mergeSort(lo, hi):', indent:0},
        {id:1, code:'if lo >= hi: return', indent:1},
        {id:2, code:'mid = (lo + hi) / 2', indent:1},
        {id:3, code:'mergeSort(lo, mid)', indent:1},
        {id:4, code:'mergeSort(mid+1, hi)', indent:1},
        {id:5, code:'merge(lo, mid, hi):', indent:1},
        {id:6, code:'copy to tmp[]', indent:2},
        {id:7, code:'while i<=mid and j<=hi:', indent:2},
        {id:8, code:'pick smaller into arr', indent:3},
      ],
      heap: [
        {id:0, code:'buildMaxHeap(arr)', indent:0},
        {id:1, code:'for i = n/2-1 downto 0:', indent:1},
        {id:2, code:'heapify(arr, n, i)', indent:2},
        {id:3, code:'for i = n-1 downto 1:', indent:0},
        {id:4, code:'swap(arr[0], arr[i])', indent:1},
        {id:5, code:'heapify(arr, i, 0):', indent:1},
        {id:6, code:'largest = i; l=2i+1; r=2i+2', indent:2},
        {id:7, code:'if child > largest: update', indent:2},
        {id:8, code:'if largest != i: swap+recurse', indent:2},
      ],
      counting: [
        {id:0, code:'max = max(arr)', indent:0},
        {id:1, code:'count[0..max] = 0', indent:0},
        {id:2, code:'for v in arr:', indent:0},
        {id:3, code:'count[v]++', indent:1},
        {id:4, code:'idx = 0', indent:0},
        {id:5, code:'for v = 1 to max:', indent:0},
        {id:6, code:'while count[v]-- > 0:', indent:1},
        {id:7, code:'arr[idx++] = v', indent:2},
      ],
      radix: [
        {id:0, code:'for exp = 1; max/exp > 0; exp*=10:', indent:0},
        {id:1, code:'count[0..9] = 0', indent:1},
        {id:2, code:'for v in arr:', indent:1},
        {id:3, code:'count[(v/exp)%10]++', indent:2},
        {id:4, code:'prefix sum count[]', indent:1},
        {id:5, code:'fill output[] right to left', indent:1},
        {id:6, code:'arr = output', indent:1},
      ],
    }

    let currentAlgo = 'bubble'
    let arr: number[] = []
    interface SortState {
      comparing: number[]
      swapping: number[]
      sorted: Set<number>
      pivot: number
      activeLine: number
    }
    let state: SortState = {
      comparing: [], swapping: [], sorted: new Set(), pivot: -1, activeLine: -1
    }
    let running = false
    let stopRequested = false
    let paused = false
    let stepResolve: (() => void) | null = null
    let cmpCount = 0, swapCount = 0

    // ── Helpers ───────────────────────────────────────────────────────────────
    function getSize() { return parseInt((document.getElementById('size-select') as HTMLSelectElement).value) }
    function getDelay() { return parseInt((document.getElementById('speed-select') as HTMLSelectElement).value) }

    function setDesc(text: string) { stepDescEl.textContent = text }
    function setLine(n: number) {
      state.activeLine = n
      renderPseudo()
    }

    function renderPseudo() {
      const lines = PSEUDOCODE[currentAlgo] || []
      pseudoPanel.innerHTML = ''
      lines.forEach(({id, code, indent}) => {
        const div = document.createElement('div')
        const isActive = id === state.activeLine
        div.style.cssText = [
          `padding: 3px 8px 3px ${8 + indent * 12}px`,
          `border-left: 3px solid ${isActive ? '#00d4ff' : 'transparent'}`,
          `background: ${isActive ? 'rgba(0,212,255,0.12)' : 'transparent'}`,
          `color: ${isActive ? '#e0f8ff' : 'rgba(180,200,220,0.55)'}`,
          'white-space: nowrap',
          'transition: background 0.1s',
        ].join(';')
        div.textContent = code
        pseudoPanel.appendChild(div)
        if (isActive) div.scrollIntoView({block:'nearest', behavior:'smooth'})
      })
    }

    function genArray() {
      const n = getSize()
      arr = Array.from({length: n}, (_, i) => i + 1)
      for (let i = n-1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i+1));
        [arr[i], arr[j]] = [arr[j], arr[i]]
      }
      resetState()
      drawBars()
      overlay.style.display = 'flex'
    }

    function resetState() {
      state = {comparing:[], swapping:[], sorted: new Set(), pivot: -1, activeLine: -1}
      cmpCount = 0; swapCount = 0; stopRequested = false; paused = false; stepResolve = null
      cmpEl.textContent = '0'; swapEl.textContent = '0'; timeEl.textContent = '0'
      setDesc('—')
      renderPseudo()
    }

    function resize() {
      canvas.width = canvas.clientWidth * devicePixelRatio
      canvas.height = canvas.clientHeight * devicePixelRatio
      ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0)
      drawBars()
    }

    function drawBars() {
      const W = canvas.clientWidth, H = canvas.clientHeight
      if (!W || !H) return
      ctx.clearRect(0, 0, W, H)
      const n = arr.length
      const barW = W / n
      const max = Math.max(...arr)
      const info = ALGO_INFO[currentAlgo]

      arr.forEach((v, i) => {
        const x = i * barW
        const h = (v / max) * (H - 6)
        const y = H - h
        const gap = Math.max(0.5, barW * 0.12)
        const bw = barW - gap
        let color = info.color + 'aa'
        let glow = 0

        if (state.sorted.has(i))         { color = '#39ff14cc'; glow = 4 }
        if (state.comparing.includes(i)) { color = '#ffaa00ff'; glow = 14 }
        if (state.swapping.includes(i))  { color = '#ff00aaff'; glow = 18 }
        if (state.pivot === i)           { color = '#ffffffff'; glow = 12 }

        ctx.save()
        ctx.shadowBlur = glow
        ctx.shadowColor = color
        ctx.fillStyle = color
        const r = Math.min(2, bw / 3)
        ctx.beginPath()
        ctx.roundRect(x + gap/2, y, bw, h, [r, r, 0, 0])
        ctx.fill()
        ctx.restore()
      })
    }

    // ── Step control ──────────────────────────────────────────────────────────
    function sleep(ms: number) {
      return new Promise<void>((resolve, reject) => {
        setTimeout(() => stopRequested ? reject('stopped') : resolve(), ms)
      })
    }

    async function waitStep() {
      if (stopRequested) throw 'stopped'
      if (paused) {
        await new Promise<void>(r => { stepResolve = r })
        if (stopRequested) throw 'stopped'
        // after single step, re-pause
        paused = true
      } else {
        await sleep(getDelay())
      }
    }

    async function cmp(i: number, j: number) {
      cmpCount++; cmpEl.textContent = String(cmpCount)
      state.comparing = [i, j]; drawBars()
      setDesc(`比较 arr[${i}]=${arr[i]} 和 arr[${j}]=${arr[j]}`)
      await waitStep()
      state.comparing = []
    }

    async function doSwap(i: number, j: number) {
      swapCount++; swapEl.textContent = String(swapCount)
      state.swapping = [i, j]
      setDesc(`交换 arr[${i}] ↔ arr[${j}]  (${arr[i]} ↔ ${arr[j]})`)
      drawBars(); await sleep(Math.max(2, getDelay() * 0.5))
      ;[arr[i], arr[j]] = [arr[j], arr[i]]
      drawBars(); await sleep(Math.max(2, getDelay() * 0.5))
      state.swapping = []
    }

    // ── Algorithms ────────────────────────────────────────────────────────────
    async function bubbleSort() {
      const n = arr.length
      for (let i = 0; i < n-1; i++) {
        setLine(0)
        for (let j = 0; j < n-i-1; j++) {
          setLine(1)
          setLine(2); await cmp(j, j+1)
          if (arr[j] > arr[j+1]) { setLine(3); await doSwap(j, j+1) }
        }
        setLine(4)
        state.sorted.add(n-i-1); drawBars()
      }
      state.sorted.add(0)
    }

    async function selectionSort() {
      const n = arr.length
      for (let i = 0; i < n-1; i++) {
        setLine(0)
        let minIdx = i; setLine(1)
        for (let j = i+1; j < n; j++) {
          setLine(2); setLine(3); await cmp(minIdx, j)
          if (arr[j] < arr[minIdx]) { minIdx = j; setLine(4) }
        }
        setLine(5)
        if (minIdx !== i) await doSwap(i, minIdx)
        state.sorted.add(i); drawBars()
      }
      state.sorted.add(n-1)
    }

    async function insertionSort() {
      const n = arr.length
      state.sorted.add(0)
      for (let i = 1; i < n; i++) {
        setLine(0); setLine(1)
        let j = i
        while (j > 0) {
          setLine(2); await cmp(j-1, j)
          if (arr[j] < arr[j-1]) { setLine(3); setLine(4); await doSwap(j-1, j); j-- }
          else break
        }
        setLine(5)
        state.sorted.add(i); drawBars()
      }
    }

    async function shellSort() {
      const n = arr.length
      setLine(0)
      for (let gap = Math.floor(n/2); gap > 0; gap = Math.floor(gap/2)) {
        setLine(1)
        for (let i = gap; i < n; i++) {
          setLine(2)
          let j = i
          while (j >= gap) {
            setLine(3); setLine(4); await cmp(j-gap, j)
            if (arr[j] < arr[j-gap]) { setLine(5); await doSwap(j-gap, j); j -= gap }
            else break
          }
        }
        setLine(6)
      }
      arr.forEach((_, i) => state.sorted.add(i)); drawBars()
    }

    async function quickSort(lo = 0, hi = arr.length-1): Promise<void> {
      setLine(0)
      if (lo >= hi) { setLine(1); if (lo === hi) state.sorted.add(lo); return }
      setLine(2); state.pivot = hi; drawBars()
      setDesc(`枢轴 arr[${hi}]=${arr[hi]}`)
      await sleep(getDelay())
      setLine(3); let p = lo
      setLine(4)
      for (let i = lo; i < hi; i++) {
        setLine(5); await cmp(i, hi)
        if (arr[i] <= arr[hi]) { setLine(6); if (i !== p) await doSwap(i, p); p++ }
      }
      setLine(7); await doSwap(p, hi)
      state.pivot = -1; state.sorted.add(p)
      setLine(8)
      await quickSort(lo, p-1); await quickSort(p+1, hi)
    }

    async function mergeSort(lo = 0, hi = arr.length-1): Promise<void> {
      setLine(0)
      if (lo >= hi) { setLine(1); return }
      const mid = (lo+hi) >> 1
      setLine(2); setLine(3); await mergeSort(lo, mid)
      setLine(4); await mergeSort(mid+1, hi)
      setLine(5); setLine(6)
      const tmp = arr.slice(lo, hi+1)
      let i = 0, j = mid-lo+1, k = lo
      setLine(7)
      while (i <= mid-lo && j < tmp.length) {
        cmpCount++; cmpEl.textContent = String(cmpCount)
        state.comparing = [lo+i, lo+j]; drawBars()
        setDesc(`比较 arr[${lo+i}]=${tmp[i]} 和 arr[${lo+j}]=${tmp[j]}`)
        await waitStep()
        state.comparing = []
        setLine(8)
        if (tmp[i] <= tmp[j]) arr[k++] = tmp[i++]
        else { arr[k++] = tmp[j++]; swapCount++; swapEl.textContent = String(swapCount) }
      }
      while (i <= mid-lo) arr[k++] = tmp[i++]
      while (j < tmp.length) arr[k++] = tmp[j++]
      for (let x = lo; x <= hi; x++) state.sorted.add(x)
      setDesc(`arr[${lo}..${hi}] 已合并`)
      drawBars()
    }

    async function heapSort() {
      const n = arr.length
      const heapify = async (size: number, i: number): Promise<void> => {
        setLine(6)
        let largest = i, l = 2*i+1, r = 2*i+2
        setLine(7)
        if (l < size) { await cmp(l, largest); if (arr[l] > arr[largest]) largest = l }
        if (r < size) { await cmp(r, largest); if (arr[r] > arr[largest]) largest = r }
        if (largest !== i) { setLine(8); await doSwap(i, largest); await heapify(size, largest) }
      }
      setLine(0); setLine(1)
      for (let i = Math.floor(n/2)-1; i >= 0; i--) { setLine(2); await heapify(n, i) }
      setLine(3)
      for (let i = n-1; i > 0; i--) {
        setLine(4); await doSwap(0, i)
        state.sorted.add(i)
        setLine(5); await heapify(i, 0)
      }
      state.sorted.add(0); drawBars()
    }

    async function countingSort() {
      const max = Math.max(...arr)
      setLine(0); setLine(1)
      const count = new Array(max+1).fill(0)
      setLine(2); setLine(3)
      arr.forEach(v => count[v]++)
      setLine(4); let idx = 0
      setLine(5)
      for (let v = 1; v <= max; v++) {
        setLine(6)
        while (count[v]-- > 0) {
          setLine(7)
          state.comparing = [idx]; cmpCount++; cmpEl.textContent = String(cmpCount)
          setDesc(`放置 ${v} 到 arr[${idx}]`)
          drawBars(); await waitStep()
          arr[idx] = v; state.sorted.add(idx); idx++; drawBars()
        }
      }
      state.comparing = []
    }

    async function radixSort() {
      const max = Math.max(...arr)
      setLine(0)
      for (let exp = 1; Math.floor(max/exp) > 0; exp *= 10) {
        setLine(1)
        const output = new Array(arr.length).fill(0)
        const count = new Array(10).fill(0)
        setLine(2); setLine(3)
        arr.forEach(v => count[Math.floor(v/exp)%10]++)
        setLine(4)
        for (let i = 1; i < 10; i++) count[i] += count[i-1]
        setLine(5)
        for (let i = arr.length-1; i >= 0; i--) {
          const digit = Math.floor(arr[i]/exp)%10
          output[--count[digit]] = arr[i]
          state.comparing = [i]
          setDesc(`数位 ${exp}: arr[${i}]=${arr[i]} 位=${digit}`)
          drawBars(); await waitStep()
          swapCount++; swapEl.textContent = String(swapCount)
        }
        setLine(6)
        arr.splice(0, arr.length, ...output)
        state.comparing = []; drawBars()
        await sleep(getDelay() * 2)
      }
      arr.forEach((_, i) => state.sorted.add(i))
      setDesc('基数排序完成')
      drawBars()
    }

    const ALGOS: Record<string, ()=>Promise<void>> = {
      bubble: bubbleSort, selection: selectionSort, insertion: insertionSort,
      shell: shellSort, quick: ()=>quickSort(), merge: ()=>mergeSort(),
      heap: heapSort, counting: countingSort, radix: radixSort,
    }

    // ── UI Controls ───────────────────────────────────────────────────────────
    function setControlState(mode: 'idle'|'running'|'paused') {
      const btnRun    = document.getElementById('btn-run')!
      const btnPause  = document.getElementById('btn-pause')!
      const btnResume = document.getElementById('btn-resume')!
      const btnStep   = document.getElementById('btn-step')!
      const btnStop   = document.getElementById('btn-stop')!
      const btnShuffle= document.getElementById('btn-shuffle')!

      if (mode === 'idle') {
        btnRun.style.display = ''; btnPause.classList.add('hidden')
        btnResume.classList.add('hidden'); btnStep.classList.add('hidden')
        btnStop.classList.add('hidden'); btnShuffle.style.display = ''
      } else if (mode === 'running') {
        btnRun.style.display = 'none'; btnPause.classList.remove('hidden')
        btnResume.classList.add('hidden'); btnStep.classList.add('hidden')
        btnStop.classList.remove('hidden'); btnShuffle.style.display = 'none'
      } else { // paused
        btnRun.style.display = 'none'; btnPause.classList.add('hidden')
        btnResume.classList.remove('hidden'); btnStep.classList.remove('hidden')
        btnStop.classList.remove('hidden'); btnShuffle.style.display = 'none'
      }
    }

    async function runSort() {
      if (running) return
      running = true; stopRequested = false; paused = false
      resetState()
      overlay.style.display = 'none'
      setControlState('running')
      const t0 = Date.now()
      try {
        await ALGOS[currentAlgo]()
        arr.forEach((_, i) => state.sorted.add(i))
        setLine(-1); drawBars()
        timeEl.textContent = String(Date.now() - t0)
        const finalTime = Date.now() - t0
        setDesc(`排序完成！共比较 ${cmpCount} 次，交换 ${swapCount} 次，耗时 ${finalTime}ms`)
      } catch {}
      running = false; stopRequested = false; paused = false; stepResolve = null
      setControlState('idle')
    }

    document.getElementById('btn-shuffle')!.addEventListener('click', () => { if (!running) genArray() })
    document.getElementById('btn-run')!.addEventListener('click', runSort)

    document.getElementById('btn-pause')!.addEventListener('click', () => {
      paused = true; setControlState('paused')
    })

    document.getElementById('btn-resume')!.addEventListener('click', () => {
      paused = false
      const r = stepResolve; stepResolve = null
      r?.()
      setControlState('running')
    })

    document.getElementById('btn-step')!.addEventListener('click', () => {
      // execute one step then pause again
      const r = stepResolve; stepResolve = null
      paused = false   // briefly unpause so waitStep proceeds
      r?.()
      // re-pause will happen inside waitStep after promise resolves
    })

    document.getElementById('btn-stop')!.addEventListener('click', () => {
      stopRequested = true
      const r = stepResolve; stepResolve = null
      paused = false; r?.()
    })

    document.getElementById('size-select')!.addEventListener('change', () => { if (!running) genArray() })
    document.addEventListener('keydown', e => {
      if ((e.key === 'r' || e.key === 'R') && !running) genArray()
    })

    // Algo buttons
    document.querySelectorAll('.algo-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        if (running) return
        document.querySelectorAll('.algo-btn').forEach(b => {
          const el = b as HTMLElement
          const c = el.dataset.color!
          el.style.background = 'transparent'
          el.style.borderColor = c + '44'
          el.style.color = c + '99'
        })
        const el = btn as HTMLElement
        const c = el.dataset.color!
        el.style.background = c + '18'
        el.style.borderColor = c + 'bb'
        el.style.color = c
        currentAlgo = el.dataset.algo!
        sortLabel.textContent = currentAlgo + 'Sort'
        sortLabel.style.color = c
        sortLabel.style.textShadow = `0 0 12px ${c}`
        const info = ALGO_INFO[currentAlgo]
        document.getElementById('tc-avg')!.textContent = info.avg
        document.getElementById('tc-worst')!.textContent = info.worst
        document.getElementById('sc')!.textContent = info.space
        document.getElementById('stable')!.textContent = info.stable + (info.stable==='✅'?' 稳定':' 不稳定')
        renderPseudo()
      })
    })

    window.addEventListener('resize', resize)
    genArray(); resize()
    ;(document.querySelector('.algo-btn[data-algo="bubble"]') as HTMLElement)?.click()
  </script>
</BaseLayout>
