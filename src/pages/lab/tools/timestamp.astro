---
import BaseLayout from '../../../layouts/BaseLayout.astro'
---
<BaseLayout title="时间戳工具 | void.dev">
  <div class="min-h-screen" style="background:var(--color-void);font-family:var(--font-mono)">
    <nav class="px-6 py-4 border-b" style="border-color:var(--color-void-border);color:var(--color-text-secondary)">
      <span style="color:#ffa500">❯</span>
      <a href="/void-blog/lab/" style="color:var(--color-text-secondary);text-decoration:none" onmouseover="this.style.color='#ffa500'" onmouseout="this.style.color='var(--color-text-secondary)'">~/lab</a>
      <span class="mx-2">/</span>
      <span style="color:#ffa500">timestamp</span>
    </nav>

    <div class="p-6 max-w-3xl mx-auto">
      <h1 class="text-2xl font-bold mb-2" style="color:#ffa500;text-shadow:0 0 20px rgba(255,165,0,0.6)">
        ⏱ 时间戳工具
      </h1>
      <p class="mb-6 text-sm" style="color:var(--color-text-muted)">实时时钟 · 时间戳转换 · 时区</p>

      <!-- Live clock -->
      <div class="mb-6 p-5 rounded-xl" style="background:var(--color-void-card);border:1px solid rgba(255,165,0,0.2)">
        <div class="text-xs mb-3" style="color:var(--color-text-muted)">CURRENT TIME</div>
        <div class="grid gap-2" style="grid-template-columns:auto 1fr">
          <span class="text-xs" style="color:var(--color-text-muted);padding-top:2px">Unix ms</span>
          <span id="live-ms" style="color:#ffa500;font-size:22px;font-weight:700;letter-spacing:1px">-</span>
          <span class="text-xs" style="color:var(--color-text-muted)">Unix s</span>
          <span id="live-s" style="color:var(--color-text-secondary)">-</span>
          <span class="text-xs" style="color:var(--color-text-muted)">ISO 8601</span>
          <span id="live-iso" style="color:var(--color-text-secondary)">-</span>
          <span class="text-xs" style="color:var(--color-text-muted)">本地时间</span>
          <span id="live-local" style="color:var(--color-text-secondary)">-</span>
        </div>
      </div>

      <!-- Timezone selector -->
      <div class="flex gap-3 items-center mb-6">
        <span class="text-sm" style="color:var(--color-text-muted)">时区：</span>
        <select id="tz-select"
          style="background:rgba(0,0,0,0.4);border:1px solid var(--color-void-border);color:var(--color-text-primary);font-family:var(--font-mono);font-size:13px;border-radius:8px;padding:6px 12px;outline:none;cursor:pointer">
          <option value="UTC">UTC</option>
          <option value="Asia/Shanghai" selected>Asia/Shanghai (CST)</option>
          <option value="America/New_York">America/New_York (EST)</option>
          <option value="America/Los_Angeles">America/Los_Angeles (PST)</option>
          <option value="Europe/London">Europe/London (GMT)</option>
          <option value="Europe/Paris">Europe/Paris (CET)</option>
          <option value="Asia/Tokyo">Asia/Tokyo (JST)</option>
        </select>
      </div>

      <!-- Convert A: timestamp → datetime -->
      <div class="mb-4 p-5 rounded-xl" style="background:var(--color-void-card);border:1px solid var(--color-void-border)">
        <div class="text-xs mb-3" style="color:var(--color-text-muted)">A → 时间戳 转 日期</div>
        <div class="flex gap-3 mb-4">
          <input id="ts-input" type="text" placeholder="输入 Unix 时间戳（s 或 ms）"
            style="flex:1;background:rgba(0,0,0,0.4);border:1px solid var(--color-void-border);color:var(--color-text-primary);font-family:var(--font-mono);font-size:13px;border-radius:8px;padding:8px 12px;outline:none"
            onfocus="this.style.borderColor='rgba(255,165,0,0.5)'" onblur="this.style.borderColor='var(--color-void-border)'" />
          <button id="btn-now-a" class="now-btn">现在</button>
        </div>
        <div id="ts-result" class="grid gap-1 text-sm" style="display:none"></div>
      </div>

      <!-- Convert B: datetime → timestamp -->
      <div class="p-5 rounded-xl" style="background:var(--color-void-card);border:1px solid var(--color-void-border)">
        <div class="text-xs mb-3" style="color:var(--color-text-muted)">B → 日期 转 时间戳</div>
        <div class="flex gap-3 mb-4">
          <input id="dt-input" type="text" placeholder="2024-01-01 00:00:00 or ISO"
            style="flex:1;background:rgba(0,0,0,0.4);border:1px solid var(--color-void-border);color:var(--color-text-primary);font-family:var(--font-mono);font-size:13px;border-radius:8px;padding:8px 12px;outline:none"
            onfocus="this.style.borderColor='rgba(255,165,0,0.5)'" onblur="this.style.borderColor='var(--color-void-border)'" />
          <button id="btn-now-b" class="now-btn">现在</button>
        </div>
        <div id="dt-result" class="grid gap-1 text-sm" style="display:none"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .now-btn {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255,165,0,0.4);
    background: rgba(255,165,0,0.08);
    color: #ffa500;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }
  .now-btn:hover {
    background: rgba(255,165,0,0.2);
    border-color: rgba(255,165,0,0.8);
  }
  .result-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 8px;
    padding: 4px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .result-label { color: var(--color-text-muted); font-size: 12px; }
  .result-value { color: var(--color-text-primary); }
</style>

<script>
  function getTz() {
    return (document.getElementById('tz-select') as HTMLSelectElement).value
  }

  function formatInTz(date: Date, tz: string) {
    return new Intl.DateTimeFormat('zh-CN', {
      timeZone: tz,
      year:'numeric', month:'2-digit', day:'2-digit',
      hour:'2-digit', minute:'2-digit', second:'2-digit',
      hour12: false
    }).format(date).replace(/\//g, '-')
  }

  function updateClock() {
    const now = new Date()
    const tz = getTz()
    document.getElementById('live-ms')!.textContent = now.getTime().toString()
    document.getElementById('live-s')!.textContent = Math.floor(now.getTime()/1000).toString()
    document.getElementById('live-iso')!.textContent = now.toISOString()
    document.getElementById('live-local')!.textContent = formatInTz(now, tz)
  }

  setInterval(updateClock, 100)
  updateClock()
  document.getElementById('tz-select')!.addEventListener('change', updateClock)

  function rowHtml(label: string, value: string) {
    return `<div class="result-row"><span class="result-label">${label}</span><span class="result-value" style="color:var(--color-text-primary)">${value}</span></div>`
  }

  // A: timestamp → datetime
  function convertTs() {
    let val = (document.getElementById('ts-input') as HTMLInputElement).value.trim()
    const resultEl = document.getElementById('ts-result')!
    if (!val) { resultEl.style.display = 'none'; return }
    let n = parseFloat(val)
    if (isNaN(n)) { resultEl.innerHTML = '<span style="color:#ff4466">✗ 无效时间戳</span>'; resultEl.style.display = 'block'; return }
    // auto-detect s vs ms
    if (n < 1e10) n = n * 1000
    const d = new Date(n)
    const tz = getTz()
    resultEl.style.display = 'grid'
    resultEl.innerHTML = [
      rowHtml('Unix ms', d.getTime().toString()),
      rowHtml('Unix s', Math.floor(d.getTime()/1000).toString()),
      rowHtml('ISO 8601', d.toISOString()),
      rowHtml(tz, formatInTz(d, tz)),
      rowHtml('UTC', formatInTz(d, 'UTC')),
      rowHtml('相对', relativeTime(d)),
    ].join('')
  }

  function relativeTime(d: Date) {
    const diff = (d.getTime() - Date.now()) / 1000
    const abs = Math.abs(diff)
    const suffix = diff < 0 ? '前' : '后'
    if (abs < 60) return `${Math.round(abs)} 秒${suffix}`
    if (abs < 3600) return `${Math.round(abs/60)} 分钟${suffix}`
    if (abs < 86400) return `${Math.round(abs/3600)} 小时${suffix}`
    return `${Math.round(abs/86400)} 天${suffix}`
  }

  // B: datetime → timestamp
  function convertDt() {
    let val = (document.getElementById('dt-input') as HTMLInputElement).value.trim()
    const resultEl = document.getElementById('dt-result')!
    if (!val) { resultEl.style.display = 'none'; return }
    const d = new Date(val)
    if (isNaN(d.getTime())) { resultEl.innerHTML = '<span style="color:#ff4466">✗ 无法解析日期</span>'; resultEl.style.display = 'block'; return }
    resultEl.style.display = 'grid'
    resultEl.innerHTML = [
      rowHtml('Unix ms', d.getTime().toString()),
      rowHtml('Unix s', Math.floor(d.getTime()/1000).toString()),
      rowHtml('ISO 8601', d.toISOString()),
      rowHtml(getTz(), formatInTz(d, getTz())),
      rowHtml('相对', relativeTime(d)),
    ].join('')
  }

  document.getElementById('ts-input')!.addEventListener('input', convertTs)
  document.getElementById('dt-input')!.addEventListener('input', convertDt)
  document.getElementById('tz-select')!.addEventListener('change', () => { convertTs(); convertDt() })

  document.getElementById('btn-now-a')!.addEventListener('click', () => {
    ;(document.getElementById('ts-input') as HTMLInputElement).value = Date.now().toString()
    convertTs()
  })
  document.getElementById('btn-now-b')!.addEventListener('click', () => {
    const now = new Date()
    ;(document.getElementById('dt-input') as HTMLInputElement).value = now.toISOString().slice(0,19).replace('T',' ')
    convertDt()
  })
</script>
