---
export const prerender = true
import BaseLayout from '../../../layouts/BaseLayout.astro'
---
<BaseLayout title="网络诊断 | void.dev">
  <div class="min-h-screen bg-[var(--color-void)]" style="font-family:var(--font-mono)">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.85)] backdrop-blur-xl">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-4">
        <a href="/" class="text-sm text-[var(--color-neon-green)] hover:glow-green transition-all">~/void-blog</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <a href="/lab/" class="text-xs text-[var(--color-neon-cyan)] hover:opacity-80 transition-opacity">lab</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="text-xs text-[var(--color-neon-cyan)]">netinfo</span>
      </div>
    </nav>

    <div class="max-w-3xl mx-auto px-6 py-10">
      <div class="mb-8">
        <p class="text-[10px] text-[var(--color-text-muted)] tracking-[0.25em] uppercase mb-2">network</p>
        <h1 class="text-3xl font-bold mb-2" style="color:#00d4ff;text-shadow:0 0 20px rgba(0,212,255,0.3)">网络诊断</h1>
        <p class="text-sm text-[var(--color-text-muted)]">IP 信息 · DNS 延迟 · 连接质量</p>
      </div>

      <!-- IP Info -->
      <section class="mb-8">
        <h2 class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-3 flex items-center gap-2">
          <span style="color:#00d4ff">▶</span> IP 信息
        </h2>
        <div id="ip-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="info-card" id="card-ip">
            <div class="label">Public IP</div>
            <div class="value" id="val-ip"><span class="loading">扫描中...</span></div>
          </div>
          <div class="info-card">
            <div class="label">位置</div>
            <div class="value" id="val-loc">—</div>
          </div>
          <div class="info-card">
            <div class="label">ISP / ASN</div>
            <div class="value" id="val-isp">—</div>
          </div>
          <div class="info-card">
            <div class="label">时区</div>
            <div class="value" id="val-tz">—</div>
          </div>
        </div>
      </section>

      <!-- Browser/System -->
      <section class="mb-8">
        <h2 class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-3 flex items-center gap-2">
          <span style="color:#00ff88">▶</span> 本机信息
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="info-card">
            <div class="label">User Agent</div>
            <div class="value text-xs break-all" id="val-ua"></div>
          </div>
          <div class="info-card">
            <div class="label">平台 / CPU</div>
            <div class="value" id="val-platform"></div>
          </div>
          <div class="info-card">
            <div class="label">屏幕分辨率</div>
            <div class="value" id="val-screen"></div>
          </div>
          <div class="info-card">
            <div class="label">语言 / 时区</div>
            <div class="value" id="val-lang"></div>
          </div>
          <div class="info-card">
            <div class="label">网络类型</div>
            <div class="value" id="val-net"></div>
          </div>
          <div class="info-card">
            <div class="label">CPU 核心数</div>
            <div class="value" id="val-cpu"></div>
          </div>
        </div>
      </section>

      <!-- Latency test -->
      <section class="mb-8">
        <h2 class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-3 flex items-center gap-2">
          <span style="color:#b44cff">▶</span> 延迟测试
          <button id="btn-ping" class="ml-auto text-[11px] px-4 py-1 rounded border transition-all cursor-pointer"
            style="border-color:rgba(180,76,255,0.4);color:#b44cff;background:rgba(180,76,255,0.06)">
            ▶ 开始测试
          </button>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="ping-grid">
          {[
            {id:'google', label:'Google', url:'https://www.google.com/favicon.ico'},
            {id:'github',  label:'GitHub',  url:'https://github.com/favicon.ico'},
            {id:'cf',     label:'Cloudflare', url:'https://1.1.1.1/favicon.ico'},
            {id:'npm',    label:'npm',     url:'https://registry.npmjs.org/-/ping'},
          ].map(({id,label}) => (
            <div class="info-card" id={`ping-${id}`}>
              <div class="label">{label}</div>
              <div class="value ping-val">—</div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>

  <style>
    .info-card {
      padding: 12px 16px;
      border-radius: 10px;
      background: #0f0f1a;
      border: 1px solid rgba(30,30,48,0.8);
      transition: border-color 0.2s;
    }
    .info-card:hover { border-color: rgba(0,212,255,0.2); }
    .label { font-size: 10px; color: rgba(104,104,160,0.8); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px; }
    .value { font-size: 13px; color: #e8e8f0; word-break: break-all; }
    .loading { color: rgba(0,212,255,0.5); animation: pulse 1.2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    .ping-ok  { color: #00ff88; }
    .ping-mid { color: #ffa500; }
    .ping-bad { color: #ff4466; }
  </style>

  <script is:inline>
  (function(){
    // Browser info (sync)
    document.getElementById('val-ua').textContent       = navigator.userAgent
    document.getElementById('val-platform').textContent = `${navigator.platform} / ${navigator.hardwareConcurrency ?? '?'} core`
    document.getElementById('val-screen').textContent   = `${screen.width}×${screen.height} @${window.devicePixelRatio}x`
    document.getElementById('val-lang').textContent     = `${navigator.language} / ${Intl.DateTimeFormat().resolvedOptions().timeZone}`
    document.getElementById('val-cpu').textContent      = navigator.hardwareConcurrency ? `${navigator.hardwareConcurrency} 核` : '未知'
    const conn = navigator.connection
    document.getElementById('val-net').textContent      = conn ? `${conn.effectiveType ?? ''}  ↓${conn.downlink ?? '?'}Mbps  RTT ${conn.rtt ?? '?'}ms` : '浏览器不支持'

    // IP info via ipapi.co
    fetch('https://ipapi.co/json/')
      .then(r => r.json())
      .then(d => {
        document.getElementById('val-ip').textContent  = d.ip ?? '—'
        document.getElementById('val-loc').textContent = [d.city, d.region, d.country_name].filter(Boolean).join(', ')
        document.getElementById('val-isp').textContent = `${d.org ?? '—'}`
        document.getElementById('val-tz').textContent  = d.timezone ?? '—'
      })
      .catch(() => {
        document.getElementById('val-ip').textContent = '请求失败（可能需要 VPN）'
      })

    // Ping tests
    const TARGETS = [
      {id:'google', url:'https://www.google.com/favicon.ico'},
      {id:'github',  url:'https://github.com/favicon.ico'},
      {id:'cf',     url:'https://cloudflare.com/favicon.ico'},
      {id:'npm',    url:'https://registry.npmjs.org/-/ping'},
    ]

    async function pingOne(url) {
      const t0 = performance.now()
      try {
        await fetch(url + '?_=' + Date.now(), { mode:'no-cors', cache:'no-store' })
        return Math.round(performance.now() - t0)
      } catch { return null }
    }

    async function runPing() {
      document.getElementById('btn-ping').textContent = '⟳ 测试中...'
      document.getElementById('btn-ping').disabled = true
      for (const {id, url} of TARGETS) {
        const el = document.querySelector(`#ping-${id} .ping-val`)
        el.textContent = '...'
        const ms = await pingOne(url)
        if (ms === null) {
          el.textContent = 'timeout'; el.className = 'value ping-val ping-bad'
        } else {
          el.textContent = `${ms} ms`
          el.className = 'value ping-val ' + (ms < 100 ? 'ping-ok' : ms < 300 ? 'ping-mid' : 'ping-bad')
        }
      }
      document.getElementById('btn-ping').textContent = '↺ 重新测试'
      document.getElementById('btn-ping').disabled = false
    }

    document.getElementById('btn-ping').addEventListener('click', runPing)
    runPing()
  })()
  </script>
</BaseLayout>
