---
export const prerender = true
import BaseLayout from '../../../layouts/BaseLayout.astro'
---
<BaseLayout title="Diff 对比 | void.dev">
  <div class="min-h-screen" style="background:var(--color-void);font-family:var(--font-mono)">
    <nav class="px-6 py-4 border-b" style="border-color:var(--color-void-border);color:var(--color-text-secondary)">
      <span style="color:#39ff14">❯</span>
      <a href="/lab/" style="color:var(--color-text-secondary);text-decoration:none" onmouseover="this.style.color='#39ff14'" onmouseout="this.style.color='var(--color-text-secondary)'">~/lab</a>
      <span class="mx-2">/</span>
      <span style="color:#39ff14">diff</span>
    </nav>

    <div class="p-6 max-w-7xl mx-auto">
      <h1 class="text-2xl font-bold mb-2" style="color:#39ff14;text-shadow:0 0 20px rgba(57,255,20,0.5)">
        ± Diff 对比
      </h1>
      <p class="mb-4 text-sm" style="color:var(--color-text-muted)">两段文本逐行差异对比</p>

      <!-- Stats + mode toggle -->
      <div class="flex flex-wrap gap-4 items-center mb-4">
        <div id="diff-stats" class="flex gap-4 text-xs">
          <span style="color:#39ff14">+<span id="stat-add">0</span> 新增</span>
          <span style="color:#ff6b6b">-<span id="stat-del">0</span> 删除</span>
          <span style="color:var(--color-text-muted)">≡<span id="stat-eq">0</span> 相同</span>
        </div>
        <div class="ml-auto flex gap-2">
          <button class="mode-btn active-mode" data-mode="unified" onclick="setMode('unified')">逐行</button>
          <button class="mode-btn" data-mode="split" onclick="setMode('split')">并排</button>
        </div>
      </div>

      <!-- Inputs -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
        <div>
          <p class="text-xs mb-1" style="color:rgba(57,255,20,0.6)">原始文本 (Left)</p>
          <textarea id="left-input" rows="10" placeholder="粘贴原始文本..."
            class="w-full px-4 py-3 rounded-lg text-sm outline-none resize-y"
            style="background:var(--color-void-card);border:1px solid rgba(57,255,20,0.25);color:var(--color-text-primary);caret-color:#39ff14"
            oninput="runDiff()"></textarea>
        </div>
        <div>
          <p class="text-xs mb-1" style="color:rgba(57,255,20,0.6)">修改文本 (Right)</p>
          <textarea id="right-input" rows="10" placeholder="粘贴修改后的文本..."
            class="w-full px-4 py-3 rounded-lg text-sm outline-none resize-y"
            style="background:var(--color-void-card);border:1px solid rgba(57,255,20,0.25);color:var(--color-text-primary);caret-color:#39ff14"
            oninput="runDiff()"></textarea>
        </div>
      </div>

      <!-- Diff output -->
      <div id="diff-output" class="rounded-xl overflow-hidden border" style="border-color:rgba(57,255,20,0.2)"></div>
    </div>
  </div>

  <style>
    .mode-btn {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 5px 14px;
      border-radius: 5px;
      border: 1px solid rgba(57,255,20,0.2);
      color: rgba(57,255,20,0.6);
      background: transparent;
      cursor: pointer;
      transition: all 0.15s;
    }
    .mode-btn:hover { border-color: rgba(57,255,20,0.5); color: #39ff14; }
    .active-mode { border-color: #39ff14 !important; color: #39ff14 !important; background: rgba(57,255,20,0.06) !important; }

    .diff-line {
      display: flex;
      align-items: baseline;
      font-size: 12px;
      line-height: 1.6;
      padding: 1px 0;
    }
    .diff-gutter {
      min-width: 32px;
      padding: 0 8px;
      text-align: right;
      font-size: 10px;
      user-select: none;
      opacity: 0.5;
    }
    .diff-content { padding: 0 12px; flex: 1; white-space: pre-wrap; word-break: break-all; }
    .diff-add { background: rgba(57,255,20,0.1); }
    .diff-del { background: rgba(255,0,170,0.1); }
    .diff-eq { }

    .collapsed-hint {
      font-size: 11px;
      color: rgba(57,255,20,0.4);
      padding: 3px 12px;
      cursor: pointer;
      background: rgba(57,255,20,0.03);
      border-top: 1px solid rgba(57,255,20,0.08);
      border-bottom: 1px solid rgba(57,255,20,0.08);
    }
    .collapsed-hint:hover { color: #39ff14; background: rgba(57,255,20,0.07); }

    /* Split mode */
    .split-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      font-size: 12px;
      line-height: 1.6;
    }
    .split-cell {
      padding: 1px 12px;
      white-space: pre-wrap;
      word-break: break-all;
      border-right: 1px solid rgba(57,255,20,0.08);
    }
  </style>

  <script is:inline>
    let currentMode = 'unified'

    function setMode(m) {
      currentMode = m
      document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active-mode'))
      document.querySelector(`[data-mode="${m}"]`).classList.add('active-mode')
      runDiff()
    }

    function diffLines(a, b) {
      const aLines = a === '' ? [] : a.split('\n')
      const bLines = b === '' ? [] : b.split('\n')
      const m = aLines.length, n = bLines.length
      const dp = Array.from({length: m + 1}, () => new Int32Array(n + 1))
      for (let x = 1; x <= m; x++)
        for (let y = 1; y <= n; y++)
          dp[x][y] = aLines[x-1] === bLines[y-1]
            ? dp[x-1][y-1] + 1
            : Math.max(dp[x-1][y], dp[x][y-1])
      const ops = []
      let x = m, y = n
      while (x > 0 || y > 0) {
        if (x > 0 && y > 0 && aLines[x-1] === bLines[y-1]) {
          ops.unshift({type:'equal', left:aLines[x-1], right:bLines[y-1]}); x--; y--
        } else if (y > 0 && (x === 0 || dp[x][y-1] >= dp[x-1][y])) {
          ops.unshift({type:'add', left:null, right:bLines[y-1]}); y--
        } else {
          ops.unshift({type:'del', left:aLines[x-1], right:null}); x--
        }
      }
      return ops
    }

    function esc(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    }

    function runDiff() {
      const left  = document.getElementById('left-input').value
      const right = document.getElementById('right-input').value
      if (!left && !right) {
        document.getElementById('diff-output').innerHTML = ''
        document.getElementById('stat-add').textContent = '0'
        document.getElementById('stat-del').textContent = '0'
        document.getElementById('stat-eq').textContent  = '0'
        return
      }
      const ops = diffLines(left, right)
      document.getElementById('stat-add').textContent = ops.filter(o=>o.type==='add').length
      document.getElementById('stat-del').textContent = ops.filter(o=>o.type==='del').length
      document.getElementById('stat-eq').textContent  = ops.filter(o=>o.type==='equal').length
      currentMode === 'unified' ? renderUnified(ops) : renderSplit(ops)
    }

    const CTX = 3

    // 预计算每个 op 的左右行号
    function calcLineNums(ops) {
      let lN = 0, rN = 0
      return ops.map(op => {
        if (op.type === 'equal') { lN++; rN++; return {l:lN, r:rN} }
        if (op.type === 'del')   { lN++;          return {l:lN, r:null} }
        /* add */                  rN++;          return {l:null, r:rN}
      })
    }

    function lineHtml(type, text, lNum, rNum) {
      const bg    = type==='add' ? 'rgba(57,255,20,0.08)' : type==='del' ? 'rgba(255,80,80,0.1)' : ''
      const color = type==='add' ? '#6dff80' : type==='del' ? '#ff8888' : 'var(--color-text-muted)'
      const sign  = type==='add' ? '+' : type==='del' ? '-' : ' '
      const signColor = type==='add' ? '#39ff14' : type==='del' ? '#ff6b6b' : 'transparent'
      return `<div class="diff-line" style="background:${bg}">
        <span class="diff-gutter" style="color:rgba(136,136,170,0.35)">${lNum!==null?lNum:''}</span>
        <span class="diff-gutter" style="color:rgba(136,136,170,0.25)">${rNum!==null?rNum:''}</span>
        <span class="diff-gutter" style="color:${signColor};font-weight:bold">${sign}</span>
        <span class="diff-content" style="color:${color}">${esc(text??'')}</span>
      </div>`
    }

    function renderUnified(ops) {
      const el = document.getElementById('diff-output')
      if (!ops.length) { el.innerHTML = '<div style="padding:16px;color:var(--color-text-muted)">无内容</div>'; return }

      const lineNums = calcLineNums(ops)

      // 分组折叠
      const groups = []
      for (const op of ops) {
        const last = groups[groups.length-1]
        if (last && last.type === op.type) last.lines.push(op)
        else groups.push({type:op.type, lines:[op]})
      }

      let opIdx = 0, html = ''
      groups.forEach(g => {
        const gLen = g.lines.length
        if (g.type === 'equal' && gLen > CTX * 2 + 1) {
          for (let j = 0; j < CTX; j++, opIdx++) {
            const {l,r} = lineNums[opIdx]
            html += lineHtml('eq', g.lines[j].left, l, r)
          }
          const skip = gLen - CTX * 2
          const skipStart = opIdx
          opIdx += skip
          html += `<div class="collapsed-hint" data-start="${skipStart}" data-count="${skip}" onclick="expandAll()">… 折叠了 ${skip} 行相同内容（点击展开）</div>`
          for (let j = 0; j < CTX; j++, opIdx++) {
            const {l,r} = lineNums[opIdx]
            html += lineHtml('eq', g.lines[gLen-CTX+j].left, l, r)
          }
        } else {
          for (const op of g.lines) {
            const {l,r} = lineNums[opIdx++]
            html += lineHtml(op.type==='equal'?'eq':op.type, op.type==='del'?op.left:op.right, l, r)
          }
        }
      })
      el.innerHTML = html
      el._ops = ops
      el._lineNums = lineNums
    }

    function expandAll() {
      const el = document.getElementById('diff-output')
      const ops = el._ops, lineNums = el._lineNums
      if (!ops) return
      let html = ''
      ops.forEach((op, i) => {
        const {l,r} = lineNums[i]
        html += lineHtml(op.type==='equal'?'eq':op.type, op.type==='del'?op.left:op.right, l, r)
      })
      el.innerHTML = html
    }

    function renderSplit(ops) {
      const el = document.getElementById('diff-output')
      if (!ops.length) { el.innerHTML = '<div style="padding:16px;color:var(--color-text-muted)">无内容</div>'; return }

      const rows = []
      let i = 0
      while (i < ops.length) {
        if (ops[i].type === 'equal') {
          rows.push({type:'equal', left:ops[i].left, right:ops[i].right}); i++
        } else {
          const dels = [], adds = []
          while (i < ops.length && ops[i].type === 'del')  { dels.push(ops[i].left);  i++ }
          while (i < ops.length && ops[i].type === 'add')  { adds.push(ops[i].right); i++ }
          const maxLen = Math.max(dels.length, adds.length)
          for (let j = 0; j < maxLen; j++)
            rows.push({type:'change', left:j<dels.length?dels[j]:null, right:j<adds.length?adds[j]:null})
        }
      }

      let lN = 0, rN = 0
      let html = `<div style="display:grid;grid-template-columns:1fr 1fr;border-bottom:1px solid rgba(57,255,20,0.12)">
        <div style="padding:5px 12px;font-size:10px;color:rgba(57,255,20,0.45);border-right:1px solid rgba(57,255,20,0.1)">LEFT（原始）</div>
        <div style="padding:5px 12px;font-size:10px;color:rgba(57,255,20,0.45)">RIGHT（修改）</div>
      </div>`

      rows.forEach(row => {
        if (row.type === 'equal') {
          lN++; rN++
          html += `<div style="display:grid;grid-template-columns:1fr 1fr;font-size:12px;line-height:1.6">
            <div class="split-cell" style="color:var(--color-text-muted)"><span class="diff-gutter" style="opacity:0.3">${lN}</span> ${esc(row.left)}</div>
            <div class="split-cell" style="color:var(--color-text-muted)"><span class="diff-gutter" style="opacity:0.3">${rN}</span> ${esc(row.right)}</div>
          </div>`
        } else {
          const hasL = row.left !== null, hasR = row.right !== null
          if (hasL) lN++
          if (hasR) rN++
          const lCell = hasL
            ? `<div class="split-cell" style="background:rgba(255,80,80,0.08);color:#ff9999"><span class="diff-gutter" style="color:rgba(255,100,100,0.4)">${lN}</span> <span style="color:rgba(255,80,80,0.5)">-</span> ${esc(row.left)}</div>`
            : `<div class="split-cell" style="background:rgba(255,80,80,0.03)"><span style="color:rgba(136,136,170,0.15)">　</span></div>`
          const rCell = hasR
            ? `<div class="split-cell" style="background:rgba(57,255,20,0.07);color:#7dff90"><span class="diff-gutter" style="color:rgba(57,255,20,0.4)">${rN}</span> <span style="color:rgba(57,255,20,0.5)">+</span> ${esc(row.right)}</div>`
            : `<div class="split-cell" style="background:rgba(57,255,20,0.02)"><span style="color:rgba(136,136,170,0.15)">　</span></div>`
          html += `<div style="display:grid;grid-template-columns:1fr 1fr;font-size:12px;line-height:1.6">${lCell}${rCell}</div>`
        }
      })
      el.innerHTML = html
    }
</script>
</BaseLayout>
