---
import BaseLayout from '../../../layouts/BaseLayout.astro'
---
<BaseLayout title="Diff 对比 | void.dev">
  <div class="min-h-screen" style="background:var(--color-void);font-family:var(--font-mono)">
    <nav class="px-6 py-4 border-b" style="border-color:var(--color-void-border);color:var(--color-text-secondary)">
      <span style="color:#39ff14">❯</span>
      <a href="/void-blog/lab/" style="color:var(--color-text-secondary);text-decoration:none" onmouseover="this.style.color='#39ff14'" onmouseout="this.style.color='var(--color-text-secondary)'">~/lab</a>
      <span class="mx-2">/</span>
      <span style="color:#39ff14">diff</span>
    </nav>

    <div class="p-6 max-w-7xl mx-auto">
      <h1 class="text-2xl font-bold mb-2" style="color:#39ff14;text-shadow:0 0 20px rgba(57,255,20,0.5)">
        ± Diff 对比
      </h1>
      <p class="mb-4 text-sm" style="color:var(--color-text-muted)">两段文本逐行差异对比</p>

      <!-- Stats + mode toggle -->
      <div class="flex flex-wrap gap-4 items-center mb-4">
        <div id="diff-stats" class="flex gap-4 text-xs">
          <span style="color:#39ff14">+<span id="stat-add">0</span> 新增</span>
          <span style="color:#ff6b6b">-<span id="stat-del">0</span> 删除</span>
          <span style="color:var(--color-text-muted)">≡<span id="stat-eq">0</span> 相同</span>
        </div>
        <div class="ml-auto flex gap-2">
          <button class="mode-btn active-mode" data-mode="unified" onclick="setMode('unified')">逐行</button>
          <button class="mode-btn" data-mode="split" onclick="setMode('split')">并排</button>
        </div>
      </div>

      <!-- Inputs -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
        <div>
          <p class="text-xs mb-1" style="color:rgba(57,255,20,0.6)">原始文本 (Left)</p>
          <textarea id="left-input" rows="10" placeholder="粘贴原始文本..."
            class="w-full px-4 py-3 rounded-lg text-sm outline-none resize-y"
            style="background:var(--color-void-card);border:1px solid rgba(57,255,20,0.25);color:var(--color-text-primary);caret-color:#39ff14"
            oninput="runDiff()"></textarea>
        </div>
        <div>
          <p class="text-xs mb-1" style="color:rgba(57,255,20,0.6)">修改文本 (Right)</p>
          <textarea id="right-input" rows="10" placeholder="粘贴修改后的文本..."
            class="w-full px-4 py-3 rounded-lg text-sm outline-none resize-y"
            style="background:var(--color-void-card);border:1px solid rgba(57,255,20,0.25);color:var(--color-text-primary);caret-color:#39ff14"
            oninput="runDiff()"></textarea>
        </div>
      </div>

      <!-- Diff output -->
      <div id="diff-output" class="rounded-xl overflow-hidden border" style="border-color:rgba(57,255,20,0.2)"></div>
    </div>
  </div>

  <style>
    .mode-btn {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 5px 14px;
      border-radius: 5px;
      border: 1px solid rgba(57,255,20,0.2);
      color: rgba(57,255,20,0.6);
      background: transparent;
      cursor: pointer;
      transition: all 0.15s;
    }
    .mode-btn:hover { border-color: rgba(57,255,20,0.5); color: #39ff14; }
    .active-mode { border-color: #39ff14 !important; color: #39ff14 !important; background: rgba(57,255,20,0.06) !important; }

    .diff-line {
      display: flex;
      align-items: baseline;
      font-size: 12px;
      line-height: 1.6;
      padding: 1px 0;
    }
    .diff-gutter {
      min-width: 32px;
      padding: 0 8px;
      text-align: right;
      font-size: 10px;
      user-select: none;
      opacity: 0.5;
    }
    .diff-content { padding: 0 12px; flex: 1; white-space: pre-wrap; word-break: break-all; }
    .diff-add { background: rgba(57,255,20,0.1); }
    .diff-del { background: rgba(255,0,170,0.1); }
    .diff-eq { }

    .collapsed-hint {
      font-size: 11px;
      color: rgba(57,255,20,0.4);
      padding: 3px 12px;
      cursor: pointer;
      background: rgba(57,255,20,0.03);
      border-top: 1px solid rgba(57,255,20,0.08);
      border-bottom: 1px solid rgba(57,255,20,0.08);
    }
    .collapsed-hint:hover { color: #39ff14; background: rgba(57,255,20,0.07); }

    /* Split mode */
    .split-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      font-size: 12px;
      line-height: 1.6;
    }
    .split-cell {
      padding: 1px 12px;
      white-space: pre-wrap;
      word-break: break-all;
      border-right: 1px solid rgba(57,255,20,0.08);
    }
  </style>

  <script is:inline>
    let currentMode = 'unified'

    function setMode(m) {
      currentMode = m
      document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active-mode'))
      document.querySelector(`[data-mode="${m}"]`).classList.add('active-mode')
      runDiff()
    }

    function diffLines(a, b) {
      const aLines = a === '' ? [] : a.split('\n')
      const bLines = b === '' ? [] : b.split('\n')
      const m = aLines.length, n = bLines.length
      const dp = Array.from({length: m + 1}, () => new Array(n + 1).fill(0))
      for (let x = 1; x <= m; x++)
        for (let y = 1; y <= n; y++)
          dp[x][y] = aLines[x-1] === bLines[y-1]
            ? dp[x-1][y-1] + 1
            : Math.max(dp[x-1][y], dp[x][y-1])

      const ops = []
      let x = m, y = n
      while (x > 0 || y > 0) {
        if (x > 0 && y > 0 && aLines[x-1] === bLines[y-1]) {
          ops.unshift({type: 'equal', line: aLines[x-1], left: aLines[x-1], right: bLines[y-1]}); x--; y--
        } else if (y > 0 && (x === 0 || dp[x][y-1] >= dp[x-1][y])) {
          ops.unshift({type: 'add', line: bLines[y-1], left: '', right: bLines[y-1]}); y--
        } else {
          ops.unshift({type: 'del', line: aLines[x-1], left: aLines[x-1], right: ''}); x--
        }
      }
      return ops
    }

    function escapeHtml(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    }

    function runDiff() {
      const left = document.getElementById('left-input').value
      const right = document.getElementById('right-input').value

      if (!left && !right) {
        document.getElementById('diff-output').innerHTML = ''
        document.getElementById('stat-add').textContent = '0'
        document.getElementById('stat-del').textContent = '0'
        document.getElementById('stat-eq').textContent = '0'
        return
      }

      const ops = diffLines(left, right)
      const adds = ops.filter(o => o.type === 'add').length
      const dels = ops.filter(o => o.type === 'del').length
      const eqs = ops.filter(o => o.type === 'equal').length
      document.getElementById('stat-add').textContent = adds
      document.getElementById('stat-del').textContent = dels
      document.getElementById('stat-eq').textContent = eqs

      if (currentMode === 'unified') {
        renderUnified(ops)
      } else {
        renderSplit(ops)
      }
    }

    const CONTEXT = 3

    function renderUnified(ops) {
      const el = document.getElementById('diff-output')
      if (!ops.length) { el.innerHTML = '<div style="padding:16px;color:var(--color-text-muted);font-size:13px">无内容</div>'; return }

      // Group consecutive equals for collapsing
      const groups = []
      let cur = null
      ops.forEach(op => {
        if (!cur || cur.type !== op.type) { cur = {type: op.type, lines: [op]}; groups.push(cur) }
        else cur.lines.push(op)
      })

      let html = ''
      let lineNum = 0
      groups.forEach((g, gi) => {
        if (g.type === 'equal') {
          const lines = g.lines
          if (lines.length <= CONTEXT * 2 + 1) {
            lines.forEach(op => {
              lineNum++
              html += `<div class="diff-line diff-eq">
                <span class="diff-gutter" style="color:rgba(57,255,20,0.3)">${lineNum}</span>
                <span class="diff-gutter" style="color:rgba(57,255,20,0.2)"> </span>
                <span class="diff-content" style="color:var(--color-text-muted)">${escapeHtml(op.line)}</span>
              </div>`
            })
          } else {
            // show first CONTEXT
            lines.slice(0, CONTEXT).forEach(op => {
              lineNum++
              html += `<div class="diff-line diff-eq">
                <span class="diff-gutter" style="color:rgba(57,255,20,0.3)">${lineNum}</span>
                <span class="diff-gutter" style="color:rgba(57,255,20,0.2)"> </span>
                <span class="diff-content" style="color:var(--color-text-muted)">${escapeHtml(op.line)}</span>
              </div>`
            })
            const skipCount = lines.length - CONTEXT * 2
            const skipStart = lineNum + 1
            lineNum += skipCount
            html += `<div class="collapsed-hint" onclick="expandGroup(${gi})">… 折叠了 ${skipCount} 行相同内容（第 ${skipStart}-${lineNum} 行，点击展开）</div>`
            // show last CONTEXT
            lines.slice(-CONTEXT).forEach(op => {
              lineNum++
              html += `<div class="diff-line diff-eq">
                <span class="diff-gutter" style="color:rgba(57,255,20,0.3)">${lineNum}</span>
                <span class="diff-gutter" style="color:rgba(57,255,20,0.2)"> </span>
                <span class="diff-content" style="color:var(--color-text-muted)">${escapeHtml(op.line)}</span>
              </div>`
            })
          }
        } else if (g.type === 'del') {
          g.lines.forEach(op => {
            lineNum++
            html += `<div class="diff-line diff-del">
              <span class="diff-gutter" style="color:rgba(255,100,100,0.6)">${lineNum}</span>
              <span class="diff-gutter" style="color:#ff6b6b;font-weight:bold">-</span>
              <span class="diff-content" style="color:#ff6b6b">${escapeHtml(op.line)}</span>
            </div>`
          })
        } else {
          g.lines.forEach(op => {
            lineNum++
            html += `<div class="diff-line diff-add">
              <span class="diff-gutter" style="color:rgba(57,255,20,0.5)">${lineNum}</span>
              <span class="diff-gutter" style="color:#39ff14;font-weight:bold">+</span>
              <span class="diff-content" style="color:#39ff14">${escapeHtml(op.line)}</span>
            </div>`
          })
        }
      })
      el.innerHTML = html
      // store ops for expand
      el._ops = ops
      el._groups = groups
    }

    function expandGroup(gi) {
      // Re-render without collapsing that group - simple approach: just re-render all expanded
      const el = document.getElementById('diff-output')
      const ops = el._ops
      if (!ops) return
      let html = ''
      let lineNum = 0
      ops.forEach(op => {
        lineNum++
        if (op.type === 'equal') {
          html += `<div class="diff-line diff-eq">
            <span class="diff-gutter" style="color:rgba(57,255,20,0.3)">${lineNum}</span>
            <span class="diff-gutter" style="color:rgba(57,255,20,0.2)"> </span>
            <span class="diff-content" style="color:var(--color-text-muted)">${escapeHtml(op.line)}</span>
          </div>`
        } else if (op.type === 'del') {
          html += `<div class="diff-line diff-del">
            <span class="diff-gutter" style="color:rgba(255,100,100,0.6)">${lineNum}</span>
            <span class="diff-gutter" style="color:#ff6b6b;font-weight:bold">-</span>
            <span class="diff-content" style="color:#ff6b6b">${escapeHtml(op.line)}</span>
          </div>`
        } else {
          html += `<div class="diff-line diff-add">
            <span class="diff-gutter" style="color:rgba(57,255,20,0.5)">${lineNum}</span>
            <span class="diff-gutter" style="color:#39ff14;font-weight:bold">+</span>
            <span class="diff-content" style="color:#39ff14">${escapeHtml(op.line)}</span>
          </div>`
        }
      })
      el.innerHTML = html
    }

    function renderSplit(ops) {
      const el = document.getElementById('diff-output')
      if (!ops.length) { el.innerHTML = '<div style="padding:16px;color:var(--color-text-muted);font-size:13px">无内容</div>'; return }

      // 并排模式：先把 del/add 序列两两对齐
      // 策略：遇到连续 del+add 块，按行号对齐；多余的用空行填充
      const rows = []
      let i = 0
      while (i < ops.length) {
        if (ops[i].type === 'equal') {
          rows.push({ type: 'equal', left: ops[i].line, right: ops[i].line })
          i++
        } else {
          // 收集连续的 del 和 add
          const dels = [], adds = []
          while (i < ops.length && ops[i].type === 'del') { dels.push(ops[i].line); i++ }
          while (i < ops.length && ops[i].type === 'add') { adds.push(ops[i].line); i++ }
          const maxLen = Math.max(dels.length, adds.length)
          for (let j = 0; j < maxLen; j++) {
            rows.push({
              type: 'change',
              left:  j < dels.length ? dels[j] : null,
              right: j < adds.length ? adds[j] : null,
            })
          }
        }
      }

      let leftNum = 0, rightNum = 0
      let html = `<div style="display:grid;grid-template-columns:1fr 1fr;background:rgba(57,255,20,0.04)">
        <div style="padding:6px 12px;font-size:10px;color:rgba(57,255,20,0.5);border-right:1px solid rgba(57,255,20,0.12)">LEFT（原始）</div>
        <div style="padding:6px 12px;font-size:10px;color:rgba(57,255,20,0.5)">RIGHT（修改）</div>
      </div>`

      rows.forEach(p => {
        if (p.type === 'equal') {
          leftNum++; rightNum++
          html += `<div class="split-row">
            <div class="split-cell" style="color:var(--color-text-muted)"><span class="diff-gutter" style="opacity:0.3">${leftNum}</span> ${escapeHtml(p.left)}</div>
            <div class="split-cell" style="color:var(--color-text-muted)"><span class="diff-gutter" style="opacity:0.3">${rightNum}</span> ${escapeHtml(p.right)}</div>
          </div>`
        } else {
          if (p.left !== null) leftNum++
          if (p.right !== null) rightNum++
          const lNum = p.left !== null ? leftNum : ''
          const rNum = p.right !== null ? rightNum : ''
          html += `<div class="split-row">
            <div class="split-cell" style="color:${p.left!==null?'#ff8888':'transparent'};background:${p.left!==null?'rgba(255,100,100,0.08)':'rgba(255,100,100,0.02)'}">${p.left!==null?`<span class="diff-gutter" style="color:rgba(255,100,100,0.4)">${lNum}</span> <span style="opacity:0.5">-</span> ${escapeHtml(p.left)}`:'<span style="opacity:0.15">~</span>'}</div>
            <div class="split-cell" style="color:${p.right!==null?'#39ff14':'transparent'};background:${p.right!==null?'rgba(57,255,20,0.06)':'rgba(57,255,20,0.01)'}">${p.right!==null?`<span class="diff-gutter" style="color:rgba(57,255,20,0.4)">${rNum}</span> <span style="opacity:0.5">+</span> ${escapeHtml(p.right)}`:'<span style="opacity:0.15">~</span>'}</div>
          </div>`
        }
      })
      el.innerHTML = html
    }
  </script>
</BaseLayout>
