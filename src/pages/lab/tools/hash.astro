---
import BaseLayout from '../../../layouts/BaseLayout.astro'
---
<BaseLayout title="Hash 工具 | void.dev">
  <div class="min-h-screen" style="background:var(--color-void);font-family:var(--font-mono)">
    <nav class="px-6 py-4 border-b" style="border-color:var(--color-void-border);color:var(--color-text-secondary)">
      <span style="color:var(--color-neon-cyan)">❯</span>
      <a href="/lab/" style="color:var(--color-text-secondary);text-decoration:none" onmouseover="this.style.color='var(--color-neon-cyan)'" onmouseout="this.style.color='var(--color-text-secondary)'">~/lab</a>
      <span class="mx-2">/</span>
      <span style="color:var(--color-neon-cyan)">hash</span>
    </nav>

    <div class="p-6 max-w-3xl mx-auto">
      <h1 class="text-2xl font-bold mb-2" style="color:var(--color-neon-cyan);text-shadow:0 0 20px rgba(0,212,255,0.6)">
        # Hash 计算
      </h1>
      <p class="mb-6 text-sm" style="color:var(--color-text-muted)">MD5 · SHA-1 · SHA-256 · SHA-512 · 文件哈希</p>

      <!-- Mode tabs -->
      <div class="flex gap-2 mb-6">
        <button id="tab-text" class="hash-tab active-hash-tab">📝 文本</button>
        <button id="tab-file" class="hash-tab">📁 文件</button>
      </div>

      <!-- Text input -->
      <div id="panel-text" class="mb-6">
        <label class="block text-xs mb-2" style="color:var(--color-text-muted)">INPUT TEXT</label>
        <textarea id="text-input" rows="5" placeholder="输入要计算哈希的文本..." spellcheck="false"
          style="width:100%;background:rgba(0,0,0,0.4);border:1px solid var(--color-void-border);color:var(--color-text-primary);font-family:var(--font-mono);font-size:13px;border-radius:12px;padding:14px;outline:none;resize:vertical"
          onfocus="this.style.borderColor='rgba(0,212,255,0.5)'" onblur="this.style.borderColor='var(--color-void-border)'"></textarea>
      </div>

      <!-- File drop -->
      <div id="panel-file" style="display:none;margin-bottom:24px">
        <div id="drop-zone"
          style="border:2px dashed rgba(0,212,255,0.3);border-radius:16px;padding:40px;text-align:center;cursor:pointer;transition:all 0.3s"
          onmouseenter="this.style.borderColor='rgba(0,212,255,0.7)';this.style.background='rgba(0,212,255,0.04)'"
          onmouseleave="this.style.borderColor='rgba(0,212,255,0.3)';this.style.background='transparent'">
          <div style="font-size:36px;margin-bottom:12px">📁</div>
          <div style="color:var(--color-text-secondary);margin-bottom:8px">拖拽文件到这里</div>
          <div style="color:var(--color-text-muted);font-size:12px;margin-bottom:16px">支持任意文件</div>
          <input id="file-input" type="file" style="display:none" />
          <button onclick="document.getElementById('file-input').click()"
            style="font-family:var(--font-mono);font-size:12px;padding:7px 18px;border-radius:8px;border:1px solid rgba(0,212,255,0.4);background:rgba(0,212,255,0.08);color:var(--color-neon-cyan);cursor:pointer">
            选择文件
          </button>
        </div>
        <div id="file-info" class="mt-3 text-sm" style="color:var(--color-text-muted);display:none"></div>
      </div>

      <!-- Hash results -->
      <div id="hash-results" class="grid gap-3">
        {[
          {id:'md5',label:'MD5',len:32},
          {id:'sha1',label:'SHA-1',len:40},
          {id:'sha256',label:'SHA-256',len:64},
          {id:'sha512',label:'SHA-512',len:128},
        ].map(({id, label}) => (
          <div style="background:var(--color-void-card);border:1px solid var(--color-void-border);border-radius:10px;padding:12px 14px">
            <div class="flex justify-between items-center mb-1">
              <span class="text-xs font-bold" style="color:var(--color-neon-cyan)">{label}</span>
              <button
                onclick={`copyHash('${id}')`}
                style="font-family:var(--font-mono);font-size:10px;padding:2px 10px;border-radius:5px;border:1px solid rgba(0,212,255,0.25);background:rgba(0,212,255,0.07);color:var(--color-neon-cyan);cursor:pointer"
                id={`copy-${id}`}>复制</button>
            </div>
            <div id={id} style="font-size:12px;color:var(--color-text-secondary);word-break:break-all;min-height:18px">—</div>
          </div>
        ))}
      </div>

      <div id="progress-bar" style="display:none;margin-top:16px">
        <div style="background:var(--color-void-muted);border-radius:4px;height:4px;overflow:hidden">
          <div id="progress-fill" style="background:var(--color-neon-cyan);height:100%;width:0%;transition:width 0.2s"></div>
        </div>
        <div id="progress-text" class="text-xs mt-1" style="color:var(--color-text-muted)"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .hash-tab {
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 7px 18px;
    border-radius: 8px;
    border: 1px solid rgba(0,212,255,0.25);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.2s;
  }
  .hash-tab:hover, .active-hash-tab {
    background: rgba(0,212,255,0.1) !important;
    border-color: rgba(0,212,255,0.6) !important;
    color: var(--color-neon-cyan) !important;
  }
</style>

<script>
  // ── Vanilla MD5 (RFC 1321) ──────────────────────────────────────────────────
  function md5(input: string): string {
    function safeAdd(x: number, y: number) { const lsw=(x&0xffff)+(y&0xffff); return (((x>>16)+(y>>16)+(lsw>>16))<<16)|(lsw&0xffff) }
    function bitRotateLeft(num: number, cnt: number) { return (num<<cnt)|(num>>>(32-cnt)) }
    function md5cmn(q:number,a:number,b:number,x:number,s:number,t:number){return safeAdd(bitRotateLeft(safeAdd(safeAdd(a,q),safeAdd(x,t)),s),b)}
    function md5ff(a:number,b:number,c:number,d:number,x:number,s:number,t:number){return md5cmn((b&c)|(~b&d),a,b,x,s,t)}
    function md5gg(a:number,b:number,c:number,d:number,x:number,s:number,t:number){return md5cmn((b&d)|(c&~d),a,b,x,s,t)}
    function md5hh(a:number,b:number,c:number,d:number,x:number,s:number,t:number){return md5cmn(b^c^d,a,b,x,s,t)}
    function md5ii(a:number,b:number,c:number,d:number,x:number,s:number,t:number){return md5cmn(c^(b|~d),a,b,x,s,t)}
    function md5blks(s: string) {
      const nblk = ((s.length+8)>>6)+1, blks = new Array(nblk*16).fill(0)
      for(let i=0;i<s.length;i++) blks[i>>2]|=s.charCodeAt(i)<<((i%4)*8)
      blks[s.length>>2]|=0x80<<((s.length%4)*8)
      blks[nblk*16-2]=s.length*8; return blks
    }
    const x = md5blks(input)
    let [a,b,c,d] = [0x67452301,0xefcdab89,0x98badcfe,0x10325476]
    for(let i=0;i<x.length;i+=16){
      const [aa,bb,cc,dd]=[a,b,c,d]
      a=md5ff(a,b,c,d,x[i],7,-680876936);d=md5ff(d,a,b,c,x[i+1],12,-389564586);c=md5ff(c,d,a,b,x[i+2],17,606105819);b=md5ff(b,c,d,a,x[i+3],22,-1044525330)
      a=md5ff(a,b,c,d,x[i+4],7,-176418897);d=md5ff(d,a,b,c,x[i+5],12,1200080426);c=md5ff(c,d,a,b,x[i+6],17,-1473231341);b=md5ff(b,c,d,a,x[i+7],22,-45705983)
      a=md5ff(a,b,c,d,x[i+8],7,1770035416);d=md5ff(d,a,b,c,x[i+9],12,-1958414417);c=md5ff(c,d,a,b,x[i+10],17,-42063);b=md5ff(b,c,d,a,x[i+11],22,-1990404162)
      a=md5ff(a,b,c,d,x[i+12],7,1804603682);d=md5ff(d,a,b,c,x[i+13],12,-40341101);c=md5ff(c,d,a,b,x[i+14],17,-1502002290);b=md5ff(b,c,d,a,x[i+15],22,1236535329)
      a=md5gg(a,b,c,d,x[i+1],5,-165796510);d=md5gg(d,a,b,c,x[i+6],9,-1069501632);c=md5gg(c,d,a,b,x[i+11],14,643717713);b=md5gg(b,c,d,a,x[i],20,-373897302)
      a=md5gg(a,b,c,d,x[i+5],5,-701558691);d=md5gg(d,a,b,c,x[i+10],9,38016083);c=md5gg(c,d,a,b,x[i+15],14,-660478335);b=md5gg(b,c,d,a,x[i+4],20,-405537848)
      a=md5gg(a,b,c,d,x[i+9],5,568446438);d=md5gg(d,a,b,c,x[i+14],9,-1019803690);c=md5gg(c,d,a,b,x[i+3],14,-187363961);b=md5gg(b,c,d,a,x[i+8],20,1163531501)
      a=md5gg(a,b,c,d,x[i+13],5,-1444681467);d=md5gg(d,a,b,c,x[i+2],9,-51403784);c=md5gg(c,d,a,b,x[i+7],14,1735328473);b=md5gg(b,c,d,a,x[i+12],20,-1926607734)
      a=md5hh(a,b,c,d,x[i+5],4,-378558);d=md5hh(d,a,b,c,x[i+8],11,-2022574463);c=md5hh(c,d,a,b,x[i+11],16,1839030562);b=md5hh(b,c,d,a,x[i+14],23,-35309556)
      a=md5hh(a,b,c,d,x[i+1],4,-1530992060);d=md5hh(d,a,b,c,x[i+4],11,1272893353);c=md5hh(c,d,a,b,x[i+7],16,-155497632);b=md5hh(b,c,d,a,x[i+10],23,-1094730640)
      a=md5hh(a,b,c,d,x[i+13],4,681279174);d=md5hh(d,a,b,c,x[i],11,-358537222);c=md5hh(c,d,a,b,x[i+3],16,-722521979);b=md5hh(b,c,d,a,x[i+6],23,76029189)
      a=md5hh(a,b,c,d,x[i+9],4,-640364487);d=md5hh(d,a,b,c,x[i+12],11,-421815835);c=md5hh(c,d,a,b,x[i+15],16,530742520);b=md5hh(b,c,d,a,x[i+2],23,-995338651)
      a=md5ii(a,b,c,d,x[i],6,-198630844);d=md5ii(d,a,b,c,x[i+7],10,1126891415);c=md5ii(c,d,a,b,x[i+14],15,-1416354905);b=md5ii(b,c,d,a,x[i+5],21,-57434055)
      a=md5ii(a,b,c,d,x[i+12],6,1700485571);d=md5ii(d,a,b,c,x[i+3],10,-1894986606);c=md5ii(c,d,a,b,x[i+10],15,-1051523);b=md5ii(b,c,d,a,x[i+1],21,-2054922799)
      a=md5ii(a,b,c,d,x[i+8],6,1873313359);d=md5ii(d,a,b,c,x[i+15],10,-30611744);c=md5ii(c,d,a,b,x[i+6],15,-1560198380);b=md5ii(b,c,d,a,x[i+13],21,1309151649)
      a=md5ii(a,b,c,d,x[i+4],6,-145523070);d=md5ii(d,a,b,c,x[i+11],10,-1120210379);c=md5ii(c,d,a,b,x[i+2],15,718787259);b=md5ii(b,c,d,a,x[i+9],21,-343485551)
      a=safeAdd(a,aa);b=safeAdd(b,bb);c=safeAdd(c,cc);d=safeAdd(d,dd)
    }
    return [a,b,c,d].map(n=>((n&0xff).toString(16).padStart(2,'0'))+((n>>8&0xff).toString(16).padStart(2,'0'))+((n>>16&0xff).toString(16).padStart(2,'0'))+((n>>24&0xff).toString(16).padStart(2,'0'))).join('')
  }

  async function sha(algo: string, data: ArrayBuffer): Promise<string> {
    const buf = await crypto.subtle.digest(algo, data)
    return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('')
  }

  async function computeText(text: string) {
    document.getElementById('md5')!.textContent = md5(text)
    const enc = new TextEncoder().encode(text)
    document.getElementById('sha1')!.textContent = await sha('SHA-1', enc)
    document.getElementById('sha256')!.textContent = await sha('SHA-256', enc)
    document.getElementById('sha512')!.textContent = await sha('SHA-512', enc)
  }

  let debounceTimer: ReturnType<typeof setTimeout>
  document.getElementById('text-input')!.addEventListener('input', (e) => {
    clearTimeout(debounceTimer)
    debounceTimer = setTimeout(() => computeText((e.target as HTMLTextAreaElement).value), 150)
  })

  // File mode
  async function computeFile(file: File) {
    const info = document.getElementById('file-info')!
    info.textContent = `计算中... ${file.name} (${(file.size/1024).toFixed(2)} KB)`
    info.style.display = 'block'
    document.getElementById('progress-bar')!.style.display = 'block'
    document.getElementById('progress-fill')!.style.width = '30%'

    const buf = await file.arrayBuffer()
    const arr = new Uint8Array(buf)
    document.getElementById('progress-fill')!.style.width = '50%'
    // MD5 needs string (latin1)
    let str = ''
    for (let i = 0; i < arr.length; i++) str += String.fromCharCode(arr[i])
    document.getElementById('md5')!.textContent = md5(str)
    document.getElementById('progress-fill')!.style.width = '60%'
    document.getElementById('sha1')!.textContent = await sha('SHA-1', buf)
    document.getElementById('progress-fill')!.style.width = '75%'
    document.getElementById('sha256')!.textContent = await sha('SHA-256', buf)
    document.getElementById('progress-fill')!.style.width = '90%'
    document.getElementById('sha512')!.textContent = await sha('SHA-512', buf)
    document.getElementById('progress-fill')!.style.width = '100%'
    info.textContent = `✓ ${file.name} · ${(file.size/1024).toFixed(2)} KB · ${file.type || '未知类型'}`
    setTimeout(() => { document.getElementById('progress-bar')!.style.display = 'none' }, 800)
  }

  const dropZone = document.getElementById('drop-zone')!
  dropZone.addEventListener('dragover', e => { e.preventDefault() })
  dropZone.addEventListener('drop', e => {
    e.preventDefault()
    const file = e.dataTransfer?.files[0]
    if (file) computeFile(file)
  })
  document.getElementById('file-input')!.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0]
    if (file) computeFile(file)
  })

  // Tabs
  document.getElementById('tab-text')!.addEventListener('click', () => {
    document.getElementById('panel-text')!.style.display = 'block'
    document.getElementById('panel-file')!.style.display = 'none'
    document.getElementById('tab-text')!.classList.add('active-hash-tab')
    document.getElementById('tab-file')!.classList.remove('active-hash-tab')
  })
  document.getElementById('tab-file')!.addEventListener('click', () => {
    document.getElementById('panel-text')!.style.display = 'none'
    document.getElementById('panel-file')!.style.display = 'block'
    document.getElementById('tab-file')!.classList.add('active-hash-tab')
    document.getElementById('tab-text')!.classList.remove('active-hash-tab')
  })

  function copyHash(id: string) {
    const val = document.getElementById(id)!.textContent || ''
    navigator.clipboard.writeText(val).then(() => {
      const btn = document.getElementById(`copy-${id}`)!
      btn.textContent = '已复制 ✓'; setTimeout(() => btn.textContent = '复制', 1500)
    })
  }
  ;(window as any).copyHash = copyHash
</script>
