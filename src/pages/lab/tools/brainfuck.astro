---
import BaseLayout from '../../../layouts/BaseLayout.astro'
---
<BaseLayout title="Brainfuck 解释器 | void.dev">
  <div class="min-h-screen bg-[var(--color-void)]" style="font-family:var(--font-mono)">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.85)] backdrop-blur-xl">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-4">
        <a href="/void-blog/" class="text-sm text-[var(--color-neon-green)] hover:glow-green transition-all">~/void-blog</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <a href="/void-blog/lab/" class="text-xs text-[var(--color-neon-cyan)] hover:opacity-80 transition-opacity">lab</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="text-xs text-[var(--color-neon-purple)]">brainfuck</span>
        <div class="ml-auto flex items-center gap-3 text-[10px] text-[var(--color-text-muted)]">
          <span id="bf-status"></span>
        </div>
      </div>
    </nav>

    <div class="max-w-4xl mx-auto px-6 py-10">
      <div class="mb-6">
        <p class="text-[10px] text-[var(--color-text-muted)] tracking-[0.25em] uppercase mb-2">esoteric language</p>
        <h1 class="text-3xl font-bold mb-2" style="color:#b44cff;text-shadow:0 0 20px rgba(180,76,255,0.4)">Brainfuck</h1>
        <p class="text-sm text-[var(--color-text-muted)]">8 个指令的图灵完备语言 — <code style="color:#b44cff">+ - &lt; &gt; [ ] . ,</code></p>
      </div>

      <!-- Examples -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="text-[10px] text-[var(--color-text-muted)] self-center">示例：</span>
        {[
          {label:'Hello World', code:'++++++++[>++++[>++>+++>+++>+<<<<-]>+>+>->>+[<]<-]>>.>---.+++++++..+++.>>.<-.<.+++.------.--------.>>+.>++.'},
          {label:'Cat (echo)', code:',[.,]'},
          {label:'ROT13', code:'-,+[-.-[>>++++[>++++++++<-]<+<-[>+>+>-[>>>]<[[>+<-]>>+>]<<<<<-]]>>>[-]+>--[-[<->+++[-]]]<[++++++++++++<[>-[>+>>]>[+[<+>-]>+>>]<<<<<-]>>[<+>-]>[-[-<<[-]>>]<<[<<->>-]>>]<<[<<+>>]>[+]]<[->>+<<]<]'},
          {label:'斐波那契', code:'>++++++++++>+>+[[+++++[>++++++++<-]>.<++++++[>--------<-]+<<<]>.>>[[-]<[>+<-]>>[<<+>+>-]<[>+<-[>+<-[>+<-[>+<-[>+<-[>+<-[>+<-[>+<-[>+<-[>[-]>>>+>+<<<<-[>+<-]]]]]]]]]]]+>>>]<<<]'},
        ].map(ex => (
          <button class="text-[11px] px-3 py-1 rounded border transition-all"
            style="border-color:rgba(180,76,255,0.3);color:rgba(180,76,255,0.7);background:transparent;cursor:pointer"
            data-code={ex.code}
            onclick={`document.getElementById('bf-code').value=this.dataset.code;document.getElementById('bf-input').value='';document.getElementById('bf-output').textContent='';document.getElementById('bf-status').textContent=''`}>
            {ex.label}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
        <!-- Code editor -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <p class="text-[10px] text-[var(--color-text-muted)] uppercase tracking-widest">Source Code</p>
            <div class="flex gap-2">
              <span id="byte-count" class="text-[10px] text-[var(--color-text-muted)]">0 bytes</span>
              <button id="btn-run" class="text-[11px] px-4 py-1 rounded border font-bold transition-all"
                style="border-color:rgba(180,76,255,0.5);color:#b44cff;background:rgba(180,76,255,0.08);cursor:pointer">
                ▶ Run <kbd style="font-size:9px;opacity:0.5">Ctrl+↵</kbd>
              </button>
            </div>
          </div>
          <textarea id="bf-code" rows="10" spellcheck="false"
            placeholder="输入 Brainfuck 代码..."
            class="w-full rounded-lg px-4 py-3 text-sm outline-none resize-y"
            style="background:#06060e;border:1px solid rgba(180,76,255,0.2);color:#d4b4ff;caret-color:#b44cff;line-height:1.6"
            oninput="document.getElementById('byte-count').textContent=this.value.replace(/[^+\-<>.,[\]]/g,'').length+' bytes'"></textarea>
        </div>

        <!-- Input + Output -->
        <div class="flex flex-col gap-4">
          <div>
            <p class="text-[10px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Stdin</p>
            <textarea id="bf-input" rows="3" placeholder="程序输入..."
              class="w-full rounded-lg px-4 py-3 text-sm outline-none resize-none"
              style="background:#06060e;border:1px solid rgba(0,212,255,0.2);color:#e8e8f0;caret-color:#00d4ff"></textarea>
          </div>
          <div class="flex-1">
            <div class="flex items-center justify-between mb-2">
              <p class="text-[10px] text-[var(--color-text-muted)] uppercase tracking-widest">Output</p>
              <span id="bf-stats" class="text-[10px] text-[var(--color-text-muted)]"></span>
            </div>
            <pre id="bf-output" class="rounded-lg px-4 py-3 text-sm overflow-auto"
              style="background:#030308;border:1px solid rgba(0,212,255,0.15);color:#00ff88;min-height:120px;white-space:pre-wrap;word-break:break-all"></pre>
          </div>
        </div>
      </div>

      <!-- Memory visualizer -->
      <div>
        <p class="text-[10px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Memory Tape <span id="ptr-label" class="normal-case text-[var(--color-neon-cyan)]"></span></p>
        <div id="bf-memory" class="flex flex-wrap gap-1"></div>
      </div>

      <!-- Instruction reference -->
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-2">
        {[
          {op:'+', desc:'当前格 +1'},
          {op:'-', desc:'当前格 -1'},
          {op:'>', desc:'指针右移'},
          {op:'<', desc:'指针左移'},
          {op:'.', desc:'输出当前格 ASCII'},
          {op:',', desc:'读入一字符'},
          {op:'[', desc:'格为0则跳到]'},
          {op:']', desc:'格非0则跳回['},
        ].map(({op, desc}) => (
          <div class="px-3 py-2 rounded-lg" style="background:#0f0f1a;border:1px solid rgba(180,76,255,0.1)">
            <span class="text-lg font-bold" style="color:#b44cff">{op}</span>
            <span class="text-[11px] text-[var(--color-text-muted)] ml-2">{desc}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
  (function(){
    const MAX_STEPS = 1e7
    const TAPE_SIZE = 30000

    function run(code, input) {
      const ops = [...code].filter(c => '+-<>.,[]'.includes(c))
      const tape = new Uint8Array(TAPE_SIZE)
      let ptr = 0, ip = 0, inp = 0, out = '', steps = 0
      // 预编译括号
      const jumps = {}
      const stack = []
      ops.forEach((c,i) => {
        if (c === '[') stack.push(i)
        else if (c === ']') {
          const j = stack.pop()
          jumps[i] = j; jumps[j] = i
        }
      })
      while (ip < ops.length && steps < MAX_STEPS) {
        const c = ops[ip]
        switch(c) {
          case '+': tape[ptr] = (tape[ptr] + 1) & 0xff; break
          case '-': tape[ptr] = (tape[ptr] - 1 + 256) & 0xff; break
          case '>': ptr = (ptr + 1) % TAPE_SIZE; break
          case '<': ptr = (ptr - 1 + TAPE_SIZE) % TAPE_SIZE; break
          case '.': out += String.fromCharCode(tape[ptr]); break
          case ',': tape[ptr] = inp < input.length ? input.charCodeAt(inp++) : 0; break
          case '[': if (!tape[ptr]) ip = jumps[ip]; break
          case ']': if (tape[ptr])  ip = jumps[ip]; break
        }
        ip++; steps++
      }
      return { out, tape, ptr, steps, halted: steps < MAX_STEPS }
    }

    function renderMemory(tape, ptr) {
      const el = document.getElementById('bf-memory')
      const start = Math.max(0, ptr - 15)
      const end = Math.min(tape.length, ptr + 16)
      el.innerHTML = ''
      for (let i = start; i < end; i++) {
        const cell = document.createElement('div')
        const isPtr = i === ptr
        cell.className = 'flex flex-col items-center'
        cell.innerHTML = `
          <div style="font-size:9px;color:rgba(136,136,170,0.5);margin-bottom:1px">${i}</div>
          <div style="width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:11px;border-radius:4px;border:1px solid ${isPtr?'rgba(0,212,255,0.6)':'rgba(30,30,48,0.8)'};background:${isPtr?'rgba(0,212,255,0.12)':'rgba(15,15,26,0.8)'};color:${isPtr?'#00d4ff':'rgba(200,200,220,0.7)'};">${tape[i]}</div>
          <div style="font-size:9px;color:rgba(136,136,170,0.3);margin-top:1px">${tape[i]?String.fromCharCode(tape[i]):' '}</div>
        `
        el.appendChild(cell)
      }
      document.getElementById('ptr-label').textContent = `ptr=${ptr}`
    }

    function execute() {
      const code  = document.getElementById('bf-code').value
      const input = document.getElementById('bf-input').value
      const outEl = document.getElementById('bf-output')
      const statusEl = document.getElementById('bf-status')
      const statsEl  = document.getElementById('bf-stats')
      if (!code.trim()) return

      statusEl.textContent = '⟳ running'
      statusEl.style.color = '#ffa500'
      setTimeout(() => {
        const t0 = performance.now()
        const {out, tape, ptr, steps, halted} = run(code, input)
        const ms = (performance.now() - t0).toFixed(1)
        outEl.textContent = out || '(no output)'
        statsEl.textContent = `${steps.toLocaleString()} steps · ${ms}ms`
        statusEl.textContent = halted ? '✓ OK' : '⚠ limit'
        statusEl.style.color  = halted ? '#39ff14' : '#ffa500'
        renderMemory(tape, ptr)
      }, 10)
    }

    document.getElementById('btn-run').addEventListener('click', execute)
    document.addEventListener('keydown', e => {
      if ((e.ctrlKey||e.metaKey) && e.key==='Enter') { e.preventDefault(); execute() }
    })
  })()
  </script>
</BaseLayout>
