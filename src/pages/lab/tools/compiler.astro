    { name:'Promise', code:`const delay=(ms,v)=>new Promise(r=>setTimeout(()=>r(v),ms))\nPromise.resolve(1)\n  .then(v=>{console.log("step1:",v);return delay(0,v+1)})\n  .then(v=>{console.log("step2:",v);return v*10})\n  .then(v=>console.log("done:",v))` },
    { name:'解构',    code:`const {name,age,...rest}={name:"Alice",age:30,role:"admin",city:"BJ"}\nconsole.log(name,age,rest)\nconst [h,...t]=[1,2,3,4,5]\nconsole.log(h,t)` },
  ],
