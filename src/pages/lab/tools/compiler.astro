    { name:'并发',    code:`package main\nimport ("fmt";"sync")\nfunc worker(id int,wg *sync.WaitGroup){\n    defer wg.Done()\n    fmt.Printf("worker %d done\\n",id)\n}\nfunc main(){\n    var wg sync.WaitGroup\n    for i:=1;i<=5;i++{wg.Add(1);go worker(i,&wg)}\n    wg.Wait()\n}` },
