---
import BaseLayout from '../../../layouts/BaseLayout.astro'
---

<BaseLayout title="在线编译器 | void.dev">
  <div class="min-h-screen bg-[var(--color-void)] flex flex-col" style="font-family:var(--font-mono)">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.9)] backdrop-blur-xl">
      <div class="max-w-full px-4 h-12 flex items-center gap-3">
        <a href="/void-blog/lab/" class="text-xs text-[var(--color-neon-green)] hover:opacity-80 transition-opacity">~/lab</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="text-xs text-[var(--color-neon-cyan)]">compiler</span>
        <div class="ml-auto flex items-center gap-3 text-[10px] text-[var(--color-text-muted)]">
          <span id="run-status"></span>
          <span id="engine-label" class="px-2 py-0.5 rounded border" style="border-color:rgba(0,212,255,0.2);color:rgba(0,212,255,0.5)">Worker</span>
        </div>
      </div>
    </nav>

    <div class="flex flex-1 overflow-hidden" style="height:calc(100vh - 48px)">
      <!-- Sidebar -->
      <div class="w-44 flex-shrink-0 border-r border-[var(--color-void-border)] flex flex-col" style="background:#05050f">
        <div class="p-3 border-b border-[var(--color-void-border)]">
          <p class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Language</p>
          <div class="flex flex-col gap-1" id="lang-list"></div>
        </div>
        <div class="p-3 flex-1 overflow-y-auto">
          <p class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Examples</p>
          <div class="flex flex-col gap-1" id="example-list"></div>
        </div>
        <div class="p-3 border-t border-[var(--color-void-border)]">
          <label class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest block mb-1">Stdin</label>
          <textarea id="stdin-input" rows="3" placeholder="stdin (Python)..."
            style="width:100%;background:rgba(0,0,0,0.4);border:1px solid var(--color-void-border);color:var(--color-text-primary);font-size:11px;border-radius:6px;padding:6px;outline:none;resize:none"></textarea>
        </div>
      </div>

      <!-- Editor + Output -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Toolbar -->
        <div class="flex items-center gap-3 px-4 py-2 border-b border-[var(--color-void-border)]" style="background:#07071a">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full" style="background:#ff5f56"></div>
            <div class="w-3 h-3 rounded-full" style="background:#ffbd2e"></div>
            <div class="w-3 h-3 rounded-full" style="background:#27c93f"></div>
          </div>
          <span id="editor-filename" class="text-[11px] text-[var(--color-text-muted)]">main.js</span>
          <div class="ml-auto flex items-center gap-2">
            <button id="run-btn"
              class="flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-xs font-bold"
              style="background:rgba(57,255,20,0.12);border:1px solid rgba(57,255,20,0.4);color:#39ff14">
              ▶ Run
              <kbd style="font-size:9px;opacity:0.5;padding:1px 4px;border:1px solid rgba(57,255,20,0.3);border-radius:3px">Ctrl+↵</kbd>
            </button>
            <button id="clear-btn" class="px-2 py-1.5 rounded text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors border border-[var(--color-void-border)]">Clear</button>
            <button id="copy-btn"  class="px-2 py-1.5 rounded text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors border border-[var(--color-void-border)]">Copy</button>
          </div>
        </div>

        <!-- Editor -->
        <div class="flex flex-1 overflow-hidden">
          <div id="line-numbers" class="select-none text-right px-3 py-4 text-[11px] leading-[1.6] overflow-hidden"
            style="background:#06060e;color:rgba(136,136,170,0.4);min-width:3rem;border-right:1px solid var(--color-void-border)">1</div>
          <textarea id="editor" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off"
            class="flex-1 p-4 text-[12px] leading-[1.6] resize-none outline-none"
            style="background:#06060e;color:#e8e8f0;caret-color:#00d4ff;tab-size:2"></textarea>
        </div>

        <!-- Output -->
        <div style="height:200px;background:#030308;border-top:1px solid var(--color-void-border);display:flex;flex-direction:column">
          <div class="flex items-center gap-3 px-4 py-1.5 border-b border-[var(--color-void-border)]">
            <span style="font-size:10px;color:var(--color-text-muted)">OUTPUT</span>
            <span id="exec-time" style="font-size:10px;color:rgba(136,136,170,0.5)"></span>
          </div>
          <pre id="output" class="flex-1 overflow-auto p-3 text-[12px] leading-relaxed" style="margin:0;color:#e8e8f0;white-space:pre-wrap;word-break:break-all"></pre>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
document.addEventListener('DOMContentLoaded', function () {

// ── Languages ─────────────────────────────────────────────────────────────────
const LANGS = [
  {
    id: 'javascript', label: 'JavaScript', color: '#f7df1e', icon: '🟨', ext: 'js', engine: 'worker',
    template:
`// JavaScript — Worker 沙箱，支持 async/await、ES2024
console.log("Hello, JavaScript!")

const pipe = (...fns) => x => fns.reduce((v, f) => f(v), x)
const double = x => x * 2
const addOne = x => x + 1
const square = x => x * x
console.log("pipe:", pipe(double, addOne, square)(3)) // (3*2+1)^2 = 49

async function main() {
  const nums = [5, 2, 8, 1, 9, 3]
  nums.sort((a, b) => a - b)
  console.log("sorted:", nums)
  const squares = await Promise.all(nums.map(async x => x * x))
  console.log("squares:", squares)
}
main()`,
  },
  {
    id: 'typescript', label: 'TypeScript', color: '#3178c6', icon: '🔷', ext: 'ts', engine: 'babel',
    template:
`// TypeScript — Babel 转译后在 Worker 中运行
interface Point { x: number; y: number }

function distance(a: Point, b: Point): number {
  return Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2)
}
console.log("dist:", distance({ x: 0, y: 0 }, { x: 3, y: 4 }))

type Result<T> = { ok: true; value: T } | { ok: false; error: string }
function divide(a: number, b: number): Result<number> {
  if (b === 0) return { ok: false, error: "division by zero" }
  return { ok: true, value: a / b }
}
console.log(divide(10, 2))
console.log(divide(5, 0))

const greet = (name: string) => \`Hello, \${name}!\`
console.log(greet("TypeScript"))`,
  },
  {
    id: 'python', label: 'Python', color: '#3776ab', icon: '🐍', ext: 'py', engine: 'skulpt',
    template:
`# Python — Skulpt 在浏览器内运行（Python 3 子集）
print("Hello, Python!")

def quicksort(arr):
    if len(arr) <= 1: return arr
    p = arr[len(arr) // 2]
    left  = [x for x in arr if x < p]
    mid   = [x for x in arr if x == p]
    right = [x for x in arr if x > p]
    return quicksort(left) + mid + quicksort(right)

print(quicksort([3, 6, 8, 10, 1, 2, 1]))

class Animal:
    def __init__(self, name):
        self.name = name
    def speak(self):
        return f"{self.name} makes a sound"

class Dog(Animal):
    def speak(self):
        return f"{self.name} says Woof!"

for a in [Dog("Rex"), Animal("Cat")]:
    print(a.speak())`,
  },
]

const EXAMPLES = {
  javascript: [
    { name: '斐波那契',   code: `function fib(n, memo = {}) {\n  if (n <= 1) return n\n  if (memo[n]) return memo[n]\n  return (memo[n] = fib(n-1, memo) + fib(n-2, memo))\n}\nfor (let i = 0; i < 12; i++) console.log(\`fib(\${i}) = \${fib(i)}\`)` },
    { name: 'Promise 链', code: `const delay = (ms, v) => new Promise(r => setTimeout(() => r(v), ms))\nPromise.resolve(1)\n  .then(v => { console.log("step 1:", v); return delay(0, v + 1) })\n  .then(v => { console.log("step 2:", v); return v * 10 })\n  .then(v => console.log("done:", v))` },
    { name: '正则',       code: `const text = "2024-01-15 and 2025-12-31 are dates"\nconst re = /\\d{4}-\\d{2}-\\d{2}/g\nconsole.log("dates:", [...text.matchAll(re)].map(m => m[0]))` },
    { name: '解构赋值',   code: `const user = { name: "Alice", age: 30, roles: ["admin", "user"] }\nconst { name, age, roles: [primary] } = user\nconsole.log(name, age, primary)\nconst [first, ...rest] = [1, 2, 3, 4, 5]\nconsole.log(first, rest)` },
  ],
  typescript: [
    { name: '泛型',       code: `function identity<T>(x: T): T { return x }\nconsole.log(identity<string>("hello"))\nconsole.log(identity<number>(42))\n\ntype Pair<A, B> = { first: A; second: B }\nconst p: Pair<string, number> = { first: "age", second: 30 }\nconsole.log(p)` },
    { name: '判别联合',   code: `type Shape =\n  | { kind: "circle"; r: number }\n  | { kind: "rect"; w: number; h: number }\n\nfunction area(s: Shape): number {\n  switch (s.kind) {\n    case "circle": return Math.PI * s.r ** 2\n    case "rect":   return s.w * s.h\n  }\n}\nconsole.log(area({ kind: "circle", r: 5 }).toFixed(2))\nconsole.log(area({ kind: "rect", w: 4, h: 6 }))` },
    { name: 'Mapped Types', code: `type Readonly2<T> = { readonly [K in keyof T]: T[K] }\ntype Optional<T> = { [K in keyof T]?: T[K] }\n\ninterface User { name: string; age: number; email: string }\ntype RO = Readonly2<User>\ntype Opt = Optional<User>\n\nconst u: Opt = { name: "Alice" }\nconsole.log(u)` },
  ],
  python: [
    { name: '装饰器',     code: `import time\n\ndef timer(fn):\n    def wrapper(*args, **kwargs):\n        t = time.time()\n        result = fn(*args, **kwargs)\n        print(f"{fn.__name__} took {time.time()-t:.4f}s")\n        return result\n    return wrapper\n\n@timer\ndef slow_sum(n):\n    return sum(range(n))\n\nprint(slow_sum(100000))` },
    { name: '生成器',     code: `def fibonacci():\n    a, b = 0, 1\n    while True:\n        yield a\n        a, b = b, a + b\n\ngen = fibonacci()\nfor _ in range(12):\n    print(next(gen), end=" ")\nprint()` },
    { name: '列表推导',   code: `matrix = [[i * j for j in range(1, 6)] for i in range(1, 6)]\nfor row in matrix:\n    print(" ".join(f"{v:3}" for v in row))\n\nflat = [x for row in matrix for x in row if x % 2 == 0]\nprint("偶数:", flat[:8])` },
    { name: '类继承',     code: `class Shape:\n    def area(self): return 0\n\nclass Circle(Shape):\n    def __init__(self, r): self.r = r\n    def area(self): return 3.14159 * self.r ** 2\n\nclass Rect(Shape):\n    def __init__(self, w, h): self.w, self.h = w, h\n    def area(self): return self.w * self.h\n\nfor s in [Circle(5), Rect(4, 6)]:\n    print(f"{type(s).__name__}: area = {s.area():.2f}")` },
  ],
}

// ── State ─────────────────────────────────────────────────────────────────────
let currentLang = LANGS[0]
let running = false
let skulptLoaded = false
let babelLoaded  = false

// ── DOM ───────────────────────────────────────────────────────────────────────
const editor      = document.getElementById('editor')
const output      = document.getElementById('output')
const lineNums    = document.getElementById('line-numbers')
const runBtn      = document.getElementById('run-btn')
const runStatus   = document.getElementById('run-status')
const execTime    = document.getElementById('exec-time')
const langLabel   = document.getElementById('editor-filename')
const engineLabel = document.getElementById('engine-label')
const stdinInput  = document.getElementById('stdin-input')

// ── Sidebar ───────────────────────────────────────────────────────────────────
function renderLangList() {
  const list = document.getElementById('lang-list')
  list.innerHTML = ''
  LANGS.forEach(lang => {
    const btn = document.createElement('button')
    btn.className = 'text-left text-[11px] px-2 py-1.5 rounded-lg transition-all w-full flex items-center gap-2'
    btn.style.cssText = `border:1px solid transparent;color:${lang.color}80;background:transparent;cursor:pointer`
    btn.innerHTML = `<span>${lang.icon}</span> ${lang.label}`
    btn.onclick = () => selectLang(lang)
    btn.dataset.langId = lang.id
    list.appendChild(btn)
  })
  selectLang(LANGS[0])
}

function selectLang(lang) {
  const prev = currentLang
  currentLang = lang
  document.querySelectorAll('#lang-list button').forEach(btn => {
    const active = btn.dataset.langId === lang.id
    btn.style.background  = active ? lang.color + '18' : 'transparent'
    btn.style.borderColor = active ? lang.color + '55' : 'transparent'
    btn.style.color       = active ? lang.color : lang.color + '80'
  })
  langLabel.textContent = `main.${lang.ext}`
  const engineMap = { worker: 'Worker', babel: 'Babel→Worker', skulpt: 'Skulpt' }
  engineLabel.textContent = engineMap[lang.engine]
  stdinInput.style.opacity = lang.engine === 'skulpt' ? '1' : '0.3'

  if (!editor.value || editor.value === prev.template) {
    editor.value = lang.template
    updateLineNumbers()
  }
  renderExamples(lang)

  if (lang.engine === 'skulpt' && !skulptLoaded) loadSkulpt()
  if (lang.engine === 'babel'  && !babelLoaded)  loadBabel()
}

function renderExamples(lang) {
  const list = document.getElementById('example-list')
  list.innerHTML = ''
  ;(EXAMPLES[lang.id] || []).forEach(ex => {
    const btn = document.createElement('button')
    btn.className = 'text-left text-[10px] px-2 py-1.5 rounded border transition-all w-full'
    btn.style.cssText = `border-color:${lang.color}25;color:${lang.color}80;background:transparent;cursor:pointer`
    btn.textContent = ex.name
    btn.onmouseover = () => { btn.style.borderColor = lang.color+'55'; btn.style.color = lang.color }
    btn.onmouseout  = () => { btn.style.borderColor = lang.color+'25'; btn.style.color = lang.color+'80' }
    btn.onclick = () => { editor.value = ex.code; updateLineNumbers() }
    list.appendChild(btn)
  })
}

// ── Lazy load ─────────────────────────────────────────────────────────────────
function loadScript(src, id) {
  return new Promise((resolve, reject) => {
    if (document.getElementById(id)) { resolve(); return }
    const s = document.createElement('script')
    s.id = id; s.src = src
    s.onload = resolve; s.onerror = reject
    document.head.appendChild(s)
  })
}
function loadSkulpt() {
  loadScript('https://cdn.jsdelivr.net/npm/skulpt@1.2.0/dist/skulpt.min.js', 'skulpt-core')
    .then(() => loadScript('https://cdn.jsdelivr.net/npm/skulpt@1.2.0/dist/skulpt-stdlib.js', 'skulpt-stdlib'))
    .then(() => { skulptLoaded = true })
    .catch(() => {})
}
function loadBabel() {
  loadScript('https://cdn.jsdelivr.net/npm/@babel/standalone@7.24.0/babel.min.js', 'babel-standalone')
    .then(() => { babelLoaded = true })
    .catch(() => {})
}

// ── Engines ───────────────────────────────────────────────────────────────────
function runInWorker(code) {
  return new Promise(resolve => {
    const lines = []
    const workerSrc = `
self.console = {
  log:   (...a) => self.postMessage({t:'log',   s: a.map(x => typeof x==='object'?JSON.stringify(x,null,2):String(x)).join(' ')}),
  warn:  (...a) => self.postMessage({t:'warn',  s: a.map(x=>String(x)).join(' ')}),
  error: (...a) => self.postMessage({t:'error', s: a.map(x=>String(x)).join(' ')}),
  info:  (...a) => self.postMessage({t:'log',   s: a.map(x=>String(x)).join(' ')}),
}
self.onmessage = function(e) {
  try {
    const fn = new Function(e.data)
    const r = fn()
    if (r && typeof r.then === 'function') {
      r.then(()  => self.postMessage({t:'done', exit:0}))
       .catch(er => { self.postMessage({t:'error',s:String(er)}); self.postMessage({t:'done',exit:1}) })
    } else {
      self.postMessage({t:'done', exit:0})
    }
  } catch(er) {
    self.postMessage({t:'error', s:String(er)})
    self.postMessage({t:'done', exit:1})
  }
}`
    const blob   = new Blob([workerSrc], { type: 'application/javascript' })
    const blobUrl = URL.createObjectURL(blob)
    const worker  = new Worker(blobUrl)
    const timer   = setTimeout(() => {
      worker.terminate(); URL.revokeObjectURL(blobUrl)
      resolve({ lines: [...lines, '<span style="color:#ffa500">[超时：5s 限制]</span>'], exit: 1 })
    }, 5000)
    worker.onmessage = ({ data }) => {
      if (data.t === 'done') {
        clearTimeout(timer); worker.terminate(); URL.revokeObjectURL(blobUrl)
        resolve({ lines, exit: data.exit })
      } else {
        const color = data.t === 'error' ? '#ff6b6b' : data.t === 'warn' ? '#ffa500' : null
        lines.push(color ? `<span style="color:${color}">${escHtml(data.s)}</span>` : escHtml(data.s))
      }
    }
    worker.onerror = err => {
      clearTimeout(timer); worker.terminate(); URL.revokeObjectURL(blobUrl)
      resolve({ lines: [...lines, `<span style="color:#ff6b6b">${escHtml(err.message)}</span>`], exit: 1 })
    }
    worker.postMessage(code)
  })
}

function runBabel(tsCode) {
  return new Promise(resolve => {
    if (!babelLoaded || !window.Babel) {
      resolve({ lines: ['<span style="color:#ffa500">Babel 加载中，请稍候再试…</span>'], exit: 1 }); return
    }
    let compiled
    try {
      compiled = window.Babel.transform(tsCode, {
        presets: [['typescript', {}]],
        filename: 'main.ts',
      }).code
    } catch (e) {
      resolve({ lines: [`<span style="color:#ff6b6b">TS 编译错误: ${escHtml(e.message)}</span>`], exit: 1 }); return
    }
    runInWorker(compiled).then(resolve)
  })
}

function runSkulpt(pyCode) {
  return new Promise(resolve => {
    if (!skulptLoaded || !window.Sk) {
      resolve({ lines: ['<span style="color:#ffa500">Skulpt 加载中，请稍候再试…</span>'], exit: 1 }); return
    }
    const lines = []
    window.Sk.configure({
      output: text => lines.push(escHtml(text)),
      read: x => {
        if (window.Sk.builtinFiles?.files[x] == null) throw new Error('File not found: ' + x)
        return window.Sk.builtinFiles.files[x]
      },
      inputfun: () => Promise.resolve(stdinInput.value || ''),
      __future__: window.Sk.python3,
    })
    window.Sk.misceval.asyncToPromise(() =>
      window.Sk.importMainWithBody('<stdin>', false, pyCode, true)
    ).then(() => {
      resolve({ lines, exit: 0 })
    }).catch(e => {
      resolve({ lines: [...lines, `<span style="color:#ff6b6b">${escHtml(e.toString())}</span>`], exit: 1 })
    })
  })
}

// ── Run ───────────────────────────────────────────────────────────────────────
async function runCode() {
  if (running) return
  running = true
  output.innerHTML = '<span style="color:rgba(136,136,170,0.4)">Running…</span>'
  execTime.textContent = ''
  runStatus.textContent = '⟳'
  runStatus.style.color = '#ffa500'
  runBtn.disabled = true

  const t0 = Date.now()
  try {
    let result
    if      (currentLang.engine === 'worker') result = await runInWorker(editor.value)
    else if (currentLang.engine === 'babel')  result = await runBabel(editor.value)
    else if (currentLang.engine === 'skulpt') result = await runSkulpt(editor.value)

    const ms = Date.now() - t0
    output.innerHTML = result.lines.length
      ? result.lines.join('')
      : '<span style="color:rgba(136,136,170,0.4)">(no output)</span>'
    execTime.textContent = `exit ${result.exit} · ${ms}ms`
    runStatus.textContent = result.exit === 0 ? '✓ OK' : '✕ Error'
    runStatus.style.color = result.exit === 0 ? '#39ff14' : '#ff4466'
  } catch (e) {
    output.innerHTML = `<span style="color:#ff6b6b">${escHtml(e.message)}</span>`
    runStatus.textContent = '✕'
    runStatus.style.color = '#ff4466'
  }
  running = false
  runBtn.disabled = false
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
}

// ── Editor ────────────────────────────────────────────────────────────────────
function updateLineNumbers() {
  const n = (editor.value.match(/\n/g)||[]).length + 1
  lineNums.innerHTML = Array.from({length:n},(_,i)=>i+1).join('\n')
}
editor.addEventListener('input', updateLineNumbers)
editor.addEventListener('scroll', () => { lineNums.scrollTop = editor.scrollTop })
editor.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); runCode(); return }
  if (e.key === 'Tab') {
    e.preventDefault()
    const s = editor.selectionStart, en = editor.selectionEnd
    editor.value = editor.value.slice(0, s) + '  ' + editor.value.slice(en)
    editor.selectionStart = editor.selectionEnd = s + 2
    updateLineNumbers()
  }
})

runBtn.onclick = runCode
document.getElementById('clear-btn').onclick = () => {
  output.innerHTML = ''; execTime.textContent = ''; runStatus.textContent = ''
}
document.getElementById('copy-btn').onclick = () => {
  navigator.clipboard.writeText(editor.value).then(() => {
    const b = document.getElementById('copy-btn')
    b.textContent = 'Copied!'; setTimeout(() => b.textContent = 'Copy', 1500)
  })
}

// ── Init ──────────────────────────────────────────────────────────────────────
renderLangList()
loadBabel()    // 提前加载，切换时已就绪
loadSkulpt()

})
  </script>
</BaseLayout>
