  ],
  rust: [
    { name:'所有权',  code:`fn main(){\n    let s1=String::from("hello");\n    let s2=s1.clone();\n    println!("{} {}",s1,s2);\n    let v=vec![1,2,3];\n    for i in &v{print!("{} ",i);}\n    println!();\n}` },
