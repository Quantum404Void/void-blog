---
import BaseLayout from '../../../layouts/BaseLayout.astro'
const workerUrl = import.meta.env.PUBLIC_COMPILER_WORKER_URL || ''
---

<BaseLayout title="在线编译器 | void.dev">
  <div class="min-h-screen bg-[var(--color-void)] flex flex-col" style="font-family:var(--font-mono)">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.9)] backdrop-blur-xl">
      <div class="max-w-full px-4 h-12 flex items-center gap-3">
        <a href="/void-blog/lab/" class="text-xs text-[var(--color-neon-green)] hover:opacity-80 transition-opacity">~/lab</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="text-xs text-[var(--color-neon-cyan)]">compiler</span>
        <div class="ml-auto flex items-center gap-3 text-[10px] text-[var(--color-text-muted)]">
          <span id="run-status"></span>
          <span class="px-2 py-0.5 rounded border" style="border-color:rgba(0,212,255,0.2);color:rgba(0,212,255,0.5)">Wandbox</span>
        </div>
      </div>
    </nav>

    <div class="flex flex-1 overflow-hidden" style="height:calc(100vh - 48px)">
      <!-- Sidebar -->
      <div class="w-44 flex-shrink-0 border-r border-[var(--color-void-border)] flex flex-col" style="background:#05050f">
        <div class="p-3 border-b border-[var(--color-void-border)]">
          <p class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Language</p>
          <div class="flex flex-col gap-1" id="lang-list"></div>
        </div>
        <div class="p-3 flex-1 overflow-y-auto">
          <p class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Examples</p>
          <div class="flex flex-col gap-1" id="example-list"></div>
        </div>
        <div class="p-3 border-t border-[var(--color-void-border)]">
          <label class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest block mb-1">Stdin</label>
          <textarea id="stdin-input" rows="3" placeholder="standard input..."
            style="width:100%;background:rgba(0,0,0,0.4);border:1px solid var(--color-void-border);color:var(--color-text-primary);font-size:11px;border-radius:6px;padding:6px;outline:none;resize:none"></textarea>
        </div>
      </div>

      <!-- Editor + Output -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <div class="flex items-center gap-3 px-4 py-2 border-b border-[var(--color-void-border)]" style="background:#07071a">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full" style="background:#ff5f56"></div>
            <div class="w-3 h-3 rounded-full" style="background:#ffbd2e"></div>
            <div class="w-3 h-3 rounded-full" style="background:#27c93f"></div>
          </div>
          <span id="editor-filename" class="text-[11px] text-[var(--color-text-muted)]">main.cpp</span>
          <div class="ml-auto flex items-center gap-2">
            <button id="run-btn"
              class="flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-xs font-bold"
              style="background:rgba(57,255,20,0.12);border:1px solid rgba(57,255,20,0.4);color:#39ff14">
              ▶ Run
              <kbd style="font-size:9px;opacity:0.5;padding:1px 4px;border:1px solid rgba(57,255,20,0.3);border-radius:3px">Ctrl+↵</kbd>
            </button>
            <button id="clear-btn" class="px-2 py-1.5 rounded text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors border border-[var(--color-void-border)]">Clear</button>
            <button id="copy-btn"  class="px-2 py-1.5 rounded text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors border border-[var(--color-void-border)]">Copy</button>
          </div>
        </div>

        <div class="flex flex-1 overflow-hidden">
          <div id="line-numbers" class="select-none text-right px-3 py-4 text-[11px] leading-[1.6] overflow-hidden"
            style="background:#06060e;color:rgba(136,136,170,0.4);min-width:3rem;border-right:1px solid var(--color-void-border)">1</div>
          <textarea id="editor" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off"
            class="flex-1 p-4 text-[12px] leading-[1.6] resize-none outline-none"
            style="background:#06060e;color:#e8e8f0;caret-color:#00d4ff;tab-size:2"></textarea>
        </div>

        <div style="height:220px;background:#030308;border-top:1px solid var(--color-void-border);display:flex;flex-direction:column">
          <div class="flex items-center gap-3 px-4 py-1.5 border-b border-[var(--color-void-border)]">
            <span style="font-size:10px;color:var(--color-text-muted)">OUTPUT</span>
            <span id="exec-time" style="font-size:10px;color:rgba(136,136,170,0.5)"></span>
            <span id="compiler-ver" style="font-size:10px;color:rgba(136,136,170,0.3);margin-left:auto"></span>
          </div>
          <pre id="output" class="flex-1 overflow-auto p-3 text-[12px] leading-relaxed" style="margin:0;color:#e8e8f0;white-space:pre-wrap;word-break:break-all"></pre>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ workerUrl }}>
    window.__WORKER_URL__ = workerUrl
  </script>
  <script is:inline>
document.addEventListener('DOMContentLoaded', function () {

// ── Languages ─────────────────────────────────────────────────────────────────
const LANGS = [
  { id:'cpp', label:'C++', color:'#00599c', icon:'⚙️', ext:'cpp', compiler:'gcc-head',
    template:`#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    cout << "Hello, C++!" << endl;

    vector<int> v = {5, 2, 8, 1, 9, 3};
    sort(v.begin(), v.end());
    for (int x : v) cout << x << " ";
    cout << endl;

    // Lambda
    auto square = [](int x) { return x * x; };
    for (int x : v) cout << square(x) << " ";
    cout << endl;

    return 0;
}` },

  { id:'c', label:'C', color:'#a8b9cc', icon:'🔵', ext:'c', compiler:'gcc-head-c',
    template:`#include <stdio.h>
#include <stdlib.h>

void bubble_sort(int arr[], int n) {
    for (int i = 0; i < n-1; i++)
        for (int j = 0; j < n-i-1; j++)
            if (arr[j] > arr[j+1]) {
                int t = arr[j]; arr[j] = arr[j+1]; arr[j+1] = t;
            }
}

int main() {
    printf("Hello, C!\n");
    int arr[] = {64, 34, 25, 12, 22, 11, 90};
    int n = sizeof(arr)/sizeof(arr[0]);
    bubble_sort(arr, n);
    for (int i = 0; i < n; i++) printf("%d ", arr[i]);
    printf("\n");
    return 0;
}` },

  { id:'python', label:'Python', color:'#3776ab', icon:'🐍', ext:'py', compiler:'cpython-head',
    template:`import sys
from collections import Counter

print("Hello, Python!", sys.version.split()[0])

# 标准库
data = "hello world hello python world hello"
print(Counter(data.split()).most_common(3))

# 推导式
nums = [5, 2, 8, 1, 9, 3]
print(sorted(nums))
print([x**2 for x in sorted(nums)])

# 数据类
from dataclasses import dataclass

@dataclass
class Point:
    x: float
    y: float
    def dist(self): return (self.x**2 + self.y**2)**0.5

print(Point(3, 4).dist())` },

  { id:'javascript', label:'JavaScript', color:'#f7df1e', icon:'🟨', ext:'js', compiler:'nodejs-head',
    template:`console.log("Hello, JavaScript!", process.version)

// ES2024 features
const pipe = (...fns) => x => fns.reduce((v, f) => f(v), x)
const double = x => x * 2
const addOne = x => x + 1
const square = x => x * x
console.log("pipe:", pipe(double, addOne, square)(3))

// Async/await
async function fetchData() {
  const nums = [5, 2, 8, 1, 9, 3]
  nums.sort((a, b) => a - b)
  const squares = await Promise.all(nums.map(async x => x * x))
  console.log("sorted:", nums)
  console.log("squares:", squares)
}
fetchData()

// Destructuring
const {name, age, ...rest} = {name: "Alice", age: 30, role: "admin"}
console.log(name, age, rest)` },

  { id:'typescript', label:'TypeScript', color:'#3178c6', icon:'🔷', ext:'ts', compiler:'typescript-head',
    template:`// TypeScript — 真实 tsc 编译
interface Point { x: number; y: number }

function distance(a: Point, b: Point): number {
  return Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2)
}
console.log("dist:", distance({ x: 0, y: 0 }, { x: 3, y: 4 }))

type Result<T> = { ok: true; value: T } | { ok: false; error: string }
function divide(a: number, b: number): Result<number> {
  if (b === 0) return { ok: false, error: "division by zero" }
  return { ok: true, value: a / b }
}
console.log(divide(10, 2))
console.log(divide(5, 0))

// Mapped types
type Optional<T> = { [K in keyof T]?: T[K] }
interface User { name: string; age: number }
const u: Optional<User> = { name: "Alice" }
console.log(u)` },

  { id:'go', label:'Go', color:'#00add8', icon:'🐹', ext:'go', compiler:'go-head',
    template:`package main

import (
    "fmt"
    "sort"
)

func fibonacci(n int) []int {
    if n <= 0 { return nil }
    fibs := make([]int, n)
    fibs[0] = 0
    if n > 1 { fibs[1] = 1 }
    for i := 2; i < n; i++ {
        fibs[i] = fibs[i-1] + fibs[i-2]
    }
    return fibs
}

func main() {
    fmt.Println("Hello, Go!")
    fmt.Println(fibonacci(10))

    nums := []int{5, 2, 8, 1, 9, 3}
    sort.Ints(nums)
    fmt.Println(nums)
}` },

  { id:'rust', label:'Rust', color:'#dea584', icon:'🦀', ext:'rs', compiler:'rust-head',
    template:`fn fibonacci(n: u32) -> u64 {
    match n {
        0 => 0,
        1 => 1,
        _ => fibonacci(n - 1) + fibonacci(n - 2),
    }
}

fn main() {
    println!("Hello, Rust!");

    let mut v: Vec<i32> = vec![5, 2, 8, 1, 9, 3];
    v.sort();
    println!("{:?}", v);

    let squares: Vec<i32> = v.iter().map(|x| x * x).collect();
    println!("{:?}", squares);

    for i in 0..8 {
        println!("fib({}) = {}", i, fibonacci(i));
    }
}` },

  { id:'java', label:'Java', color:'#f89820', icon:'☕', ext:'java', compiler:'openjdk-head',
    template:`import java.util.*;
import java.util.stream.*;

public class Main {
    static int fibonacci(int n) {
        if (n <= 1) return n;
        return fibonacci(n - 1) + fibonacci(n - 2);
    }

    public static void main(String[] args) {
        System.out.println("Hello, Java!");

        List<Integer> nums = Arrays.asList(5, 2, 8, 1, 9, 3);
        List<Integer> sorted = nums.stream().sorted().collect(Collectors.toList());
        System.out.println(sorted);

        List<Integer> squares = sorted.stream()
            .map(x -> x * x)
            .collect(Collectors.toList());
        System.out.println(squares);

        for (int i = 0; i < 8; i++)
            System.out.printf("fib(%d) = %d%n", i, fibonacci(i));
    }
}` },

  { id:'ruby', label:'Ruby', color:'#cc342d', icon:'💎', ext:'rb', compiler:'ruby-head',
    template:`puts "Hello, Ruby! #{RUBY_VERSION}"

# 枚举
nums = (1..10).to_a
puts nums.select(&:odd?).map { |x| x ** 2 }.inspect

# Hash
scores = {alice: 95, bob: 82, carol: 91}
puts scores.sort_by { |_, v| -v }.first(2).inspect

# 类
class Animal
  def initialize(name) = @name = name
  def speak = "#{@name} makes a sound"
end

class Dog < Animal
  def speak = "#{@name} says Woof!"
end

[Dog.new("Rex"), Animal.new("Cat")].each { |a| puts a.speak }` },

  { id:'lua', label:'Lua', color:'#00599c', icon:'🌙', ext:'lua', compiler:'lua-head',
    template:`print("Hello, Lua! " .. _VERSION)

local nums = {5, 2, 8, 1, 9, 3}
table.sort(nums)
for _, v in ipairs(nums) do io.write(v .. " ") end
print()

-- 闭包
local function counter(start)
  local n = start
  return function() n = n + 1; return n end
end
local c = counter(0)
print(c(), c(), c())

-- 元表
local Vec = {}
Vec.__index = Vec
function Vec.new(x, y) return setmetatable({x=x, y=y}, Vec) end
function Vec:len() return math.sqrt(self.x^2 + self.y^2) end
local v = Vec.new(3, 4)
print("len =", v:len())` },

  { id:'sql', label:'SQLite', color:'#e38c00', icon:'🗄️', ext:'sql', compiler:'sqlite-head',
    template:`CREATE TABLE users (
  id   INTEGER PRIMARY KEY AUTOINCREMENT,
  name TEXT NOT NULL,
  age  INTEGER,
  dept TEXT
);

INSERT INTO users (name, age, dept) VALUES
  ('Alice', 30, 'Engineering'),
  ('Bob',   25, 'Marketing'),
  ('Carol', 35, 'Engineering'),
  ('Dave',  28, 'Marketing'),
  ('Eve',   32, 'Engineering');

SELECT * FROM users ORDER BY age;

SELECT dept, COUNT(*) AS cnt, AVG(age) AS avg_age
FROM users GROUP BY dept;` },
]

// ── Examples ──────────────────────────────────────────────────────────────────
const EXAMPLES = {
