---
import BaseLayout from '../../../layouts/BaseLayout.astro'
---

<BaseLayout title="在线编译器 | void.dev">
  <div class="min-h-screen bg-[var(--color-void)] flex flex-col" style="font-family:var(--font-mono)">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.9)] backdrop-blur-xl">
      <div class="max-w-full px-4 h-12 flex items-center gap-3">
        <a href="/void-blog/lab/" class="text-xs text-[var(--color-neon-green)] hover:opacity-80 transition-opacity">~/lab</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="text-xs text-[var(--color-neon-cyan)]">compiler</span>
        <div class="ml-auto flex items-center gap-3 text-[10px] text-[var(--color-text-muted)]">
          <span id="run-status" class="text-[var(--color-neon-green)]"></span>
          <span>Powered by <a href="https://wandbox.org" target="_blank" class="hover:text-[var(--color-neon-cyan)] transition-colors">Wandbox</a></span>
        </div>
      </div>
    </nav>

    <!-- Main layout -->
    <div class="flex flex-1 overflow-hidden" style="height:calc(100vh - 48px)">
      <!-- Sidebar -->
      <div class="w-44 flex-shrink-0 border-r border-[var(--color-void-border)] flex flex-col overflow-y-auto" style="background:#05050f">
        <!-- Language select -->
        <div class="p-3 border-b border-[var(--color-void-border)]">
          <p class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Language</p>
          <div class="flex flex-col gap-1" id="lang-list">
            <!-- JS injected -->
          </div>
        </div>
        <!-- Examples -->
        <div class="p-3 flex-1">
          <p class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Examples</p>
          <div class="flex flex-col gap-1" id="example-list"></div>
        </div>
        <!-- Settings -->
        <div class="p-3 border-t border-[var(--color-void-border)]">
          <label class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest block mb-1">Stdin</label>
          <textarea id="stdin-input" rows="3" placeholder="stdin..." style="width:100%;background:rgba(0,0,0,0.4);border:1px solid var(--color-void-border);color:var(--color-text-primary);font-size:11px;border-radius:6px;padding:6px;outline:none;resize:none"></textarea>
        </div>
      </div>

      <!-- Editor + Output -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Editor header -->
        <div class="flex items-center gap-3 px-4 py-2 border-b border-[var(--color-void-border)]" style="background:#07071a">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full" style="background:#ff5f56"></div>
            <div class="w-3 h-3 rounded-full" style="background:#ffbd2e"></div>
            <div class="w-3 h-3 rounded-full" style="background:#27c93f"></div>
          </div>
          <span id="editor-filename" class="text-[11px] text-[var(--color-text-muted)]">main.py</span>
          <div class="ml-auto flex items-center gap-2">
            <button id="run-btn" onclick="runCode()"
              class="flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-xs font-bold transition-all"
              style="background:rgba(57,255,20,0.12);border:1px solid rgba(57,255,20,0.4);color:#39ff14"
              onmouseover="this.style.background='rgba(57,255,20,0.22)'"
              onmouseout="this.style.background='rgba(57,255,20,0.12)'">
              ▶ Run
              <kbd style="font-size:9px;opacity:0.5;padding:1px 4px;border:1px solid rgba(57,255,20,0.3);border-radius:3px">Ctrl+↵</kbd>
            </button>
            <button onclick="clearOutput()" class="px-2 py-1.5 rounded text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors border border-[var(--color-void-border)]">Clear</button>
            <button onclick="copyCode()" class="px-2 py-1.5 rounded text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors border border-[var(--color-void-border)]">Copy</button>
          </div>
        </div>

        <!-- Editor -->
        <div class="flex flex-1 overflow-hidden">
          <!-- Line numbers -->
          <div id="line-numbers" class="select-none text-right px-3 py-4 text-[11px] leading-[1.6] overflow-hidden"
            style="background:#06060e;color:rgba(136,136,170,0.4);min-width:3rem;border-right:1px solid var(--color-void-border)">
            1
          </div>
          <!-- Code area -->
          <textarea id="editor" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off"
            class="flex-1 p-4 text-[12px] leading-[1.6] resize-none outline-none"
            style="background:#06060e;color:#e8e8f0;caret-color:#00d4ff;tab-size:4"
            oninput="updateLineNumbers()" onkeydown="handleKey(event)"></textarea>
        </div>

        <!-- Output -->
        <div style="height:200px;background:#030308;border-top:1px solid var(--color-void-border);display:flex;flex-direction:column">
          <div class="flex items-center gap-3 px-4 py-1.5 border-b border-[var(--color-void-border)]">
            <span style="font-size:10px;color:var(--color-text-muted)">OUTPUT</span>
            <span id="exec-time" style="font-size:10px;color:rgba(136,136,170,0.5)"></span>
          </div>
          <pre id="output" class="flex-1 overflow-auto p-3 text-[12px] leading-relaxed" style="margin:0;color:#e8e8f0"></pre>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
document.addEventListener('DOMContentLoaded', function() {

// ── Language config ──────────────────────────────────────────────────────────
const LANGS = [
  {id:'python',  label:'Python',     color:'#3776ab', compiler:'cpython-3.12.7', ext:'py',   icon:'🐍',
   template:`# Python 3.12\nprint("Hello, World!")\n\n# 快速排序\ndef quicksort(arr):\n    if len(arr) <= 1: return arr\n    p = arr[len(arr)//2]\n    return quicksort([x for x in arr if x < p]) + [x for x in arr if x == p] + quicksort([x for x in arr if x > p])\n\nprint(quicksort([3,6,8,10,1,2,1]))`},

  {id:'cpp',     label:'C++',        color:'#00d4ff', compiler:'gcc-13.2.0',     ext:'cpp',  icon:'⚙️',
   template:`#include <iostream>\n#include <vector>\n#include <algorithm>\nusing namespace std;\n\nint main() {\n    cout << "Hello, C++!" << endl;\n    vector<int> v = {5, 2, 8, 1, 9, 3};\n    sort(v.begin(), v.end());\n    for (int x : v) cout << x << " ";\n    cout << endl;\n    return 0;\n}`},

  {id:'c',       label:'C',          color:'#a8b9cc', compiler:'gcc-13.2.0-c',   ext:'c',    icon:'🔧',
   template:`#include <stdio.h>\n#include <stdlib.h>\n\nvoid bubble_sort(int arr[], int n) {\n    for (int i = 0; i < n-1; i++)\n        for (int j = 0; j < n-i-1; j++)\n            if (arr[j] > arr[j+1]) {\n                int t = arr[j]; arr[j] = arr[j+1]; arr[j+1] = t;\n            }\n}\n\nint main() {\n    int arr[] = {64, 34, 25, 12, 22, 11, 90};\n    int n = sizeof(arr)/sizeof(arr[0]);\n    bubble_sort(arr, n);\n    printf("Sorted: ");\n    for (int i = 0; i < n; i++) printf("%d ", arr[i]);\n    printf("\\n");\n    return 0;\n}`},

  {id:'java',    label:'Java',       color:'#f89820', compiler:'openjdk-jdk-21+35', ext:'java', icon:'☕',
   template:`import java.util.*;\n\npublic class Main {\n    public static void main(String[] args) {\n        System.out.println("Hello, Java!");\n        List<Integer> list = Arrays.asList(5, 2, 8, 1, 9, 3);\n        Collections.sort(list);\n        System.out.println("Sorted: " + list);\n    }\n}`},

  {id:'javascript', label:'JavaScript', color:'#f7df1e', compiler:'nodejs-20.17.0', ext:'js', icon:'🟨',
   template:`// Node.js 20\nconsole.log("Hello, JavaScript!")\n\n// async/await\nasync function fetchData() {\n  const data = [1, 2, 3, 4, 5]\n  const result = await Promise.all(data.map(async x => x * x))\n  console.log("Squares:", result)\n}\n\nfetchData()`},

  {id:'typescript', label:'TypeScript', color:'#3178c6', compiler:'nodejs-20.17.0',  ext:'ts', icon:'🔷',
   // Wandbox doesn't have native TS, compile via tsx
   template:`// TypeScript\nconst greet = (name: string): string => {\n  return \`Hello, \${name}!\`\n}\n\nconsole.log(greet("TypeScript"))\n\ninterface Point { x: number; y: number }\nconst dist = (a: Point, b: Point): number =>\n  Math.sqrt((a.x-b.x)**2 + (a.y-b.y)**2)\n\nconsole.log("Distance:", dist({x:0,y:0}, {x:3,y:4}))`},

  {id:'go',      label:'Go',         color:'#00add8', compiler:'go-1.23.2',      ext:'go',   icon:'🔵',
   template:`package main\n\nimport (\n\t"fmt"\n\t"sort"\n)\n\nfunc main() {\n\tfmt.Println("Hello, Go!")\n\tnums := []int{5, 2, 8, 1, 9, 3}\n\tsort.Ints(nums)\n\tfmt.Println("Sorted:", nums)\n}`},

  {id:'rust',    label:'Rust',       color:'#ce422b', compiler:'rust-1.82.0',    ext:'rs',   icon:'🦀',
   template:`fn main() {\n    println!("Hello, Rust!");\n    let mut v = vec![5, 2, 8, 1, 9, 3];\n    v.sort();\n    println!("Sorted: {:?}", v);\n    \n    // 闭包\n    let squares: Vec<i32> = (1..=5).map(|x| x * x).collect();\n    println!("Squares: {:?}", squares);\n}`},

  {id:'kotlin',  label:'Kotlin',     color:'#7f52ff', compiler:'kotlin-2.0.21',  ext:'kt',   icon:'🟣',
   template:`fun main() {\n    println("Hello, Kotlin!")\n    val nums = listOf(5, 2, 8, 1, 9, 3).sorted()\n    println("Sorted: \$nums")\n    val squares = (1..5).map { it * it }\n    println("Squares: \$squares")\n}`},

  {id:'ruby',    label:'Ruby',       color:'#cc342d', compiler:'ruby-3.3.0',     ext:'rb',   icon:'💎',
   template:`puts "Hello, Ruby!"\nnums = [5, 2, 8, 1, 9, 3].sort\nputs "Sorted: #{nums}"\nsquares = (1..5).map { |x| x**2 }\nputs "Squares: #{squares}"`},

  {id:'php',     label:'PHP',        color:'#4f5b93', compiler:'php-7.4.28',     ext:'php',  icon:'🐘',
   template:`<?php\necho "Hello, PHP!\\n";\n$nums = [5, 2, 8, 1, 9, 3];\nsort($nums);\necho "Sorted: " . implode(", ", $nums) . "\\n";\n$squares = array_map(fn($x) => $x * $x, range(1, 5));\necho "Squares: " . implode(", ", $squares) . "\\n";`},

  {id:'bash',    label:'Bash',       color:'#89e051', compiler:'bash',           ext:'sh',   icon:'💻',
   template:`#!/bin/bash\necho "Hello, Bash!"\n\n# 数组操作\narr=(5 2 8 1 9 3)\necho "Original: \${arr[@]}"\n\n# 冒泡排序\nn=\${#arr[@]}\nfor ((i=0; i<n; i++)); do\n  for ((j=0; j<n-i-1; j++)); do\n    if [ "\${arr[j]}" -gt "\${arr[$((j+1))]}" ]; then\n      tmp="\${arr[j]}"; arr[j]="\${arr[$((j+1))]}"; arr[$((j+1))]="\$tmp"\n    fi\n  done\ndone\necho "Sorted: \${arr[@]}"`},
]

// Compiler name → Wandbox compiler identifier mapping
const WANDBOX_COMPILERS = {
  'cpython-3.12.7': 'cpython-3.12.7',
  'gcc-13.2.0':     'gcc-13.2.0',
  'gcc-13.2.0-c':   'gcc-13.2.0-c',
  'openjdk-jdk-21+35': 'openjdk-jdk-21+35',
  'nodejs-20.17.0': 'nodejs-20.17.0',
  'go-1.23.2':      'go-1.23.2',
  'rust-1.82.0':    'rust-1.82.0',
  'kotlin-2.0.21':  'kotlin-2.0.21',
  'ruby-3.3.0':     'ruby-3.3.0',
  'php-7.4.28':     'php-7.4.28',
  'bash':           'bash',
}

let currentLang = LANGS[0]
let running = false

// ── DOM ───────────────────────────────────────────────────────────────────────
const editor      = document.getElementById('editor')
const output      = document.getElementById('output')
const lineNums    = document.getElementById('line-numbers')
const runBtn      = document.getElementById('run-btn')
const runStatus   = document.getElementById('run-status')
const execTime    = document.getElementById('exec-time')
const langLabel   = document.getElementById('editor-filename')
const stdinInput  = document.getElementById('stdin-input')

// ── Language list ─────────────────────────────────────────────────────────────
function renderLangList() {
  const list = document.getElementById('lang-list')
  list.innerHTML = ''
  LANGS.forEach(lang => {
    const btn = document.createElement('button')
    btn.className = 'text-left text-[11px] px-2 py-1.5 rounded-lg transition-all w-full flex items-center gap-2'
    btn.style.cssText = `border:1px solid transparent;color:${lang.color}80;background:transparent`
    btn.innerHTML = `<span>${lang.icon}</span> ${lang.label}`
    btn.onclick = () => selectLang(lang)
    btn.dataset.langId = lang.id
    list.appendChild(btn)
  })
  selectLang(LANGS[0])
}

function selectLang(lang) {
  currentLang = lang
  // Update button styles
  document.querySelectorAll('#lang-list button').forEach(btn => {
    const isActive = btn.dataset.langId === lang.id
    btn.style.background = isActive ? lang.color + '18' : 'transparent'
    btn.style.borderColor = isActive ? lang.color + '55' : 'transparent'
    btn.style.color = isActive ? lang.color : lang.color + '80'
    btn.style.boxShadow = isActive ? `0 0 6px ${lang.color}22` : ''
  })
  langLabel.textContent = `main.${lang.ext}`
  if (!editor.value || editor.value === currentLang?.template) {
    editor.value = lang.template
    updateLineNumbers()
  }
  // Render examples
  renderExamples(lang)
}

function renderExamples(lang) {
  const list = document.getElementById('example-list')
  list.innerHTML = ''
  const examples = LANG_EXAMPLES[lang.id] || []
  examples.forEach(ex => {
    const btn = document.createElement('button')
    btn.className = 'text-left text-[10px] px-2 py-1.5 rounded border transition-all w-full'
    btn.style.cssText = `border-color:${lang.color}25;color:${lang.color}80;background:transparent`
    btn.textContent = ex.name
    btn.onmouseover = () => { btn.style.borderColor = lang.color + '55'; btn.style.color = lang.color }
    btn.onmouseout = () => { btn.style.borderColor = lang.color + '25'; btn.style.color = lang.color + '80' }
    btn.onclick = () => { editor.value = ex.code; updateLineNumbers() }
    list.appendChild(btn)
  })
}

// ── Examples per language ─────────────────────────────────────────────────────
const LANG_EXAMPLES = {
  python: [
    {name:'Hello World', code:`print("Hello, World!")`},
    {name:'递归斐波那契', code:`from functools import lru_cache\n\n@lru_cache(maxsize=None)\ndef fib(n):\n    if n <= 1: return n\n    return fib(n-1) + fib(n-2)\n\nfor i in range(15):\n    print(f"fib({i}) = {fib(i)}")`},
    {name:'列表推导', code:`# 列表推导与生成器\nsquares = [x**2 for x in range(10) if x % 2 == 0]\nprint("Even squares:", squares)\n\n# 嵌套列表推导\nmatrix = [[i*j for j in range(1,4)] for i in range(1,4)]\nfor row in matrix:\n    print(row)`},
    {name:'类与继承', code:`class Animal:\n    def __init__(self, name):\n        self.name = name\n    def speak(self):\n        return f"{self.name} makes a sound"\n\nclass Dog(Animal):\n    def speak(self):\n        return f"{self.name} says Woof!"\n\nclass Cat(Animal):\n    def speak(self):\n        return f"{self.name} says Meow!"\n\nfor animal in [Dog("Rex"), Cat("Whiskers"), Animal("Generic")]:\n    print(animal.speak())`},
  ],
  cpp: [
    {name:'Hello World', code:`#include <iostream>\nusing namespace std;\nint main() { cout << "Hello, C++!" << endl; return 0; }`},
    {name:'STL 算法', code:`#include <iostream>\n#include <vector>\n#include <algorithm>\n#include <numeric>\nusing namespace std;\n\nint main() {\n    vector<int> v = {5,2,8,1,9,3,7,4,6};\n    sort(v.begin(), v.end());\n    cout << "Sorted: ";\n    for (int x : v) cout << x << " ";\n    cout << "\\nSum: " << accumulate(v.begin(),v.end(),0) << endl;\n    auto it = lower_bound(v.begin(),v.end(),6);\n    cout << "lower_bound(6) at index: " << (it-v.begin()) << endl;\n    return 0;\n}`},
    {name:'Lambda & 智能指针', code:`#include <iostream>\n#include <memory>\n#include <functional>\n#include <vector>\nusing namespace std;\n\nstruct Node { int val; Node(int v) : val(v) { cout << "Node(" << v << ") created\\n"; } ~Node() { cout << "Node(" << val << ") destroyed\\n"; } };\n\nint main() {\n    auto ptr = make_shared<Node>(42);\n    cout << "Value: " << ptr->val << ", use_count: " << ptr.use_count() << "\\n";\n    auto copy = ptr;\n    cout << "use_count after copy: " << ptr.use_count() << "\\n";\n    \n    vector<int> v = {3,1,4,1,5,9,2,6};\n    sort(v.begin(), v.end(), [](int a, int b){ return a > b; });\n    for (int x : v) cout << x << " ";\n    return 0;\n}`},
  ],
  javascript: [
    {name:'Hello World', code:`console.log("Hello, JavaScript!")`},
    {name:'Promise链', code:`const delay = ms => new Promise(r => setTimeout(r, ms))\n\nasync function main() {\n  console.log("Start")\n  await delay(0)\n  const results = await Promise.all([1,2,3].map(async n => {\n    await delay(0)\n    return n * n\n  }))\n  console.log("Squares:", results)\n  console.log("Done")\n}\n\nmain()`},
    {name:'闭包与柯里化', code:`// 柯里化\nconst curry = fn => {\n  const arity = fn.length\n  return function curried(...args) {\n    if (args.length >= arity) return fn(...args)\n    return (...more) => curried(...args, ...more)\n  }\n}\n\nconst add = curry((a, b, c) => a + b + c)\nconsole.log(add(1)(2)(3))  // 6\nconsole.log(add(1, 2)(3))  // 6\nconsole.log(add(1)(2, 3))  // 6\n\n// 记忆化\nconst memo = fn => {\n  const cache = new Map()\n  return (...args) => {\n    const key = JSON.stringify(args)\n    if (cache.has(key)) return cache.get(key)\n    const result = fn(...args)\n    cache.set(key, result)\n    return result\n  }\n}\n\nconst fib = memo(n => n <= 1 ? n : fib(n-1) + fib(n-2))\nconsole.log([...Array(10)].map((_,i) => fib(i)))`},
  ],
  go: [
    {name:'Hello World', code:`package main\nimport "fmt"\nfunc main() { fmt.Println("Hello, Go!") }`},
    {name:'Goroutine', code:`package main\n\nimport (\n\t"fmt"\n\t"sync"\n)\n\nfunc worker(id int, wg *sync.WaitGroup) {\n\tdefer wg.Done()\n\tfmt.Printf("Worker %d starting\\n", id)\n\t// 模拟工作\n\tsum := 0\n\tfor i := 0; i < 1000; i++ { sum += i }\n\tfmt.Printf("Worker %d done, sum=%d\\n", id, sum)\n}\n\nfunc main() {\n\tvar wg sync.WaitGroup\n\tfor i := 1; i <= 3; i++ {\n\t\twg.Add(1)\n\t\tgo worker(i, &wg)\n\t}\n\twg.Wait()\n\tfmt.Println("All workers done")\n}`},
  ],
  rust: [
    {name:'Hello World', code:`fn main() { println!("Hello, Rust!"); }`},
    {name:'所有权与借用', code:`fn main() {\n    let s1 = String::from("hello");\n    let len = calculate_length(&s1); // 借用\n    println!("'{}' has {} chars", s1, len);\n    \n    let mut s = String::from("hello");\n    change(&mut s);\n    println!("Changed: {}", s);\n    \n    // 切片\n    let words = "hello world";\n    let first = first_word(words);\n    println!("First word: {}", first);\n}\n\nfn calculate_length(s: &String) -> usize { s.len() }\nfn change(s: &mut String) { s.push_str(", world"); }\nfn first_word(s: &str) -> &str {\n    let bytes = s.as_bytes();\n    for (i, &byte) in bytes.iter().enumerate() {\n        if byte == b' ' { return &s[..i]; }\n    }\n    &s[..]\n}`},
  ],
}
// Fill in minimal examples for others
;['c','java','kotlin','ruby','php','bash','typescript'].forEach(id => {
  if (!LANG_EXAMPLES[id]) {
    const lang = LANGS.find(l => l.id === id)
    LANG_EXAMPLES[id] = [{name:'默认示例', code: lang?.template || ''}]
  }
})

// ── Editor utilities ──────────────────────────────────────────────────────────
function updateLineNumbers() {
  const lines = (editor.value.match(/\n/g) || []).length + 1
  lineNums.innerHTML = Array.from({length: lines}, (_, i) => i+1).join('\n')
}

function handleKey(e) {
  // Ctrl+Enter: run
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
    e.preventDefault(); runCode(); return
  }
  // Tab: indent
  if (e.key === 'Tab') {
    e.preventDefault()
    const s = editor.selectionStart, en = editor.selectionEnd
    editor.value = editor.value.substring(0, s) + '    ' + editor.value.substring(en)
    editor.selectionStart = editor.selectionEnd = s + 4
    updateLineNumbers()
  }
}

function copyCode() {
  navigator.clipboard.writeText(editor.value).then(() => {
    const btn = document.querySelector('button[onclick="copyCode()"]')
    if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 1500) }
  })
}

function clearOutput() {
  output.textContent = ''
  execTime.textContent = ''
  runStatus.textContent = ''
}

// ── Run code via Wandbox ──────────────────────────────────────────────────────
async function runCode() {
  if (running) return
  running = true
  clearOutput()
  runBtn.disabled = true
  runStatus.textContent = '⟳ Running...'
  runStatus.style.color = '#ffa500'

  const code = editor.value
  const lang = currentLang
  const stdin = stdinInput.value
  const t0 = Date.now()

  // TypeScript: transpile client-side using eval trick or just run as JS
  let compiler = lang.compiler
  let finalCode = code

  // Special: TypeScript → run as JS (strip types naively for demo)
  if (lang.id === 'typescript') {
    compiler = 'nodejs-20.17.0'
    // Simple type stripping for demo purposes
    finalCode = code
      .replace(/:\s*\w+(\[\])?(\s*\|[^=;\n]+)?/g, '')
      .replace(/<[^>]+>/g, '')
      .replace(/interface\s+\w+\s*\{[^}]*\}/g, '')
  }

  // Kotlin: use correct compiler name
  if (lang.id === 'kotlin') {
    // Try to find correct kotlin compiler
    try {
      const r = await fetch('https://wandbox.org/api/list.json')
      const list = await r.json()
      const kotlinComp = list.find(c => c.language === 'Kotlin')
      if (kotlinComp) compiler = kotlinComp.name
    } catch(e) {}
  }

  try {
    const payload = { compiler, code: finalCode, stdin }
    const resp = await fetch('https://wandbox.org/api/compile.json', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    })

    if (!resp.ok) throw new Error(`HTTP ${resp.status}`)
    const data = await resp.json()
    const elapsed = Date.now() - t0

    const out = data.program_output || ''
    const err = (data.program_error || '') + (data.compiler_error || '')

    if (out) {
      output.innerHTML += `<span style="color:#e8e8f0">${escapeHtml(out)}</span>`
    }
    if (err) {
      output.innerHTML += `<span style="color:#ff6b6b">${escapeHtml(err)}</span>`
    }
    if (!out && !err) {
      output.innerHTML += `<span style="color:rgba(136,136,170,0.5)">(no output)</span>`
    }

    const exitCode = data.status
    execTime.textContent = `exit ${exitCode} · ${elapsed}ms`
    runStatus.textContent = exitCode == '0' ? '✓ OK' : '✕ Error'
    runStatus.style.color = exitCode == '0' ? '#39ff14' : '#ff4466'

  } catch(e) {
    output.innerHTML = `<span style="color:#ff4466">✕ Network error: ${escapeHtml(e.message)}\n\nNote: This compiler uses Wandbox API. Check your internet connection.</span>`
    runStatus.textContent = '✕ Failed'
    runStatus.style.color = '#ff4466'
  }

  running = false
  runBtn.disabled = false
}

function escapeHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
}

// Expose for HTML onclick
window.runCode = runCode
window.clearOutput = clearOutput
window.copyCode = copyCode

// ── Init ──────────────────────────────────────────────────────────────────────
renderLangList()
updateLineNumbers()
editor.addEventListener('scroll', () => {
  lineNums.scrollTop = editor.scrollTop
})

})
  </script>
</BaseLayout>
