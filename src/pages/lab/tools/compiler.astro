  ],
  ruby: [
    { name:'枚举',    code:`(1..10).each_slice(3){|g| p g}\nputs (1..10).select(&:even?).map{|x|x**2}.inspect` },
    { name:'Mixin',   code:`module Greetable\n  def greet = "Hi, I am #{name}"\nend\nclass Person\n  include Greetable\n  attr_reader :name\n  def initialize(name) = @name=name\nend\nputs Person.new("Alice").greet` },
  ],
  lua: [
    { name:'递归',    code:`local function fact(n)\n  if n<=1 then return 1 end\n  return n*fact(n-1)\nend\nfor i=1,10 do print(i.."! = "..fact(i)) end` },
    { name:'字符串',  code:`local s="Hello, Lua!"\nprint(string.upper(s))\nprint(string.sub(s,1,5))\nfor w in string.gmatch("one two three","(%a+)") do print(w) end` },
  ],
  sql: [
    { name:'JOIN',    code:`CREATE TABLE dept(id INT,name TEXT);\nCREATE TABLE emp(id INT,name TEXT,dept_id INT,salary INT);\nINSERT INTO dept VALUES(1,'Eng'),(2,'Mkt');\nINSERT INTO emp VALUES(1,'Alice',1,9000),(2,'Bob',2,7000),(3,'Carol',1,8500);\nSELECT e.name,d.name AS dept,e.salary FROM emp e JOIN dept d ON e.dept_id=d.id ORDER BY salary DESC;` },
    { name:'GROUP BY',code:`CREATE TABLE sales(product TEXT,amount INT);\nINSERT INTO sales VALUES('A',100),('B',200),('A',150),('B',180),('A',120);\nSELECT product,SUM(amount) AS total,ROUND(AVG(amount),1) AS avg FROM sales GROUP BY product ORDER BY total DESC;` },
  ],
}

// ── State ─────────────────────────────────────────────────────────────────────
let currentLang = LANGS[0]
let running     = false

// ── DOM ───────────────────────────────────────────────────────────────────────
const editor      = document.getElementById('editor')
const output      = document.getElementById('output')
const lineNums    = document.getElementById('line-numbers')
const runBtn      = document.getElementById('run-btn')
const runStatus   = document.getElementById('run-status')
const execTime    = document.getElementById('exec-time')
const compilerVer = document.getElementById('compiler-ver')
const langLabel   = document.getElementById('editor-filename')
const stdinInput  = document.getElementById('stdin-input')

// ── Sidebar ───────────────────────────────────────────────────────────────────
function renderLangList() {
  const list = document.getElementById('lang-list')
  list.innerHTML = ''
  LANGS.forEach(lang => {
    const btn = document.createElement('button')
    btn.className = 'text-left text-[11px] px-2 py-1.5 rounded-lg transition-all w-full flex items-center gap-2'
    btn.style.cssText = `border:1px solid transparent;color:${lang.color}80;background:transparent;cursor:pointer`
    btn.innerHTML = `<span>${lang.icon}</span> ${lang.label}`
    btn.onclick = () => selectLang(lang)
    btn.dataset.langId = lang.id
    list.appendChild(btn)
  })
  selectLang(LANGS[0])
}

function selectLang(lang) {
  const prev = currentLang
  currentLang = lang
  document.querySelectorAll('#lang-list button').forEach(btn => {
    const active = btn.dataset.langId === lang.id
    btn.style.background  = active ? lang.color + '18' : 'transparent'
    btn.style.borderColor = active ? lang.color + '40' : 'transparent'
    btn.style.color       = active ? lang.color : lang.color + '60'
  })
  langLabel.textContent = `main.${lang.ext}`
  compilerVer.textContent = lang.compiler
  if (!editor.value || editor.value === prev.template) {
    editor.value = lang.template
    updateLineNumbers()
  }
  renderExamples(lang)
}

function renderExamples(lang) {
  const list = document.getElementById('example-list')
  list.innerHTML = ''
  const exs = EXAMPLES[lang.id] || []
  exs.forEach(ex => {
    const btn = document.createElement('button')
    btn.className = 'text-left text-[10px] px-2 py-1 rounded transition-colors w-full'
    btn.style.cssText = 'color:rgba(136,136,170,0.6);background:transparent;cursor:pointer;border:1px solid transparent'
    btn.textContent = ex.name
    btn.onmouseenter = () => btn.style.color = 'rgba(0,212,255,0.8)'
    btn.onmouseleave = () => btn.style.color = 'rgba(136,136,170,0.6)'
    btn.onclick = () => {
      editor.value = ex.code
      updateLineNumbers()
    }
    list.appendChild(btn)
  })
}

// ── Wandbox API ───────────────────────────────────────────────────────────────
async function runWandbox(code, compiler, stdin) {
  // 优先走 CF Worker 代理（解决 CORS），没有则直接请求 Wandbox
  const base = (window.__WORKER_URL__ || '').replace(/\/+$/, '')
  const url  = base ? base + '/api/compile.json' : 'https://wandbox.org/api/compile.json'

  let resp
  try {
    resp = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        compiler,
        code,
        stdin: stdin || '',
        'compiler-option-raw': '',
        options: '',
      }),
      signal: AbortSignal.timeout(30000),
    })
  } catch (e) {
    const msg = e.name === 'AbortError' ? '编译超时（30s）' : '网络错误: ' + e.message
    return { lines: [`<span style="color:#ff6b6b">${escHtml(msg)}</span>`], exit: 1 }
  }

  if (!resp.ok) {
    return { lines: [`<span style="color:#ff6b6b">服务错误 HTTP ${resp.status}</span>`], exit: 1 }
  }

  const data = await resp.json()
  const lines = []

  if (data.compiler_message && data.compiler_message.trim()) {
    // compiler_message 包含警告/错误，黄色显示
    lines.push('<span style="color:rgba(255,200,0,0.85)">' + escHtml(data.compiler_message.trimEnd()) + '</span>')
  }
  if (data.program_output && data.program_output.trim()) {
    lines.push(escHtml(data.program_output))
  }
  if (data.program_error && data.program_error.trim()) {
    lines.push('<span style="color:#ff6b6b">' + escHtml(data.program_error.trimEnd()) + '</span>')
  }
  if (!lines.length) {
    lines.push('<span style="color:rgba(136,136,170,0.4)">(no output)</span>')
  }

  const exit = (data.status === '0' || data.status === 0) ? 0 : 1
  return { lines, exit }
}

// ── Run ───────────────────────────────────────────────────────────────────────
async function runCode() {
  if (running) return
  running = true
  output.innerHTML = '<span style="color:rgba(136,136,170,0.3)">Compiling…</span>'
  execTime.textContent = ''
  runStatus.textContent = '⟳'
  runStatus.style.color = '#ffa500'
  runBtn.disabled = true

  const t0 = Date.now()
  try {
    const result = await runWandbox(editor.value, currentLang.compiler, stdinInput.value)
    const ms = Date.now() - t0
    output.innerHTML = result.lines.join('\n')
    execTime.textContent = `exit ${result.exit} · ${ms}ms`
    runStatus.textContent = result.exit === 0 ? '✓ OK' : '✕ Error'
    runStatus.style.color = result.exit === 0 ? '#39ff14' : '#ff4466'
  } catch (e) {
    output.innerHTML = `<span style="color:#ff6b6b">${escHtml(e.message)}</span>`
    runStatus.textContent = '✕'
    runStatus.style.color = '#ff4466'
  }
  running = false
  runBtn.disabled = false
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
}

// ── Editor ────────────────────────────────────────────────────────────────────
function updateLineNumbers() {
  const n = (editor.value.match(/\n/g) || []).length + 1
  lineNums.innerHTML = Array.from({ length: n }, (_, i) => i + 1).join('\n')
}
editor.addEventListener('input', updateLineNumbers)
editor.addEventListener('scroll', () => { lineNums.scrollTop = editor.scrollTop })
editor.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); runCode(); return }
  if (e.key === 'Tab') {
    e.preventDefault()
    const s = editor.selectionStart, en = editor.selectionEnd
    editor.value = editor.value.slice(0, s) + '  ' + editor.value.slice(en)
    editor.selectionStart = editor.selectionEnd = s + 2
    updateLineNumbers()
  }
})

runBtn.onclick = runCode
document.getElementById('clear-btn').onclick = () => {
  output.innerHTML = ''; execTime.textContent = ''; runStatus.textContent = ''
}
document.getElementById('copy-btn').onclick = () => {
  navigator.clipboard.writeText(editor.value).then(() => {
    const b = document.getElementById('copy-btn')
    b.textContent = 'Copied!'; setTimeout(() => b.textContent = 'Copy', 1500)
  })
}

// ── Init ──────────────────────────────────────────────────────────────────────
renderLangList()

})
  </script>
</BaseLayout>
