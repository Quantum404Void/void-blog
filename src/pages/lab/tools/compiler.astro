---
import BaseLayout from '../../../layouts/BaseLayout.astro'
---

<BaseLayout title="在线编译器 | void.dev">
  <div class="min-h-screen bg-[var(--color-void)] flex flex-col" style="font-family:var(--font-mono)">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.9)] backdrop-blur-xl">
      <div class="max-w-full px-4 h-12 flex items-center gap-3">
        <a href="/void-blog/lab/" class="text-xs text-[var(--color-neon-green)] hover:opacity-80 transition-opacity">~/lab</a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="text-xs text-[var(--color-neon-cyan)]">compiler</span>
        <div class="ml-auto flex items-center gap-3 text-[10px] text-[var(--color-text-muted)]">
          <span id="run-status"></span>
          <span id="engine-badge" class="px-2 py-0.5 rounded text-[9px] border" style="border-color:rgba(0,212,255,0.2);color:rgba(0,212,255,0.5)">local</span>
        </div>
      </div>
    </nav>

    <div class="flex flex-1 overflow-hidden" style="height:calc(100vh - 48px)">
      <!-- Sidebar -->
      <div class="w-44 flex-shrink-0 border-r border-[var(--color-void-border)] flex flex-col overflow-y-auto" style="background:#05050f">
        <div class="p-3 border-b border-[var(--color-void-border)]">
          <p class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Language</p>
          <div class="flex flex-col gap-1" id="lang-list"></div>
        </div>
        <div class="p-3 flex-1">
          <p class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest mb-2">Examples</p>
          <div class="flex flex-col gap-1" id="example-list"></div>
        </div>
        <div class="p-3 border-t border-[var(--color-void-border)]">
          <label class="text-[9px] text-[var(--color-text-muted)] uppercase tracking-widest block mb-1">Stdin</label>
          <textarea id="stdin-input" rows="3" placeholder="stdin (Python only)..."
            style="width:100%;background:rgba(0,0,0,0.4);border:1px solid var(--color-void-border);color:var(--color-text-primary);font-size:11px;border-radius:6px;padding:6px;outline:none;resize:none"></textarea>
        </div>
      </div>

      <!-- Editor + Output -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Editor header -->
        <div class="flex items-center gap-3 px-4 py-2 border-b border-[var(--color-void-border)]" style="background:#07071a">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full" style="background:#ff5f56"></div>
            <div class="w-3 h-3 rounded-full" style="background:#ffbd2e"></div>
            <div class="w-3 h-3 rounded-full" style="background:#27c93f"></div>
          </div>
          <span id="editor-filename" class="text-[11px] text-[var(--color-text-muted)]">main.js</span>
          <div class="ml-auto flex items-center gap-2">
            <button id="run-btn"
              class="flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-xs font-bold transition-all"
              style="background:rgba(57,255,20,0.12);border:1px solid rgba(57,255,20,0.4);color:#39ff14">
              ▶ Run
              <kbd style="font-size:9px;opacity:0.5;padding:1px 4px;border:1px solid rgba(57,255,20,0.3);border-radius:3px">Ctrl+↵</kbd>
            </button>
            <button id="clear-btn" class="px-2 py-1.5 rounded text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors border border-[var(--color-void-border)]">Clear</button>
            <button id="copy-btn" class="px-2 py-1.5 rounded text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-neon-cyan)] transition-colors border border-[var(--color-void-border)]">Copy</button>
          </div>
        </div>

        <!-- Editor -->
        <div class="flex flex-1 overflow-hidden">
          <div id="line-numbers" class="select-none text-right px-3 py-4 text-[11px] leading-[1.6] overflow-hidden"
            style="background:#06060e;color:rgba(136,136,170,0.4);min-width:3rem;border-right:1px solid var(--color-void-border)">1</div>
          <textarea id="editor" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off"
            class="flex-1 p-4 text-[12px] leading-[1.6] resize-none outline-none"
            style="background:#06060e;color:#e8e8f0;caret-color:#00d4ff;tab-size:2"></textarea>
        </div>

        <!-- Output -->
        <div style="height:200px;background:#030308;border-top:1px solid var(--color-void-border);display:flex;flex-direction:column">
          <div class="flex items-center gap-3 px-4 py-1.5 border-b border-[var(--color-void-border)]">
            <span style="font-size:10px;color:var(--color-text-muted)">OUTPUT</span>
            <span id="exec-time" style="font-size:10px;color:rgba(136,136,170,0.5)"></span>
            <!-- Playground link for unsupported languages -->
            <a id="playground-link" href="#" target="_blank" class="ml-auto hidden text-[10px] hover:opacity-100 transition-opacity"
              style="color:rgba(0,212,255,0.6);text-decoration:none">
              在官方 Playground 打开 ↗
            </a>
          </div>
          <pre id="output" class="flex-1 overflow-auto p-3 text-[12px] leading-relaxed" style="margin:0;color:#e8e8f0;white-space:pre-wrap;word-break:break-all"></pre>
        </div>
      </div>
    </div>
  </div>

  <!-- Skulpt for Python (lazy loaded) -->
  <!-- Babel standalone for TypeScript (lazy loaded) -->

  <script is:inline>
document.addEventListener('DOMContentLoaded', function () {

// ── Language definitions ─────────────────────────────────────────────────────
// engine: 'js' | 'python' | 'typescript' | 'playground'
const LANGS = [
  { id: 'javascript', label: 'JavaScript', color: '#f7df1e', icon: '🟨', ext: 'js', engine: 'js',
    template: `// JavaScript — 浏览器 Worker 沙箱运行
console.log("Hello, JavaScript!")

// 高阶函数
const pipe = (...fns) => x => fns.reduce((v, f) => f(v), x)
const double = x => x * 2
const addOne = x => x + 1
const square = x => x * x

const transform = pipe(double, addOne, square)
console.log("pipe(double,addOne,square)(3) =", transform(3))

// 异步
const delay = ms => new Promise(r => setTimeout(r, ms))
async function main() {
  await delay(0)
  const nums = [5, 2, 8, 1, 9, 3]
  console.log("sorted:", nums.sort((a, b) => a - b))
}
main()` },

  { id: 'typescript', label: 'TypeScript', color: '#3178c6', icon: '🔷', ext: 'ts', engine: 'typescript',
    template: `// TypeScript — Babel 转译后在 Worker 沙箱运行
interface Point { x: number; y: number }

function distance(a: Point, b: Point): number {
  return Math.sqrt((a.x - b.x) ** 2 + (a.y - b.y) ** 2)
}

console.log("distance:", distance({ x: 0, y: 0 }, { x: 3, y: 4 }))

const greet = (name: string): string => \`Hello, \${name}!\`
console.log(greet("TypeScript"))

type Result<T> = { ok: true; value: T } | { ok: false; error: string }
function divide(a: number, b: number): Result<number> {
  if (b === 0) return { ok: false, error: "division by zero" }
  return { ok: true, value: a / b }
}
console.log(divide(10, 2))
console.log(divide(5, 0))` },

  { id: 'python', label: 'Python', color: '#3776ab', icon: '🐍', ext: 'py', engine: 'python',
    template: `# Python — Skulpt 在浏览器内运行（标准库子集）
print("Hello, Python!")

def quicksort(arr):
    if len(arr) <= 1: return arr
    p = arr[len(arr) // 2]
    return quicksort([x for x in arr if x < p]) + \
           [x for x in arr if x == p] + \
           quicksort([x for x in arr if x > p])

print(quicksort([3, 6, 8, 10, 1, 2, 1]))

# 类
class Animal:
    def __init__(self, name):
        self.name = name
    def speak(self):
        return f"{self.name} makes a sound"

class Dog(Animal):
    def speak(self):
        return f"{self.name} says Woof!"

for a in [Dog("Rex"), Animal("Cat")]:
    print(a.speak())` },

  { id: 'cpp', label: 'C++', color: '#00d4ff', icon: '⚙️', ext: 'cpp', engine: 'playground',
    playgroundUrl: 'https://cpp.sh/?source=',
    template: `#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    cout << "Hello, C++!" << endl;
    vector<int> v = {5, 2, 8, 1, 9, 3};
    sort(v.begin(), v.end());
    for (int x : v) cout << x << " ";
    cout << endl;
    return 0;
}` },

  { id: 'go', label: 'Go', color: '#00add8', icon: '🔵', ext: 'go', engine: 'playground',
    playgroundUrl: 'https://go.dev/play/',
    template: `package main

import (
\t"fmt"
\t"sort"
)

func main() {
\tfmt.Println("Hello, Go!")
\tnums := []int{5, 2, 8, 1, 9, 3}
\tsort.Ints(nums)
\tfmt.Println("Sorted:", nums)
}` },

  { id: 'rust', label: 'Rust', color: '#ce422b', icon: '🦀', ext: 'rs', engine: 'playground',
    playgroundUrl: 'https://play.rust-lang.org/?code=',
    template: `fn main() {
    println!("Hello, Rust!");
    let mut v = vec![5, 2, 8, 1, 9, 3];
    v.sort();
    println!("Sorted: {:?}", v);
    let squares: Vec<i32> = (1..=5).map(|x| x * x).collect();
    println!("Squares: {:?}", squares);
}` },

  { id: 'java', label: 'Java', color: '#f89820', icon: '☕', ext: 'java', engine: 'playground',
    playgroundUrl: 'https://onecompiler.com/java',
    template: `import java.util.*;

public class Main {
    public static void main(String[] args) {
        System.out.println("Hello, Java!");
        List<Integer> list = Arrays.asList(5, 2, 8, 1, 9, 3);
        Collections.sort(list);
        System.out.println("Sorted: " + list);
    }
}` },
]

const EXAMPLES = {
  javascript: [
    { name: '斐波那契', code: `function fib(n) {\n  const memo = {}\n  function _fib(n) {\n    if (n <= 1) return n\n    if (memo[n]) return memo[n]\n    return (memo[n] = _fib(n-1) + _fib(n-2))\n  }\n  return _fib(n)\n}\nfor (let i = 0; i < 10; i++) console.log(\`fib(\${i}) = \${fib(i)}\`)` },
    { name: 'Promise 链', code: `const delay = (ms, val) => new Promise(r => setTimeout(() => r(val), ms))\n\nPromise.resolve(1)\n  .then(v => { console.log('step 1:', v); return delay(0, v + 1) })\n  .then(v => { console.log('step 2:', v); return v * 2 })\n  .then(v => console.log('done:', v))` },
    { name: '正则匹配', code: `const text = "2024-01-15 and 2025-12-31 are dates"\nconst re = /\\d{4}-\\d{2}-\\d{2}/g\nconst matches = text.match(re)\nconsole.log("Found dates:", matches)` },
  ],
  typescript: [
    { name: '泛型工具', code: `type DeepReadonly<T> = {\n  readonly [K in keyof T]: T[K] extends object ? DeepReadonly<T[K]> : T[K]\n}\n\ntype Maybe<T> = T | null | undefined\nfunction unwrap<T>(val: Maybe<T>, fallback: T): T {\n  return val ?? fallback\n}\nconsole.log(unwrap(null, "default"))\nconsole.log(unwrap(42, 0))` },
    { name: '枚举 + 判别联合', code: `type Shape =\n  | { kind: 'circle'; r: number }\n  | { kind: 'rect'; w: number; h: number }\n\nfunction area(s: Shape): number {\n  switch (s.kind) {\n    case 'circle': return Math.PI * s.r ** 2\n    case 'rect': return s.w * s.h\n  }\n}\nconsole.log(area({ kind: 'circle', r: 5 }).toFixed(2))\nconsole.log(area({ kind: 'rect', w: 4, h: 6 }))` },
  ],
  python: [
    { name: '装饰器', code: `import time\n\ndef timer(fn):\n    def wrapper(*args, **kwargs):\n        t = time.time()\n        result = fn(*args, **kwargs)\n        print(f"{fn.__name__} took {time.time()-t:.4f}s")\n        return result\n    return wrapper\n\n@timer\ndef slow_sum(n):\n    return sum(range(n))\n\nprint(slow_sum(100000))` },
    { name: '列表推导', code: `matrix = [[i*j for j in range(1,6)] for i in range(1,6)]\nfor row in matrix:\n    print(' '.join(f'{v:3}' for v in row))\n\nflat = [x for row in matrix for x in row if x % 2 == 0]\nprint("偶数:", flat[:10])` },
    { name: '生成器', code: `def fibonacci():\n    a, b = 0, 1\n    while True:\n        yield a\n        a, b = b, a + b\n\ngen = fibonacci()\nfor _ in range(10):\n    print(next(gen), end=' ')\nprint()` },
  ],
}

// ── State ─────────────────────────────────────────────────────────────────────
let currentLang = LANGS[0]
let running = false
let skulptReady = false
let babelReady = false

// ── DOM refs ──────────────────────────────────────────────────────────────────
const editor      = document.getElementById('editor')
const output      = document.getElementById('output')
const lineNums    = document.getElementById('line-numbers')
const runBtn      = document.getElementById('run-btn')
const runStatus   = document.getElementById('run-status')
const execTime    = document.getElementById('exec-time')
const langLabel   = document.getElementById('editor-filename')
const engineBadge = document.getElementById('engine-badge')
const pgLink      = document.getElementById('playground-link')
const stdinInput  = document.getElementById('stdin-input')

// ── Sidebar ───────────────────────────────────────────────────────────────────
function renderLangList() {
  const list = document.getElementById('lang-list')
  list.innerHTML = ''
  LANGS.forEach(lang => {
    const btn = document.createElement('button')
    btn.className = 'text-left text-[11px] px-2 py-1.5 rounded-lg transition-all w-full flex items-center gap-2'
    btn.style.cssText = `border:1px solid transparent;color:${lang.color}80;background:transparent`
    btn.innerHTML = `<span>${lang.icon}</span><span>${lang.label}</span>`
    if (lang.engine === 'playground') {
      btn.innerHTML += `<span style="font-size:9px;opacity:0.4;margin-left:auto">↗</span>`
    }
    btn.onclick = () => selectLang(lang)
    btn.dataset.langId = lang.id
    list.appendChild(btn)
  })
  selectLang(LANGS[0])
}

function selectLang(lang) {
  const prevLang = currentLang
  currentLang = lang
  document.querySelectorAll('#lang-list button').forEach(btn => {
    const active = btn.dataset.langId === lang.id
    btn.style.background = active ? lang.color + '18' : 'transparent'
    btn.style.borderColor = active ? lang.color + '55' : 'transparent'
    btn.style.color = active ? lang.color : lang.color + '80'
  })
  langLabel.textContent = `main.${lang.ext}`

  // Engine badge
  const engineLabel = { js: 'Worker', typescript: 'Babel→Worker', python: 'Skulpt', playground: 'Playground' }
  engineBadge.textContent = engineLabel[lang.engine]

  // Playground link
  if (lang.engine === 'playground') {
    pgLink.classList.remove('hidden')
    pgLink.href = lang.playgroundUrl + (lang.playgroundUrl.endsWith('/') ? '' : encodeURIComponent(editor.value || lang.template))
  } else {
    pgLink.classList.add('hidden')
  }

  // Load template if switching language or empty
  if (!editor.value || editor.value === prevLang.template) {
    editor.value = lang.template
    updateLineNumbers()
  }

  renderExamples(lang)

  // Preload engines
  if (lang.engine === 'python' && !skulptReady) loadSkulpt()
  if (lang.engine === 'typescript' && !babelReady) loadBabel()
}

function renderExamples(lang) {
  const list = document.getElementById('example-list')
  list.innerHTML = ''
  const exs = EXAMPLES[lang.id] || []
  exs.forEach(ex => {
    const btn = document.createElement('button')
    btn.className = 'text-left text-[10px] px-2 py-1.5 rounded border transition-all w-full'
    btn.style.cssText = `border-color:${lang.color}25;color:${lang.color}80;background:transparent`
    btn.textContent = ex.name
    btn.onmouseover = () => { btn.style.borderColor = lang.color + '55'; btn.style.color = lang.color }
    btn.onmouseout  = () => { btn.style.borderColor = lang.color + '25'; btn.style.color = lang.color + '80' }
    btn.onclick = () => { editor.value = ex.code; updateLineNumbers() }
    list.appendChild(btn)
  })

  if (lang.engine === 'playground') {
    const hint = document.createElement('div')
    hint.className = 'text-[10px] mt-2'
    hint.style.color = 'rgba(255,165,0,0.6)'
    hint.textContent = '点击 "在官方 Playground 打开" 运行'
    list.appendChild(hint)
  }
}

// ── Lazy load engines ─────────────────────────────────────────────────────────
function loadSkulpt() {
  if (document.getElementById('skulpt-script')) return
  const s1 = document.createElement('script')
  s1.id = 'skulpt-script'
  s1.src = 'https://cdn.jsdelivr.net/npm/skulpt@1.2.0/dist/skulpt.min.js'
  s1.onload = () => {
    const s2 = document.createElement('script')
    s2.src = 'https://cdn.jsdelivr.net/npm/skulpt@1.2.0/dist/skulpt-stdlib.js'
    s2.onload = () => { skulptReady = true }
    document.head.appendChild(s2)
  }
  document.head.appendChild(s1)
}

function loadBabel() {
  if (document.getElementById('babel-script')) return
  const s = document.createElement('script')
  s.id = 'babel-script'
  s.src = 'https://cdn.jsdelivr.net/npm/@babel/standalone@7.24.0/babel.min.js'
  s.onload = () => { babelReady = true }
  document.head.appendChild(s)
}

// ── Run engines ───────────────────────────────────────────────────────────────
function runJS(code) {
  return new Promise((resolve) => {
    const lines = []
    // Web Worker 沙箱
    const workerCode = `
self.console = {
  log:   (...a) => self.postMessage({ type:'log',   text: a.map(v => typeof v === 'object' ? JSON.stringify(v,null,2) : String(v)).join(' ') }),
  error: (...a) => self.postMessage({ type:'error', text: a.map(v => String(v)).join(' ') }),
  warn:  (...a) => self.postMessage({ type:'warn',  text: a.map(v => String(v)).join(' ') }),
  info:  (...a) => self.postMessage({ type:'log',   text: a.map(v => String(v)).join(' ') }),
}
self.onmessage = function(e) {
  try {
    const fn = new Function(e.data)
    const result = fn()
    if (result instanceof Promise) {
      result.then(() => self.postMessage({ type:'done', exit:0 }))
            .catch(err => { self.postMessage({ type:'error', text: String(err) }); self.postMessage({ type:'done', exit:1 }) })
    } else {
      self.postMessage({ type:'done', exit:0 })
    }
  } catch(err) {
    self.postMessage({ type:'error', text: String(err) })
    self.postMessage({ type:'done', exit:1 })
  }
}
`
    const blob = new Blob([workerCode], { type: 'application/javascript' })
    const url = URL.createObjectURL(blob)
    const worker = new Worker(url)
    const timeout = setTimeout(() => {
      worker.terminate(); URL.revokeObjectURL(url)
      resolve({ lines: [...lines, '[超时：5秒限制]'], exit: 1 })
    }, 5000)

    worker.onmessage = (e) => {
      if (e.data.type === 'done') {
        clearTimeout(timeout); worker.terminate(); URL.revokeObjectURL(url)
        resolve({ lines, exit: e.data.exit })
      } else {
        const color = e.data.type === 'error' ? '\x1b[31m' : (e.data.type === 'warn' ? '\x1b[33m' : '')
        lines.push((color ? `<span style="color:${e.data.type==='error'?'#ff6b6b':'#ffa500'}">` : '') + escHtml(e.data.text) + (color ? '</span>' : ''))
      }
    }
    worker.onerror = (e) => {
      clearTimeout(timeout); worker.terminate(); URL.revokeObjectURL(url)
      resolve({ lines: [...lines, `<span style="color:#ff6b6b">${escHtml(e.message)}</span>`], exit: 1 })
    }
    worker.postMessage(code)
  })
}

function runTS(code) {
  return new Promise((resolve, reject) => {
    if (!babelReady || !window.Babel) { reject(new Error('Babel 加载中，请稍候再试')); return }
    let compiled
    try {
      compiled = window.Babel.transform(code, {
        presets: ['typescript'],
        filename: 'main.ts',
      }).code
    } catch (e) {
      resolve({ lines: [`<span style="color:#ff6b6b">TS 编译错误: ${escHtml(e.message)}</span>`], exit: 1 })
      return
    }
    runJS(compiled).then(resolve)
  })
}

function runPython(code) {
  return new Promise((resolve, reject) => {
    if (!skulptReady || !window.Sk) { reject(new Error('Skulpt 加载中，请稍候再试')); return }
    const lines = []
    window.Sk.configure({
      output: (text) => lines.push(escHtml(text)),
      read: (x) => {
        if (window.Sk.builtinFiles?.files[x] === undefined) throw new Error(`文件未找到: ${x}`)
        return window.Sk.builtinFiles.files[x]
      },
      inputfun: () => Promise.resolve(stdinInput.value || ''),
      __future__: window.Sk.python3,
    })
    window.Sk.misceval.asyncToPromise(() =>
      window.Sk.importMainWithBody('<stdin>', false, code, true)
    ).then(() => {
      resolve({ lines, exit: 0 })
    }).catch((e) => {
      const msg = e.toString ? e.toString() : String(e)
      resolve({ lines: [...lines, `<span style="color:#ff6b6b">${escHtml(msg)}</span>`], exit: 1 })
    })
  })
}

// ── Main run ──────────────────────────────────────────────────────────────────
async function runCode() {
  if (running) return
  const lang = currentLang

  if (lang.engine === 'playground') {
    const url = lang.playgroundUrl + (lang.playgroundUrl.endsWith('/') ? '' : encodeURIComponent(editor.value))
    window.open(url, '_blank')
    return
  }

  running = true
  clearOutput()
  runBtn.disabled = true
  setStatus('⟳ Running...', '#ffa500')
  const t0 = Date.now()

  try {
    let result
    if (lang.engine === 'js')         result = await runJS(editor.value)
    else if (lang.engine === 'typescript') result = await runTS(editor.value)
    else if (lang.engine === 'python') result = await runPython(editor.value)

    const elapsed = Date.now() - t0
    if (result.lines.length) {
      output.innerHTML = result.lines.join('')
    } else {
      output.innerHTML = '<span style="color:rgba(136,136,170,0.4)">(no output)</span>'
    }
    execTime.textContent = `exit ${result.exit} · ${elapsed}ms`
    setStatus(result.exit === 0 ? '✓ OK' : '✕ Error', result.exit === 0 ? '#39ff14' : '#ff4466')
  } catch (e) {
    output.innerHTML = `<span style="color:#ff6b6b">${escHtml(e.message)}</span>`
    setStatus('✕ Failed', '#ff4466')
  }

  running = false
  runBtn.disabled = false
}

function setStatus(text, color) {
  runStatus.textContent = text
  runStatus.style.color = color
}

function clearOutput() {
  output.innerHTML = ''
  execTime.textContent = ''
  runStatus.textContent = ''
}

function escHtml(s) {
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
}

// ── Editor utilities ──────────────────────────────────────────────────────────
function updateLineNumbers() {
  const lines = (editor.value.match(/\n/g) || []).length + 1
  lineNums.innerHTML = Array.from({ length: lines }, (_, i) => i + 1).join('\n')
}

editor.addEventListener('input', updateLineNumbers)
editor.addEventListener('scroll', () => { lineNums.scrollTop = editor.scrollTop })
editor.addEventListener('keydown', (e) => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); runCode(); return }
  if (e.key === 'Tab') {
    e.preventDefault()
    const s = editor.selectionStart, en = editor.selectionEnd
    editor.value = editor.value.substring(0, s) + '  ' + editor.value.substring(en)
    editor.selectionStart = editor.selectionEnd = s + 2
    updateLineNumbers()
  }
})

runBtn.onclick = runCode
document.getElementById('clear-btn').onclick = clearOutput
document.getElementById('copy-btn').onclick = () => {
  navigator.clipboard.writeText(editor.value).then(() => {
    const btn = document.getElementById('copy-btn')
    btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 1500)
  })
}

// Update playground link when editor changes
editor.addEventListener('input', () => {
  if (currentLang.engine === 'playground' && currentLang.playgroundUrl) {
    pgLink.href = currentLang.playgroundUrl + (currentLang.playgroundUrl.endsWith('/') ? '' : encodeURIComponent(editor.value))
  }
})

// ── Init ──────────────────────────────────────────────────────────────────────
renderLangList()
// Preload JS is always ready; preload Python/TS on first selection
loadSkulpt()   // start loading early
loadBabel()

})
  </script>
</BaseLayout>
