    { name:'推导式',  code:`m=[[i*j for j in range(1,6)] for i in range(1,6)]\nfor r in m: print(" ".join(f"{v:3}" for v in r))\nflat=[x for r in m for x in r if x%2==0]\nprint("even:",flat[:8])` },
  ],
