    { name:'装饰器',  code:`import time\ndef timer(fn):\n    def w(*a,**k):\n        t=time.time()\n        r=fn(*a,**k)\n        print(f"{fn.__name__} took {time.time()-t:.4f}s")\n        return r\n    return w\n@timer\ndef s(n): return sum(range(n))\nprint(s(1000000))` },
