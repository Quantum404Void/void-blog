---
import BaseLayout from '../../../layouts/BaseLayout.astro'
---
<BaseLayout title="Cron 解析 | void.dev">
  <div class="min-h-screen" style="background:var(--color-void);font-family:var(--font-mono)">
    <nav class="px-6 py-4 border-b" style="border-color:var(--color-void-border);color:var(--color-text-secondary)">
      <span style="color:#ffa500">❯</span>
      <a href="/void-blog/lab/" style="color:var(--color-text-secondary);text-decoration:none" onmouseover="this.style.color='#ffa500'" onmouseout="this.style.color='var(--color-text-secondary)'">~/lab</a>
      <span class="mx-2">/</span>
      <span style="color:#ffa500">cron</span>
    </nav>

    <div class="p-6 max-w-4xl mx-auto">
      <h1 class="text-2xl font-bold mb-2" style="color:#ffa500;text-shadow:0 0 20px rgba(255,165,0,0.6)">
        ⏰ Cron 解析
      </h1>
      <p class="mb-6 text-sm" style="color:var(--color-text-muted)">Cron 表达式解析 · 下次执行时间预测</p>

      <!-- Presets -->
      <div class="mb-4 flex flex-wrap gap-2">
        <span class="text-xs self-center mr-1" style="color:var(--color-text-muted)">预设：</span>
        <button class="preset-btn" onclick="setExpr('* * * * *')">每分钟</button>
        <button class="preset-btn" onclick="setExpr('0 * * * *')">每小时</button>
        <button class="preset-btn" onclick="setExpr('0 9 * * *')">每天早上9点</button>
        <button class="preset-btn" onclick="setExpr('0 9 * * 1')">每周一早上</button>
        <button class="preset-btn" onclick="setExpr('0 9 1 * *')">每月1号</button>
        <button class="preset-btn" onclick="setExpr('*/5 * * * *')">每5分钟</button>
      </div>

      <!-- Input -->
      <div class="mb-6">
        <div class="flex gap-3 items-center">
          <input id="cron-input" type="text" value="0 9 * * *"
            class="flex-1 px-4 py-3 rounded-lg text-sm outline-none font-mono tracking-widest"
            style="background:var(--color-void-card);border:1px solid rgba(255,165,0,0.4);color:var(--color-text-primary);caret-color:#ffa500;font-size:18px;letter-spacing:0.15em"
            oninput="parseCron()" />
        </div>
        <!-- Field labels -->
        <div class="flex gap-3 mt-2 px-1">
          <span class="text-xs" style="color:rgba(255,165,0,0.6);flex:1;text-align:center">分钟</span>
          <span class="text-xs" style="color:rgba(255,165,0,0.6);flex:1;text-align:center">小时</span>
          <span class="text-xs" style="color:rgba(255,165,0,0.6);flex:1;text-align:center">日</span>
          <span class="text-xs" style="color:rgba(255,165,0,0.6);flex:1;text-align:center">月</span>
          <span class="text-xs" style="color:rgba(255,165,0,0.6);flex:1;text-align:center">周</span>
        </div>
      </div>

      <div id="cron-error" class="hidden mb-4 px-4 py-2 rounded text-sm" style="background:rgba(255,0,0,0.1);color:#ff6b6b;border:1px solid rgba(255,0,0,0.2)"></div>

      <!-- Results -->
      <div id="cron-result" class="space-y-4">
        <!-- Description -->
        <div class="px-5 py-4 rounded-xl" style="background:rgba(255,165,0,0.07);border:1px solid rgba(255,165,0,0.2)">
          <p class="text-xs mb-1" style="color:rgba(255,165,0,0.6)">执行描述</p>
          <p id="cron-desc" class="text-lg font-bold" style="color:#ffa500">-</p>
        </div>

        <!-- Field breakdown -->
        <div>
          <p class="text-xs mb-3" style="color:var(--color-text-muted)">字段解析</p>
          <div class="grid grid-cols-1 sm:grid-cols-5 gap-2" id="field-breakdown"></div>
        </div>

        <!-- Next executions -->
        <div>
          <p class="text-xs mb-3" style="color:var(--color-text-muted)">下次 5 次执行时间</p>
          <div id="next-times" class="space-y-2"></div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .preset-btn {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 5px 12px;
      border-radius: 5px;
      border: 1px solid rgba(255,165,0,0.25);
      color: rgba(255,165,0,0.8);
      background: transparent;
      cursor: pointer;
      transition: all 0.15s;
    }
    .preset-btn:hover {
      border-color: rgba(255,165,0,0.6);
      background: rgba(255,165,0,0.08);
      color: #ffa500;
    }
    .field-card {
      padding: 10px 12px;
      border-radius: 8px;
      background: var(--color-void-card);
      border: 1px solid rgba(255,165,0,0.15);
      text-align: center;
    }
  </style>

  <script is:inline>
    function setExpr(expr) {
      document.getElementById('cron-input').value = expr
      parseCron()
    }

    function parseField(val, min, max) {
      if (val === '*') return Array.from({length: max - min + 1}, (_, i) => i + min)
      if (val.includes('/')) {
        const [range, step] = val.split('/')
        const start = range === '*' ? min : parseInt(range)
        const result = []
        for (let i = start; i <= max; i += parseInt(step)) result.push(i)
        return result
      }
      if (val.includes(',')) return val.split(',').map(Number)
      if (val.includes('-')) {
        const [a, b] = val.split('-').map(Number)
        return Array.from({length: b - a + 1}, (_, i) => i + a)
      }
      return [parseInt(val)]
    }

    function validateField(val, min, max) {
      try {
        const arr = parseField(val, min, max)
        return arr.every(n => !isNaN(n) && n >= min && n <= max)
      } catch(e) { return false }
    }

    function nextExecutions(expr, count = 5) {
      const parts = expr.trim().split(/\s+/)
      if (parts.length !== 5) return []
      const [min, hour, dom, month, dow] = parts
      const mins = parseField(min, 0, 59)
      const hours = parseField(hour, 0, 23)
      const doms = parseField(dom, 1, 31)
      const months = parseField(month, 1, 12)
      const dows = parseField(dow, 0, 6)

      const results = []
      const now = new Date()
      now.setSeconds(0, 0)
      now.setMinutes(now.getMinutes() + 1)

      for (let i = 0; i < 366 * 24 * 60 && results.length < count; i++) {
        const d = new Date(now.getTime() + i * 60000)
        if (
          months.includes(d.getMonth() + 1) &&
          doms.includes(d.getDate()) &&
          dows.includes(d.getDay()) &&
          hours.includes(d.getHours()) &&
          mins.includes(d.getMinutes())
        ) {
          results.push(new Date(d))
        }
      }
      return results
    }

    function describeField(val, type) {
      if (val === '*') return `每${type}`
      if (val.startsWith('*/')) return `每 ${val.slice(2)} 个${type}`
      if (val.includes('-')) return `${val}（范围）`
      if (val.includes(',')) return val
      return val
    }

    function describeWeekday(n) {
      return ['周日','周一','周二','周三','周四','周五','周六'][n] || n
    }

    function describeCron(expr) {
      const parts = expr.trim().split(/\s+/)
      if (parts.length !== 5) return '无效表达式'
      const [min, hour, dom, month, dow] = parts

      if (min === '*' && hour === '*' && dom === '*' && month === '*' && dow === '*')
        return '每分钟执行'
      if (min.startsWith('*/') && hour === '*' && dom === '*' && month === '*' && dow === '*')
        return `每 ${min.slice(2)} 分钟执行`
      if (hour === '*' && dom === '*' && month === '*' && dow === '*')
        return `每小时第 ${min} 分钟执行`
      if (dom === '*' && month === '*' && dow === '*')
        return `每天 ${hour.padStart(2,'0')}:${min.padStart(2,'0')} 执行`
      if (dom === '*' && month === '*' && dow !== '*') {
        const days = parseField(dow, 0, 6).map(describeWeekday).join('、')
        return `每${days} ${hour.padStart(2,'0')}:${min.padStart(2,'0')} 执行`
      }
      if (dom !== '*' && month === '*' && dow === '*')
        return `每月 ${dom} 号 ${hour.padStart(2,'0')}:${min.padStart(2,'0')} 执行`
      if (dom !== '*' && month !== '*' && dow === '*')
        return `每年 ${month} 月 ${dom} 号 ${hour.padStart(2,'0')}:${min.padStart(2,'0')} 执行`

      return expr
    }

    function parseCron() {
      const expr = document.getElementById('cron-input').value.trim()
      const errEl = document.getElementById('cron-error')
      const parts = expr.split(/\s+/)

      if (!expr) { errEl.classList.add('hidden'); resetResult(); return }

      if (parts.length !== 5) {
        errEl.textContent = '需要 5 个字段：分 时 日 月 周'
        errEl.classList.remove('hidden')
        resetResult()
        return
      }

      const [min, hour, dom, month, dow] = parts
      const valid = [
        validateField(min, 0, 59),
        validateField(hour, 0, 23),
        validateField(dom, 1, 31),
        validateField(month, 1, 12),
        validateField(dow, 0, 6),
      ]
      const labels = ['分钟(0-59)', '小时(0-23)', '日(1-31)', '月(1-12)', '周(0-6)']
      const badIdx = valid.indexOf(false)
      if (badIdx !== -1) {
        errEl.textContent = `字段 "${labels[badIdx]}" 值无效`
        errEl.classList.remove('hidden')
        resetResult()
        return
      }
      errEl.classList.add('hidden')

      // Description
      document.getElementById('cron-desc').textContent = describeCron(expr)

      // Field breakdown
      const fieldDefs = [
        { label: '分钟', val: min, min: 0, max: 59 },
        { label: '小时', val: hour, min: 0, max: 23 },
        { label: '日', val: dom, min: 1, max: 31 },
        { label: '月', val: month, min: 1, max: 12 },
        { label: '周', val: dow, min: 0, max: 6 },
      ]
      document.getElementById('field-breakdown').innerHTML = fieldDefs.map(f => {
        const vals = parseField(f.val, f.min, f.max)
        const preview = vals.length > 8 ? vals.slice(0, 8).join(', ') + '…' : vals.join(', ')
        return `<div class="field-card">
          <div style="font-size:10px;color:rgba(255,165,0,0.6);margin-bottom:4px">${f.label}</div>
          <div style="font-size:14px;color:#ffa500;font-weight:bold">${f.val}</div>
          <div style="font-size:10px;color:var(--color-text-muted);margin-top:4px">${preview}</div>
        </div>`
      }).join('')

      // Next times
      const nexts = nextExecutions(expr)
      const weekNames = ['周日','周一','周二','周三','周四','周五','周六']
      document.getElementById('next-times').innerHTML = nexts.length
        ? nexts.map((d, i) => {
            const pad = n => String(n).padStart(2, '0')
            const str = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())} ${weekNames[d.getDay()]}`
            return `<div style="display:flex;align-items:center;gap:10px;padding:8px 14px;border-radius:8px;background:var(--color-void-card);border:1px solid rgba(255,165,0,0.12)">
              <span style="font-size:10px;color:rgba(255,165,0,0.5);min-width:16px">+${i+1}</span>
              <span style="font-size:13px;color:var(--color-text-primary)">${str}</span>
            </div>`
          }).join('')
        : '<div style="color:var(--color-text-muted);font-size:13px">未找到执行时间（可能超出一年范围）</div>'
    }

    function resetResult() {
      document.getElementById('cron-desc').textContent = '-'
      document.getElementById('field-breakdown').innerHTML = ''
      document.getElementById('next-times').innerHTML = ''
    }

    // Init
    parseCron()
  </script>
</BaseLayout>
