---
import BaseLayout from '../../layouts/BaseLayout.astro'
---
<BaseLayout title="Matrix Rain | void.dev">
  <div style="margin:0;padding:0;overflow:hidden;background:#000;height:100vh;width:100vw;position:relative">
    <!-- Nav overlay -->
    <div style="position:fixed;top:0;left:0;right:0;z-index:50;display:flex;align-items:center;padding:0 1.5rem;height:3rem;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);border-bottom:1px solid rgba(0,255,65,0.15);font-family:'JetBrains Mono',monospace;font-size:12px;gap:1rem">
      <a href="/lab/" style="color:rgba(0,255,65,0.8);text-decoration:none">~/lab</a>
      <span style="color:rgba(255,255,255,0.2)">/</span>
      <span style="color:rgba(0,212,255,0.8)">matrix</span>
      <div style="margin-left:auto;display:flex;align-items:center;gap:1rem">
        <span id="fps-badge" style="color:rgba(0,255,65,0.5);font-size:10px">-- fps</span>
        <span id="theme-name" style="color:rgba(0,255,65,0.7);font-size:10px">GREEN</span>
      </div>
    </div>

    <canvas id="mc" style="display:block;width:100vw;height:100vh;cursor:crosshair"></canvas>

    <!-- Controls panel (bottom) -->
    <div style="position:fixed;bottom:1rem;left:50%;transform:translateX(-50%);z-index:50;display:flex;align-items:center;gap:0.75rem;padding:0.5rem 1rem;background:rgba(0,0,0,0.75);border:1px solid rgba(0,255,65,0.2);border-radius:10px;backdrop-filter:blur(10px);font-family:'JetBrains Mono',monospace;font-size:11px;white-space:nowrap">
      <!-- Theme -->
      <button id="btn-theme" title="切换主题 T" style="padding:4px 10px;border:1px solid rgba(0,255,65,0.3);border-radius:6px;background:transparent;color:rgba(0,255,65,0.8);cursor:pointer">🎨</button>
      <!-- Pause -->
      <button id="btn-pause" title="暂停 Space" style="padding:4px 10px;border:1px solid rgba(0,212,255,0.3);border-radius:6px;background:transparent;color:rgba(0,212,255,0.8);cursor:pointer">⏸</button>
      <!-- Speed -->
      <div style="display:flex;align-items:center;gap:0.4rem;color:rgba(255,255,255,0.4)">
        速度
        <input id="speed-slider" type="range" min="0.2" max="4" step="0.1" value="1" style="width:70px;accent-color:#00ff41;cursor:pointer">
        <span id="speed-val" style="color:rgba(0,255,65,0.8);min-width:2ch">1x</span>
      </div>
      <!-- Font size -->
      <div style="display:flex;align-items:center;gap:0.4rem;color:rgba(255,255,255,0.4)">
        字号
        <input id="size-slider" type="range" min="8" max="28" step="2" value="14" style="width:60px;accent-color:#00d4ff;cursor:pointer">
        <span id="size-val" style="color:rgba(0,212,255,0.8);min-width:2ch">14</span>
      </div>
      <!-- Density -->
      <div style="display:flex;align-items:center;gap:0.4rem;color:rgba(255,255,255,0.4)">
        密度
        <input id="density-slider" type="range" min="0.1" max="1" step="0.05" value="0.6" style="width:60px;accent-color:#b400ff;cursor:pointer">
      </div>
      <!-- Fullscreen -->
      <button id="btn-fs" title="全屏 F" style="padding:4px 10px;border:1px solid rgba(180,0,255,0.3);border-radius:6px;background:transparent;color:rgba(180,0,255,0.8);cursor:pointer">⛶</button>
    </div>

    <!-- Click ripple info -->
    <div id="click-info" style="position:fixed;top:3.5rem;right:1rem;z-index:50;font-family:'JetBrains Mono',monospace;font-size:10px;color:rgba(0,255,65,0.5);opacity:0;transition:opacity 0.5s;pointer-events:none">点击产生涟漪</div>
  </div>

  <script>
    const canvas = document.getElementById('mc') as HTMLCanvasElement
    const ctx = canvas.getContext('2d')!
    const fpsEl = document.getElementById('fps-badge')!
    const themeNameEl = document.getElementById('theme-name')!
    const speedSlider = document.getElementById('speed-slider') as HTMLInputElement
    const sizeSlider = document.getElementById('size-slider') as HTMLInputElement
    const densitySlider = document.getElementById('density-slider') as HTMLInputElement
    const speedVal = document.getElementById('speed-val')!
    const sizeVal = document.getElementById('size-val')!

    const THEMES = [
      { name:'GREEN',  fg:'#00ff41', head:'#ffffff', bg:'rgba(0,0,0,0.055)', glow:'#00ff41',
        chars:'アイウエオカキクケコサシスセソタチツテトナニヌネノ0123456789<>{}[]/\\|' },
      { name:'CYAN',   fg:'#00d4ff', head:'#aaffff', bg:'rgba(0,5,12,0.055)', glow:'#00d4ff',
        chars:'01 function const let => {} () if else for while return import export async await' },
      { name:'PURPLE', fg:'#b400ff', head:'#ffaaff', bg:'rgba(4,0,10,0.055)', glow:'#b400ff',
        chars:'▓▒░█▄▀■□●○◆◇★☆♦♣♠♥01010110' },
      { name:'PINK',   fg:'#ff00aa', head:'#ffaaee', bg:'rgba(12,0,6,0.055)', glow:'#ff00aa',
        chars:'你好世界代码编程算法系统网络数据结构递归迭代循环函数变量指针内存堆栈' },
      { name:'GOLD',   fg:'#ffaa00', head:'#ffffff', bg:'rgba(8,5,0,0.055)', glow:'#ffaa00',
        chars:'#!/usr/bin/env bash echo grep sed awk find chmod sudo apt git npm bun' },
    ]
    let themeIdx = 0
    let fontSize = 14
    let speedMult = 1
    let density = 0.6
    let paused = false
    let cols = 0
    let drops: number[] = []
    let colSpeeds: number[] = []
    let ripples: {x:number,y:number,r:number,life:number}[] = []
    let frameCount = 0, fpsAcc = 0, lastTs = 0
    let rafId = 0

    function resize() {
      canvas.width = window.innerWidth
      canvas.height = window.innerHeight
      initCols()
    }

    function initCols() {
      const t = THEMES[themeIdx]
      cols = Math.floor(canvas.width / fontSize)
      drops = Array.from({length: cols}, (_, i) => Math.random() < density ? Math.random() * -(canvas.height / fontSize) : Math.random() * -50)
      colSpeeds = Array.from({length: cols}, () => 0.3 + Math.random() * 0.7)
    }

    function frame(ts: number) {
      rafId = requestAnimationFrame(frame)
      const dt = Math.min(ts - lastTs, 100)
      lastTs = ts

      // FPS
      frameCount++; fpsAcc += dt
      if (fpsAcc >= 800) {
        fpsEl.textContent = Math.round(frameCount / (fpsAcc/1000)) + ' fps'
        frameCount = 0; fpsAcc = 0
      }

      if (paused) return
      const t = THEMES[themeIdx]

      // Background fade
      ctx.fillStyle = t.bg
      ctx.fillRect(0, 0, canvas.width, canvas.height)

      ctx.font = `bold ${fontSize}px 'JetBrains Mono', monospace`

      for (let i = 0; i < cols; i++) {
        const x = i * fontSize
        const y = drops[i] * fontSize

        const ch = t.chars[Math.floor(Math.random() * t.chars.length)]

        // Head: bright white
        ctx.shadowBlur = 10
        ctx.shadowColor = t.glow
        ctx.fillStyle = t.head
        ctx.fillText(ch, x, y)

        // Second char: dim
        if (drops[i] > 1) {
          ctx.shadowBlur = 3
          ctx.fillStyle = t.fg
          const ch2 = t.chars[Math.floor(Math.random() * t.chars.length)]
          ctx.fillText(ch2, x, y - fontSize)
        }

        drops[i] += colSpeeds[i] * speedMult * (dt / 16)

        if (y > canvas.height && Math.random() > (1 - 0.03 * density)) {
          drops[i] = Math.random() * -30
        }
      }

      // Ripples
      ctx.shadowBlur = 0
      for (let i = ripples.length - 1; i >= 0; i--) {
        const r = ripples[i]
        r.r += 4 * speedMult
        r.life -= 0.025
        if (r.life <= 0) { ripples.splice(i, 1); continue }
        ctx.save()
        ctx.globalAlpha = r.life * 0.6
        ctx.strokeStyle = t.fg
        ctx.lineWidth = 2
        ctx.shadowBlur = 8; ctx.shadowColor = t.glow
        ctx.beginPath(); ctx.arc(r.x, r.y, r.r, 0, Math.PI*2); ctx.stroke()
        // inner ring
        if (r.r > 20) {
          ctx.globalAlpha = r.life * 0.3
          ctx.beginPath(); ctx.arc(r.x, r.y, r.r * 0.6, 0, Math.PI*2); ctx.stroke()
        }
        ctx.restore()
        // blast columns in ripple area
        for (let c = 0; c < cols; c++) {
          const cx = c * fontSize + fontSize/2
          const dist = Math.abs(cx - r.x)
          if (dist < r.r && dist > r.r - fontSize * 2) {
            drops[c] = Math.max(drops[c] - 2, -5)
          }
        }
      }
    }

    // Events
    canvas.addEventListener('click', (e) => {
      ripples.push({x: e.clientX, y: e.clientY, r: 0, life: 1})
      // show hint on first click
      const hint = document.getElementById('click-info')!
      hint.style.opacity = '0'
    })

    canvas.addEventListener('mousemove', (e) => {
      // subtle column boost near cursor
      const colIdx = Math.floor(e.clientX / fontSize)
      if (colIdx >= 0 && colIdx < cols) {
        drops[colIdx] = Math.min(drops[colIdx] + 0.3, canvas.height / fontSize + 5)
      }
    })

    document.getElementById('btn-theme')!.addEventListener('click', nextTheme)
    document.getElementById('btn-pause')!.addEventListener('click', () => {
      paused = !paused
      ;(document.getElementById('btn-pause') as HTMLButtonElement).textContent = paused ? '▶' : '⏸'
    })
    document.getElementById('btn-fs')!.addEventListener('click', () => {
      if (!document.fullscreenElement) document.documentElement.requestFullscreen()
      else document.exitFullscreen()
    })

    speedSlider.addEventListener('input', () => {
      speedMult = parseFloat(speedSlider.value)
      speedVal.textContent = speedMult.toFixed(1) + 'x'
    })
    sizeSlider.addEventListener('input', () => {
      fontSize = parseInt(sizeSlider.value)
      sizeVal.textContent = String(fontSize)
      initCols()
    })
    densitySlider.addEventListener('input', () => {
      density = parseFloat(densitySlider.value)
      initCols()
    })

    function nextTheme() {
      themeIdx = (themeIdx + 1) % THEMES.length
      themeNameEl.textContent = THEMES[themeIdx].name
      themeNameEl.style.color = THEMES[themeIdx].fg
      ctx.clearRect(0, 0, canvas.width, canvas.height)
    }

    document.addEventListener('keydown', e => {
      const tag = (e.target as Element)?.tagName
      if (tag === 'INPUT') return
      if (e.key === ' ') { e.preventDefault(); document.getElementById('btn-pause')!.click() }
      if (e.key === 't' || e.key === 'T') nextTheme()
      if (e.key === 'f' || e.key === 'F') document.getElementById('btn-fs')!.click()
      if (e.key === 'ArrowRight') { speedMult = Math.min(4, speedMult + 0.2); speedSlider.value = String(speedMult); speedVal.textContent = speedMult.toFixed(1)+'x' }
      if (e.key === 'ArrowLeft')  { speedMult = Math.max(0.2, speedMult - 0.2); speedSlider.value = String(speedMult); speedVal.textContent = speedMult.toFixed(1)+'x' }
    })

    window.addEventListener('resize', resize)

    // Show click hint
    setTimeout(() => { document.getElementById('click-info')!.style.opacity = '1' }, 1500)
    setTimeout(() => { document.getElementById('click-info')!.style.opacity = '0' }, 5000)

    resize()
    requestAnimationFrame(frame)
  </script>
</BaseLayout>
