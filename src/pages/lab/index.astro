---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="Lab | void.dev">
  <div class="min-h-screen bg-[var(--color-void)]">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.85)] backdrop-blur-xl">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8">
        <a href="/void-blog/" class="font-mono font-bold text-[var(--color-neon-green)] text-sm tracking-widest">void.dev</a>
        <div class="ml-auto flex items-center gap-5 text-xs font-mono text-[var(--color-text-muted)]">
          <a href="/void-blog/blog/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/blog</a>
          <a href="/void-blog/stats/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/stats</a>
          <span class="text-[rgba(180,0,255,0.9)]">~/lab</span>
        </div>
      </div>
    </nav>

    <div class="max-w-5xl mx-auto px-6 py-14">
      <div class="mb-12">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] tracking-[0.25em] uppercase mb-3">interactive_lab</p>
        <h1 class="font-mono text-4xl font-bold text-[var(--color-text-primary)] mb-2" style="text-shadow:0 0 30px rgba(180,0,255,0.2)">
          <span style="color:rgba(180,0,255,0.9)">~/</span>lab
        </h1>
        <p class="font-mono text-sm text-[var(--color-text-muted)]">技术宅的实验室 — 游戏、工具、可视化</p>
      <div class="flex gap-6 mt-4 font-mono text-xs text-[var(--color-text-muted)]">
        <span><span style="color:rgba(180,0,255,0.9)">9</span> 游戏</span>
        <span><span style="color:rgba(0,212,255,0.9)">12</span> 工具</span>
        <span><span style="color:rgba(57,255,20,0.9)">∞</span> 折腾</span>
      </div>
      </div>

      <!-- GAMES -->
      <section class="mb-12">
        <h2 class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-[0.2em] mb-5 flex items-center gap-3">
          <span class="text-[rgba(180,0,255,0.8)]">▶</span> 游戏
          <span class="flex-1 h-px bg-gradient-to-r from-[rgba(180,0,255,0.3)] to-transparent"></span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {[
            {href:'/void-blog/lab/snake/', icon:'🐍', label:'Snake', desc:'霓虹贪吃蛇', tag:'CLASSIC', color:'#39ff14'},
            {href:'/void-blog/lab/matrix/', icon:'🌧️', label:'Matrix Rain', desc:'数字雨可视化', tag:'VISUAL', color:'#00d4ff'},
            {href:'/void-blog/lab/typing/', icon:'⌨️', label:'Code Typing', desc:'代码打字测速', tag:'SKILL', color:'#ff00aa'},
            {href:'/void-blog/lab/sort/', icon:'📊', label:'Sort Visualizer', desc:'9 种排序动画', tag:'ALGO', color:'#b400ff'},
            {href:'/void-blog/lab/2048/', icon:'🔢', label:'2048', desc:'数字合并游戏，霓虹重制版', tag:'CLASSIC', color:'#ffa500'},
            {href:'/void-blog/lab/minesweeper/', icon:'💣', label:'Minesweeper', desc:'扫雷，终端 ASCII 风格', tag:'CLASSIC', color:'#ff00aa'},
            {href:'/void-blog/lab/tetris/', icon:'🧩', label:'Tetris', desc:'经典俄罗斯方块，霓虹重制', tag:'CLASSIC', color:'#b400ff'},
            {href:'/void-blog/lab/wordle/', icon:'📝', label:'Wordle', desc:'5字母猜词游戏，代码词库版', tag:'WORD', color:'#39ff14'},
            {href:'/void-blog/lab/flappy/', icon:'🐦', label:'Flappy Bird', desc:'赛博朋克风霓虹管道', tag:'CASUAL', color:'#ffa500'},
          ].map(({href, icon, label, desc, tag, color}) => (
            <a href={href} class="group block border border-[var(--color-void-border)] rounded-xl p-5 bg-[var(--color-void-card)] transition-all hover:translate-y-[-2px]"
              style={`--hc:${color}`}
              onmouseover={`this.style.borderColor='${color}55';this.style.boxShadow='0 8px 32px ${color}18'`}
              onmouseout="this.style.borderColor='';this.style.boxShadow=''">
              <div class="flex items-start justify-between mb-3">
                <span class="text-2xl">{icon}</span>
                <span class="font-mono text-[9px] px-2 py-0.5 rounded-full border" style={`border-color:${color}44;color:${color}cc`}>{tag}</span>
              </div>
              <h3 class="font-mono text-sm font-bold text-[var(--color-text-primary)] mb-1 group-hover:transition-colors" style={`transition:color 0.2s`} onmouseover={`this.style.color='${color}'`} onmouseout="this.style.color=''">{label}</h3>
              <p class="font-mono text-[11px] text-[var(--color-text-muted)]">{desc}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- TOOLS -->
      <section>
        <h2 class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-[0.2em] mb-5 flex items-center gap-3">
          <span class="text-[var(--color-neon-cyan)]">▶</span> 在线工具
          <span class="flex-1 h-px bg-gradient-to-r from-[rgba(0,212,255,0.3)] to-transparent"></span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {[
            {href:'/void-blog/lab/tools/compiler/', icon:'▶', label:'JS/HTML 运行器', desc:'浏览器端 JavaScript 和 HTML 实时运行', tag:'RUN', color:'#39ff14'},
            {href:'/void-blog/lab/tools/json/', icon:'{ }', label:'JSON 格式化', desc:'格式化 / 压缩 / 校验 JSON', tag:'FORMAT', color:'#00d4ff'},
            {href:'/void-blog/lab/tools/regex/', icon:'.*', label:'正则测试器', desc:'实时匹配 + 高亮 + 分组提取', tag:'REGEX', color:'#39ff14'},
            {href:'/void-blog/lab/tools/base64/', icon:'64', label:'Base64', desc:'编码 / 解码 / 文件转换', tag:'ENCODE', color:'#ff00aa'},
            {href:'/void-blog/lab/tools/timestamp/', icon:'⏱', label:'时间戳转换', desc:'Unix 时间戳 ↔ 日期时间', tag:'TIME', color:'#ffa500'},
            {href:'/void-blog/lab/tools/color/', icon:'🎨', label:'颜色工具', desc:'HEX / RGB / HSL 互转 + 调色板', tag:'COLOR', color:'#b400ff'},
            {href:'/void-blog/lab/tools/hash/', icon:'#', label:'哈希计算', desc:'MD5 / SHA1 / SHA256 在线计算', tag:'CRYPTO', color:'#00d4ff'},
            {href:'/void-blog/lab/tools/url/', icon:'🔗', label:'URL 工具', desc:'URL 解析/编解码/构建', tag:'NET', color:'#00d4ff'},
            {href:'/void-blog/lab/tools/cron/', icon:'⏰', label:'Cron 解析', desc:'Cron 表达式解析 + 下次执行时间', tag:'TIME', color:'#ffa500'},
            {href:'/void-blog/lab/tools/diff/', icon:'±', label:'Diff 对比', desc:'两段文本逐行差异对比', tag:'TEXT', color:'#39ff14'},
            {href:'/void-blog/lab/tools/ascii/', icon:'Aa', label:'ASCII Art', desc:'文字转 ASCII 艺术字', tag:'ART', color:'#39ff14'},
            {href:'/void-blog/lab/tools/baseconv/', icon:'0x', label:'进制转换', desc:'2/8/10/16 进制互转 + 位运算', tag:'BITS', color:'#00d4ff'},
          ].map(({href, icon, label, desc, tag, color}) => (
            <a href={href} class="group block border border-[var(--color-void-border)] rounded-xl p-5 bg-[var(--color-void-card)] transition-all hover:translate-y-[-2px]"
              onmouseover={`this.style.borderColor='${color}44';this.style.boxShadow='0 6px 24px ${color}12'`}
              onmouseout="this.style.borderColor='';this.style.boxShadow=''">
              <div class="flex items-start justify-between mb-3">
                <span class="font-mono text-xl font-bold" style={`color:${color};text-shadow:0 0 12px ${color}66`}>{icon}</span>
                <span class="font-mono text-[9px] px-2 py-0.5 rounded-full border" style={`border-color:${color}44;color:${color}cc`}>{tag}</span>
              </div>
              <h3 class="font-mono text-sm font-bold text-[var(--color-text-primary)] mb-1 transition-colors">{label}</h3>
              <p class="font-mono text-[11px] text-[var(--color-text-muted)]">{desc}</p>
            </a>
          ))}
        </div>
      </section>

      <div class="mt-12 text-center font-mono text-[10px] text-[var(--color-text-muted)] opacity-30 select-none">
        ↑↑↓↓←→←→BA
      </div>
    </div>
  </div>
</BaseLayout>
