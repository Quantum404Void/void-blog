---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="2048 | void.dev">
  <div class="min-h-screen bg-[var(--color-void)]">
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.85)] backdrop-blur-xl">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center gap-8">
        <a href="/void-blog/" class="font-mono font-bold text-[var(--color-neon-green)] text-sm tracking-widest">void.dev</a>
        <div class="ml-auto flex items-center gap-2 text-xs font-mono text-[var(--color-text-muted)]">
          <a href="/void-blog/lab/" class="hover:text-[var(--color-neon-cyan)] transition-colors">~/lab</a>
          <span class="opacity-40">/</span>
          <span class="text-[rgba(255,165,0,0.9)]">2048</span>
        </div>
      </div>
    </nav>

    <div class="max-w-5xl mx-auto px-6 py-10">
      <div class="mb-8 text-center">
        <h1 class="font-mono text-4xl font-bold text-[var(--color-text-primary)] mb-2">
          <span class="text-[rgba(255,165,0,0.9)]">2048</span>
        </h1>
        <p class="font-mono text-sm text-[var(--color-text-muted)]">数字合并游戏 — 合并到 2048 赢得胜利</p>
      </div>

      <!-- Score Row -->
      <div class="flex items-center justify-center gap-6 mb-6">
        <div class="font-mono text-center border border-[rgba(255,165,0,0.3)] rounded-xl px-6 py-3 bg-[var(--color-void-card)]">
          <div class="text-[10px] text-[var(--color-text-muted)] tracking-widest uppercase mb-1">Score</div>
          <div id="score" class="text-2xl font-bold text-[rgba(255,165,0,0.9)]">0</div>
        </div>
        <div class="font-mono text-center border border-[rgba(255,165,0,0.3)] rounded-xl px-6 py-3 bg-[var(--color-void-card)]">
          <div class="text-[10px] text-[var(--color-text-muted)] tracking-widest uppercase mb-1">Best</div>
          <div id="best" class="text-2xl font-bold text-[rgba(255,165,0,0.9)]">0</div>
        </div>
        <button id="newGame" class="font-mono text-sm px-6 py-3 rounded-xl border border-[rgba(255,165,0,0.4)] text-[rgba(255,165,0,0.9)] hover:bg-[rgba(255,165,0,0.1)] transition-colors">
          New Game
        </button>
      </div>

      <!-- Game Board -->
      <div class="flex justify-center">
        <div id="board-wrapper" class="relative" style="touch-action:none">
          <div id="board" class="grid gap-3 p-3 rounded-2xl bg-[rgba(255,165,0,0.08)] border border-[rgba(255,165,0,0.2)]"
            style="grid-template-columns:repeat(4,100px);grid-template-rows:repeat(4,100px)">
          </div>
          <!-- Overlay messages -->
          <div id="overlay" class="hidden absolute inset-0 rounded-2xl flex items-center justify-center bg-[rgba(10,10,15,0.85)] backdrop-blur-sm">
            <div class="text-center">
              <div id="overlay-msg" class="font-mono text-3xl font-bold mb-4"></div>
              <button onclick="document.getElementById('overlay').classList.add('hidden');window._2048.init()" 
                class="font-mono text-sm px-6 py-2 rounded-xl border border-[rgba(255,165,0,0.4)] text-[rgba(255,165,0,0.9)] hover:bg-[rgba(255,165,0,0.1)] transition-colors">
                Play Again
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 text-center font-mono text-xs text-[var(--color-text-muted)] opacity-60">
        方向键 / WASD 移动 &nbsp;·&nbsp; 移动端支持滑动
      </div>
    </div>
  </div>

  <style>
    .tile {
      width: 100px;
      height: 100px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      font-family: monospace;
      font-weight: bold;
      font-size: 28px;
      transition: transform 0.1s ease, background-color 0.1s ease;
      border: 1px solid rgba(255,255,255,0.05);
    }
    .tile-empty {
      background: rgba(255,255,255,0.03);
      color: transparent;
    }
    .tile-merge {
      animation: pop 0.15s ease;
    }
    @keyframes pop {
      0%   { transform: scale(1); }
      50%  { transform: scale(1.12); }
      100% { transform: scale(1); }
    }
    @media (max-width: 520px) {
      .tile { width: 72px; height: 72px; font-size: 20px; border-radius: 8px; }
      #board { grid-template-columns: repeat(4,72px) !important; grid-template-rows: repeat(4,72px) !important; gap: 10px !important; }
    }
    @media (max-width: 380px) {
      .tile { width: 58px; height: 58px; font-size: 16px; }
      #board { grid-template-columns: repeat(4,58px) !important; grid-template-rows: repeat(4,58px) !important; }
    }
  </style>

  <script is:inline>
document.addEventListener("DOMContentLoaded", function() {

    const COLORS: Record<number, {bg: string; color: string; shadow: string}> = {
      0:    {bg:'rgba(255,255,255,0.03)', color:'transparent', shadow:'none'},
      2:    {bg:'rgba(0,212,255,0.15)',   color:'rgba(0,212,255,0.9)',  shadow:'0 0 16px rgba(0,212,255,0.4)'},
      4:    {bg:'rgba(0,212,255,0.28)',   color:'rgba(0,212,255,1)',    shadow:'0 0 20px rgba(0,212,255,0.6)'},
      8:    {bg:'rgba(57,255,20,0.2)',    color:'rgba(57,255,20,0.9)',  shadow:'0 0 16px rgba(57,255,20,0.4)'},
      16:   {bg:'rgba(57,255,20,0.35)',   color:'rgba(57,255,20,1)',    shadow:'0 0 20px rgba(57,255,20,0.6)'},
      32:   {bg:'rgba(255,165,0,0.2)',    color:'rgba(255,165,0,0.9)', shadow:'0 0 16px rgba(255,165,0,0.4)'},
      64:   {bg:'rgba(255,165,0,0.35)',   color:'rgba(255,165,0,1)',   shadow:'0 0 20px rgba(255,165,0,0.6)'},
      128:  {bg:'rgba(255,0,170,0.2)',    color:'rgba(255,0,170,0.9)', shadow:'0 0 16px rgba(255,0,170,0.4)'},
      256:  {bg:'rgba(255,0,170,0.35)',   color:'rgba(255,0,170,1)',   shadow:'0 0 20px rgba(255,0,170,0.6)'},
      512:  {bg:'rgba(180,0,255,0.2)',    color:'rgba(180,0,255,0.9)', shadow:'0 0 16px rgba(180,0,255,0.4)'},
      1024: {bg:'rgba(180,0,255,0.35)',   color:'rgba(180,0,255,1)',   shadow:'0 0 20px rgba(180,0,255,0.6)'},
      2048: {bg:'rgba(255,255,255,0.15)', color:'rgba(255,255,255,1)', shadow:'0 0 32px rgba(255,255,255,0.8)'},
    }

    function getColor(v: number) {
      return COLORS[v] ?? {bg:'rgba(255,255,255,0.2)', color:'#fff', shadow:'none'}
    }

    function moveLeft(row: number[]): {row: number[]; score: number} {
      const filtered = row.filter(x => x !== 0)
      let score = 0
      for (let i = 0; i < filtered.length - 1; i++) {
        if (filtered[i] === filtered[i + 1]) {
          filtered[i] *= 2
          score += filtered[i]
          filtered.splice(i + 1, 1)
          i++
        }
      }
      while (filtered.length < 4) filtered.push(0)
      return {row: filtered, score}
    }

    function transpose(grid: number[][]): number[][] {
      return grid[0].map((_, c) => grid.map(r => r[c]))
    }

    function reverseRows(grid: number[][]): number[][] {
      return grid.map(r => [...r].reverse())
    }

    type Dir = 'left' | 'right' | 'up' | 'down'

    function move(grid: number[][], dir: Dir): {grid: number[][]; score: number; moved: boolean} {
      let g = grid.map(r => [...r])
      let totalScore = 0
      const origStr = JSON.stringify(g)

      if (dir === 'right') {
        g = reverseRows(g)
        const res = g.map(r => moveLeft(r))
        g = res.map(r => r.row)
        totalScore = res.reduce((s, r) => s + r.score, 0)
        g = reverseRows(g)
      } else if (dir === 'left') {
        const res = g.map(r => moveLeft(r))
        g = res.map(r => r.row)
        totalScore = res.reduce((s, r) => s + r.score, 0)
      } else if (dir === 'up') {
        g = transpose(g)
        const res = g.map(r => moveLeft(r))
        g = res.map(r => r.row)
        totalScore = res.reduce((s, r) => s + r.score, 0)
        g = transpose(g)
      } else if (dir === 'down') {
        g = transpose(g)
        g = reverseRows(g)
        const res = g.map(r => moveLeft(r))
        g = res.map(r => r.row)
        totalScore = res.reduce((s, r) => s + r.score, 0)
        g = reverseRows(g)
        g = transpose(g)
      }

      return {grid: g, score: totalScore, moved: JSON.stringify(g) !== origStr}
    }

    function addRandom(grid: number[][]): number[][] {
      const empty: [number, number][] = []
      for (let r = 0; r < 4; r++)
        for (let c = 0; c < 4; c++)
          if (grid[r][c] === 0) empty.push([r, c])
      if (empty.length === 0) return grid
      const [r, c] = empty[Math.floor(Math.random() * empty.length)]
      const g = grid.map(row => [...row])
      g[r][c] = Math.random() < 0.9 ? 2 : 4
      return g
    }

    function isGameOver(grid: number[][]): boolean {
      for (let r = 0; r < 4; r++)
        for (let c = 0; c < 4; c++) {
          if (grid[r][c] === 0) return false
          if (c < 3 && grid[r][c] === grid[r][c + 1]) return false
          if (r < 3 && grid[r][c] === grid[r + 1][c]) return false
        }
      return true
    }

    function hasWon(grid: number[][]): boolean {
      return grid.some(r => r.some(v => v >= 2048))
    }

    class Game2048 {
      grid: number[][] = []
      score = 0
      best = 0
      won = false
      boardEl = document.getElementById('board')!
      scoreEl = document.getElementById('score')!
      bestEl = document.getElementById('best')!
      overlayEl = document.getElementById('overlay')!
      overlayMsg = document.getElementById('overlay-msg')!

      constructor() {
        this.best = parseInt(localStorage.getItem('2048-best') ?? '0')
        this.bestEl.textContent = String(this.best)
        this.init()
        this.bindKeys()
        this.bindTouch()
      }

      init() {
        this.grid = Array.from({length: 4}, () => Array(4).fill(0))
        this.score = 0
        this.won = false
        this.scoreEl.textContent = '0'
        this.overlayEl.classList.add('hidden')
        this.grid = addRandom(this.grid)
        this.grid = addRandom(this.grid)
        this.render()
      }

      doMove(dir: Dir) {
        const {grid, score, moved} = move(this.grid, dir)
        if (!moved) return
        this.grid = addRandom(grid)
        this.score += score
        if (this.score > this.best) {
          this.best = this.score
          localStorage.setItem('2048-best', String(this.best))
          this.bestEl.textContent = String(this.best)
        }
        this.scoreEl.textContent = String(this.score)
        this.render()

        if (!this.won && hasWon(this.grid)) {
          this.won = true
          setTimeout(() => this.showOverlay('🎉 YOU WIN!', '#39ff14'), 300)
        } else if (isGameOver(this.grid)) {
          setTimeout(() => this.showOverlay('GAME OVER', '#ff4444'), 300)
        }
      }

      showOverlay(msg: string, color: string) {
        this.overlayMsg.textContent = msg
        this.overlayMsg.style.color = color
        this.overlayEl.classList.remove('hidden')
      }

      render() {
        this.boardEl.innerHTML = ''
        for (let r = 0; r < 4; r++) {
          for (let c = 0; c < 4; c++) {
            const v = this.grid[r][c]
            const {bg, color, shadow} = getColor(v)
            const el = document.createElement('div')
            el.className = 'tile' + (v === 0 ? ' tile-empty' : '')
            el.textContent = v === 0 ? '' : String(v)
            el.style.background = bg
            el.style.color = color
            el.style.textShadow = shadow
            el.style.boxShadow = v >= 2048 ? shadow : ''
            this.boardEl.appendChild(el)
          }
        }
      }

      bindKeys() {
        const map: Record<string, Dir> = {
          ArrowLeft:'left', ArrowRight:'right', ArrowUp:'up', ArrowDown:'down',
          a:'left', d:'right', w:'up', s:'down',
          A:'left', D:'right', W:'up', S:'down',
        }
        document.addEventListener('keydown', e => {
          const dir = map[e.key]
          if (dir) { e.preventDefault(); this.doMove(dir) }
        })
      }

      bindTouch() {
        let sx = 0, sy = 0
        const wrapper = document.getElementById('board-wrapper')!
        wrapper.addEventListener('touchstart', e => {
          sx = e.changedTouches[0].clientX
          sy = e.changedTouches[0].clientY
        }, {passive: true})
        wrapper.addEventListener('touchend', e => {
          const dx = e.changedTouches[0].clientX - sx
          const dy = e.changedTouches[0].clientY - sy
          if (Math.max(Math.abs(dx), Math.abs(dy)) < 20) return
          if (Math.abs(dx) > Math.abs(dy)) {
            this.doMove(dx > 0 ? 'right' : 'left')
          } else {
            this.doMove(dy > 0 ? 'down' : 'up')
          }
        }, {passive: true})
      }
    }

    const game = new Game2048()
    ;(window as any)._2048 = game

    document.getElementById('newGame')!.addEventListener('click', () => game.init())
  
});
</script>
</BaseLayout>
