---
import { getCollection, render } from 'astro:content'
import type { GetStaticPaths } from 'astro'
import PostLayout from '../../layouts/PostLayout.astro'

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft)
  return posts.map(post => {
    const slug = post.id.replace(/\.mdx?$/, '')
    return { params: { slug }, props: { post } }
  })
}) satisfies GetStaticPaths

const { post } = Astro.props
const { Content, headings } = await render(post)

const wordCount = post.body?.length ?? 0
const readingTime = Math.max(1, Math.round(wordCount / 600))

// 只保留 h2/h3
const tocHeadings = headings.filter(h => h.depth <= 3)

// 相关文章：按 tags 排序，取前 3 篇
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter(p => !p.id.startsWith('about') && p.id !== post.id)

const postTags = new Set(post.data.tags ?? [])
const related = allPosts
  .map(p => ({
    post: p,
    score: (p.data.tags ?? []).filter(t => postTags.has(t)).length,
  }))
  .filter(x => x.score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map(x => x.post)

// 前后篇导航
const sortedAll = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
const curIdx = sortedAll.findIndex(p => p.id === post.id)
const prevPost = curIdx < sortedAll.length - 1 ? sortedAll[curIdx + 1] : null
const nextPost = curIdx > 0 ? sortedAll[curIdx - 1] : null
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  image={post.data.image}
  readingTime={readingTime}
  headings={tocHeadings}
  related={related.map(p => ({ slug: p.id.replace(/\.mdx?$/, ''), title: p.data.title, tags: p.data.tags ?? [] }))}
  prevPost={prevPost ? { slug: prevPost.id.replace(/\.mdx?$/, ''), title: prevPost.data.title } : null}
  nextPost={nextPost ? { slug: nextPost.id.replace(/\.mdx?$/, ''), title: nextPost.data.title } : null}
>
  <Content />
</PostLayout>
