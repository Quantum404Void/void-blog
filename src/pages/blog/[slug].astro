---
import PostLayout from '../../layouts/PostLayout.astro'
import { getPost, getAllPosts } from '../../lib/db'
import { renderMarkdown } from '../../lib/markdown'

const { slug } = Astro.params

const post = await getPost(slug!)
if (!post) return Astro.redirect('/404')

const { html, headings } = await renderMarkdown(post.content)
const tocHeadings = headings.filter(h => h.depth <= 3)

const wordCount = post.content.length
const readingTime = Math.max(1, Math.round(wordCount / 600))

// 相关文章
const allPosts = (await getAllPosts()).filter(p => p.slug !== slug && p.slug !== 'about')
const postTags = new Set(post.tags)
const related = allPosts
  .map(p => ({ post: p, score: p.tags.filter(t => postTags.has(t)).length }))
  .filter(x => x.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(x => x.post)

// 前后篇导航
const curIdx = allPosts.findIndex(p => p.slug === slug)
const prevPost = curIdx < allPosts.length - 1 ? allPosts[curIdx + 1] : null
const nextPost = curIdx > 0 ? allPosts[curIdx - 1] : null
---

<PostLayout
  title={post.title}
  description={post.description}
  pubDate={new Date(post.pub_date)}
  tags={post.tags}
  readingTime={readingTime}
  headings={tocHeadings}
  related={related.map(p => ({ slug: p.slug, title: p.title, tags: p.tags }))}
  prevPost={prevPost ? { slug: prevPost.slug, title: prevPost.title } : null}
  nextPost={nextPost ? { slug: nextPost.slug, title: nextPost.title } : null}
>
  <div class="prose-content" set:html={html} />
</PostLayout>
