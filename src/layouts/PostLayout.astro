---
import BaseLayout from './BaseLayout.astro'
import ReadingProgress from '../components/ReadingProgress.vue'
import TableOfContents from '../components/TableOfContents.vue'

interface Props {
  title: string
  description?: string
  pubDate: Date
  updatedDate?: Date
  tags?: string[]
  image?: string
  readingTime?: number
  headings?: { depth: number; slug: string; text: string }[]
  related?: { slug: string; title: string; tags: string[] }[]
  prevPost?: { slug: string; title: string } | null
  nextPost?: { slug: string; title: string } | null
}

const { title, description, pubDate, updatedDate, tags = [], image, readingTime, headings = [], related = [], prevPost, nextPost } = Astro.props

const formatDate = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
---

<BaseLayout {title} {description} {pubDate} {tags} {image}>
  <!-- 阅读进度条 -->
  <ReadingProgress client:load />

  <div class="min-h-screen bg-[var(--color-void)]">
    <!-- Nav -->
    <nav class="sticky top-0 z-50 border-b border-[var(--color-void-border)] bg-[rgba(10,10,15,0.8)] backdrop-blur-xl">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center gap-6">
        <a href="/void-blog/" class="font-mono text-sm text-[var(--color-neon-green)] hover:glow-green transition-all">
          ~/void-blog
        </a>
        <span class="text-[var(--color-text-muted)]">/</span>
        <span class="font-mono text-xs text-[var(--color-text-muted)] truncate max-w-xs">{title}</span>
        <div class="ml-auto flex items-center gap-4 text-xs text-[var(--color-text-muted)] font-mono">
          {readingTime && <span>约 {readingTime} 分钟</span>}
        </div>
      </div>
    </nav>

    <!-- Layout: article + TOC -->
    <div class="max-w-6xl mx-auto px-6 py-16 flex gap-12">

      <!-- Article -->
      <main class="flex-1 min-w-0 max-w-3xl">
        <!-- Header -->
        <header class="mb-12">
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-6">
              {tags.map(tag => (
                <a
                  href={`/void-blog/tags/${tag}/`}
                  class="font-mono text-xs px-3 py-1 rounded-full border border-[rgba(0,212,255,0.3)] text-[var(--color-neon-cyan)] bg-[rgba(0,212,255,0.05)] hover:border-[rgba(0,212,255,0.6)] hover:bg-[rgba(0,212,255,0.1)] transition-all"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}

          <h1 class="text-3xl sm:text-4xl font-bold font-mono leading-tight mb-6 text-[var(--color-text-primary)]">
            {title}
          </h1>

          {description && (
            <p class="text-lg text-[var(--color-text-secondary)] mb-6 leading-relaxed">{description}</p>
          )}

          <div class="flex items-center gap-4 text-sm text-[var(--color-text-muted)] font-mono border-t border-[var(--color-void-border)] pt-4">
            <time datetime={pubDate.toISOString()}>
              <span class="text-[var(--color-neon-green)]">$</span> {formatDate(pubDate)}
            </time>
            {updatedDate && (
              <span class="text-xs">(更新于 {formatDate(updatedDate)})</span>
            )}
          </div>
        </header>

        <!-- Content -->
        <article class="prose">
          <slot />
        </article>

        <!-- Footer -->
        <footer class="mt-16 pt-8 border-t border-[var(--color-void-border)] space-y-10">

          <!-- 前后篇导航 -->
          <div class="grid grid-cols-2 gap-4 font-mono text-xs">
            {prevPost ? (
              <a
                href={`/void-blog/blog/${prevPost.slug}/`}
                class="prev-post-link group flex flex-col gap-1 p-4 rounded-xl border border-[var(--color-void-border)] hover:border-[rgba(0,212,255,0.35)] hover:bg-[var(--color-void-card)] transition-all"
              >
                <span class="text-[var(--color-text-muted)] text-[10px] uppercase tracking-widest">← 上一篇</span>
                <span class="text-[var(--color-text-primary)] group-hover:text-[var(--color-neon-cyan)] transition-colors line-clamp-2 leading-snug">{prevPost.title}</span>
              </a>
            ) : <div />}
            {nextPost ? (
              <a
                href={`/void-blog/blog/${nextPost.slug}/`}
                class="next-post-link group flex flex-col gap-1 p-4 rounded-xl border border-[var(--color-void-border)] hover:border-[rgba(0,212,255,0.35)] hover:bg-[var(--color-void-card)] transition-all text-right"
              >
                <span class="text-[var(--color-text-muted)] text-[10px] uppercase tracking-widest">下一篇 →</span>
                <span class="text-[var(--color-text-primary)] group-hover:text-[var(--color-neon-cyan)] transition-colors line-clamp-2 leading-snug">{nextPost.title}</span>
              </a>
            ) : <div />}
          </div>

          <!-- 相关文章 -->
          {related.length > 0 && (
            <div>
              <div class="flex items-center gap-4 mb-5">
                <span class="h-px flex-1 bg-gradient-to-r from-transparent via-[rgba(180,76,255,0.3)] to-transparent"></span>
                <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-[0.2em] flex items-center gap-2">
                  <span class="text-[var(--color-neon-purple)]">&#9654;</span> 相关文章
                </p>
                <span class="h-px flex-1 bg-gradient-to-r from-transparent via-[rgba(180,76,255,0.3)] to-transparent"></span>
              </div>
              <div class="space-y-2">
                {related.map(r => (
                  <a
                    href={`/void-blog/blog/${r.slug}/`}
                    class="group flex items-start gap-3 p-3 rounded-xl border border-transparent hover:border-[var(--color-void-border)] hover:bg-[var(--color-void-card)] transition-all"
                  >
                    <span class="text-[var(--color-neon-purple)] font-mono text-xs mt-0.5">▸</span>
                    <div class="flex-1 min-w-0">
                      <span class="font-mono text-sm text-[var(--color-text-primary)] group-hover:text-[var(--color-neon-cyan)] transition-colors line-clamp-1">{r.title}</span>
                      <div class="flex flex-wrap gap-1.5 mt-1.5">
                        {r.tags.slice(0, 3).map(t => (
                          <span class="font-mono text-[10px] text-[var(--color-text-muted)] bg-[var(--color-void-muted)] px-2 py-0.5 rounded-full">#{t}</span>
                        ))}
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Author / share strip -->
          <div class="flex items-center justify-between flex-wrap gap-4 py-4 border-t border-[var(--color-void-border)]">
            <div class="flex items-center gap-3 font-mono text-xs text-[var(--color-text-muted)]">
              <div class="w-8 h-8 rounded-full border border-[rgba(0,212,255,0.3)] flex items-center justify-center text-sm" style="background:rgba(0,212,255,0.08);color:#00d4ff">王</div>
              <div>
                <div class="text-[var(--color-text-primary)] font-bold" style="font-size:11px">王宇</div>
                <div style="font-size:10px;color:rgba(136,136,170,0.8)">C++ / AI Agent / 桌面应用</div>
              </div>
            </div>
            <div class="flex gap-3 font-mono text-[10px] text-[var(--color-text-muted)]">
              <a href="https://github.com/Quantum505Void" target="_blank" rel="noopener" class="hover:text-[var(--color-neon-green)] transition-colors">GitHub</a>
              <a href="/void-blog/rss.xml" class="hover:text-[var(--color-neon-cyan)] transition-colors">RSS</a>
            </div>
          </div>

          <a
            href="/void-blog/"
            class="font-mono text-sm text-[var(--color-neon-cyan)] hover:text-[var(--color-neon-green)] transition-colors flex items-center gap-2"
          >
            <span>←</span> 返回首页
          </a>
        </footer>
      </main>

      <!-- TOC Sidebar -->
      {headings.length > 1 && (
        <aside class="hidden xl:block w-52 shrink-0">
          <TableOfContents headings={headings} client:load />
        </aside>
      )}
    </div>
  </div>

  <!-- 代码块复制按钮 + 语言 badge -->
  <script>
    function enhanceCodeBlocks() {
      document.querySelectorAll('pre.astro-code').forEach((pre) => {
        // 文件名 badge：检测第一行的 // filename: xxx.ts 注释
        const codeEl = pre.querySelector('code')
        if (codeEl && !pre.querySelector('.filename-badge')) {
          const firstLine = codeEl.querySelector('.line:first-child, span:first-child')
          const rawText = codeEl.innerText.split('\n')[0]?.trim() ?? ''
          const filenameMatch = rawText.match(/^\/\/\s*filename:\s*(.+)$/)
          if (filenameMatch) {
            const badge = document.createElement('span')
            badge.className = 'filename-badge'
            badge.textContent = filenameMatch[1].trim()
            badge.style.cssText = `
              position: absolute; top: 0; left: 0; right: 0;
              display: flex; align-items: center;
              font-family: var(--font-mono); font-size: 11px;
              padding: 4px 12px 4px 12px;
              color: rgba(232,232,240,0.85);
              background: rgba(19,19,31,0.9);
              border-bottom: 1px solid rgba(30,30,48,0.8);
              border-radius: 0.75rem 0.75rem 0 0;
              z-index: 5;
              pointer-events: none;
            `
            const icon = document.createElement('span')
            icon.textContent = '📄 '
            icon.style.fontSize = '10px'
            badge.prepend(icon)
            ;(pre as HTMLElement).style.paddingTop = '2.5rem'
            pre.insertBefore(badge, pre.firstChild)
            // Hide the first line that contains the comment
            if (firstLine) (firstLine as HTMLElement).style.display = 'none'
          }
        }

        // 语言 badge：从 class="astro-code language-xxx" 提取
        if (!pre.hasAttribute('data-lang')) {
          const cls = Array.from(pre.classList).find(c => c.startsWith('language-'))
          const lang = cls ? cls.replace('language-', '') : ''
          if (lang && lang !== 'text') pre.setAttribute('data-lang', lang)
        }

        // 复制按钮
        if (pre.querySelector('.copy-btn')) return
        const btn = document.createElement('button')
        btn.className = 'copy-btn'
        btn.innerHTML = '复制'
        btn.style.cssText = `
          position: absolute; top: 0.5rem; right: 0.75rem;
          font-family: var(--font-mono); font-size: 11px;
          padding: 3px 8px; border-radius: 4px; cursor: pointer;
          background: rgba(0,212,255,0.1); color: rgba(0,212,255,0.7);
          border: 1px solid rgba(0,212,255,0.25); transition: all 0.2s;
          opacity: 0; z-index: 10;
        `
        ;(pre as HTMLElement).style.position = 'relative'
        pre.addEventListener('mouseenter', () => { btn.style.opacity = '1' })
        pre.addEventListener('mouseleave', () => { btn.style.opacity = '0' })
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.innerText ?? ''
          await navigator.clipboard.writeText(code)
          btn.innerHTML = '已复制 ✓'
          btn.style.color = 'rgba(0,255,136,0.9)'
          btn.style.borderColor = 'rgba(0,255,136,0.4)'
          setTimeout(() => {
            btn.innerHTML = '复制'
            btn.style.color = 'rgba(0,212,255,0.7)'
            btn.style.borderColor = 'rgba(0,212,255,0.25)'
          }, 2000)
        })
        pre.appendChild(btn)
      })
    }
    document.addEventListener('DOMContentLoaded', enhanceCodeBlocks)
    enhanceCodeBlocks()
  </script>
</BaseLayout>
